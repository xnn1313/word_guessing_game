.history-list {
  display: flex;
  flex-direction: column;
}

.history-row {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: space-between;
  padding: 13rpx 6rpx;
  border-bottom: 2rpx solid #e7eeeb;
}

.history-row:last-child {
  border-bottom: none;
}

.history-row.latest {
  margin: 0 -8rpx;
  padding-right: 14rpx;
  padding-left: 14rpx;
  border-bottom-color: transparent;
  border-radius: 15rpx;
  background: #e5f5f1;
}

.word-wrap {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: center;
}

.history-word {
  overflow: hidden;
  color: #17383b;
  font-size: 28rpx;
  font-weight: 680;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.latest-mark {
  display: grid;
  width: 30rpx;
  height: 30rpx;
  flex: 0 0 auto;
  margin-left: 10rpx;
  place-items: center;
  border-radius: 8rpx;
  background: #0f8f82;
  color: #ffffff;
  font-size: 17rpx;
  font-weight: 740;
}

.score-wrap {
  width: 188rpx;
  flex: 0 0 auto;
  margin-left: 18rpx;
}

.history-value {
  display: block;
  font-size: 24rpx;
  font-weight: 760;
  font-variant-numeric: tabular-nums;
  text-align: right;
}

.score-track {
  width: 100%;
  height: 7rpx;
  margin-top: 7rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dfe8e5;
}

.score-fill {
  min-width: 5rpx;
  height: 100%;
  border-radius: inherit;
}

.history-value.tone-high { color: #087568; }
.history-value.tone-mid { color: #9a6615; }
.history-value.tone-low { color: #bd4c48; }
.history-value.tone-zero { color: #778986; }
.score-fill.tone-high { background: #0f8f82; }
.score-fill.tone-mid { background: #d9a63c; }
.score-fill.tone-low { background: #df6a65; }
.score-fill.tone-zero { background: #93a39f; }

.history-empty {
  display: flex;
  min-height: 220rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #718582;
  font-size: 23rpx;
  text-align: center;
}

.empty-rings {
  display: flex;
  gap: 9rpx;
  margin-bottom: 20rpx;
}

.empty-rings text {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #b5ddd6;
  border-radius: 50%;
}

.empty-rings text:nth-child(2) { border-color: #63b9aa; }
.empty-rings text:nth-child(3) { border-color: #0f8f82; }
