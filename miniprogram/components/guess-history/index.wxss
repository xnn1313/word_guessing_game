.history-list {
  display: flex;
  flex-direction: column;
}

.history-row {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 12rpx 8rpx;
  border-bottom: 2rpx solid #dfe3f1;
}

.history-row:last-child { border-bottom: none; }

.history-row.latest {
  margin: 0 -8rpx;
  padding-right: 16rpx;
  padding-left: 16rpx;
  border: 3rpx solid #151b3a;
  border-radius: 16rpx;
  background: #dfe5ff;
}

.word-wrap { display: flex; min-width: 0; flex: 1; align-items: center; }
.history-word { overflow: hidden; color: #151b3a; font-size: 27rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }

.latest-mark {
  display: grid;
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 auto;
  margin-left: 10rpx;
  place-items: center;
  border: 2rpx solid #151b3a;
  border-radius: 8rpx;
  background: #3157ff;
  color: #ffffff;
  font-size: 17rpx;
  font-weight: 850;
}

.score-wrap { width: 190rpx; flex: 0 0 auto; }
.history-value { display: block; font-size: 24rpx; font-weight: 900; font-variant-numeric: tabular-nums; text-align: right; }
.score-track { width: 100%; height: 9rpx; margin-top: 6rpx; overflow: hidden; border: 2rpx solid #151b3a; border-radius: 99rpx; background: #ffffff; }
.score-fill { min-width: 5rpx; height: 100%; }
.history-value.tone-high { color: #2342d8; }
.history-value.tone-mid { color: #8f6200; }
.history-value.tone-low { color: #b83540; }
.history-value.tone-zero { color: #70778f; }
.score-fill.tone-high { background: #3157ff; }
.score-fill.tone-mid { background: #ffd84d; }
.score-fill.tone-low { background: #ff7f75; }
.score-fill.tone-zero { background: #b8bfd3; }

.history-empty {
  display: flex;
  min-height: 230rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #646c89;
  font-size: 23rpx;
  text-align: center;
}

.empty-rings { display: flex; gap: 10rpx; margin-bottom: 18rpx; }
.empty-rings text { width: 22rpx; height: 22rpx; border: 4rpx solid #3157ff; border-radius: 6rpx; transform: rotate(8deg); }
.empty-rings text:nth-child(2) { border-color: #ff7f75; transform: rotate(-8deg); }
.empty-rings text:nth-child(3) { border-color: #ffd84d; transform: rotate(5deg); }
