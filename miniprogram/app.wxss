page {
  --color-bg: #f3f7f5;
  --color-surface: #ffffff;
  --color-primary: #12a37f;
  --color-primary-dark: #08735c;
  --color-primary-soft: #e4f6f0;
  --color-night: #17343b;
  --color-night-soft: #244850;
  --color-accent: #ffc857;
  --color-text: #172b2b;
  --color-muted: #71817d;
  --color-border: #dce7e3;
  --color-success: #168b68;
  --color-warning: #bd7426;
  --color-danger: #d2535a;
  min-height: 100%;
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
  line-height: 1.4;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(36rpx + env(safe-area-inset-bottom));
}

.surface {
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 24rpx rgba(22, 50, 49, 0.045);
}

.page-title {
  color: var(--color-text);
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.section-title {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 760;
}

.primary-button,
.secondary-button,
.danger-button {
  width: 100%;
  min-height: 88rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 760;
  line-height: 88rpx;
  text-align: center;
}

.primary-button {
  background: var(--color-primary);
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(18, 163, 127, 0.2);
}

.secondary-button {
  border: 2rpx solid #b9d9cf;
  background: #ffffff;
  color: var(--color-primary-dark);
}

.danger-button {
  border: 2rpx solid #edcfd1;
  background: #fffafa;
  color: var(--color-danger);
}

.primary-button[disabled],
.secondary-button[disabled],
.danger-button[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

.text-input {
  width: 100%;
  height: 86rpx;
  padding: 0 26rpx;
  border: 2rpx solid #d7e4df;
  border-radius: 20rpx;
  background: #f8fbfa;
  color: var(--color-text);
  font-size: 29rpx;
}

.text-input:focus {
  border-color: var(--color-primary);
  background: #ffffff;
}

.empty-state,
.loading-state {
  color: #92a09c;
  font-size: 24rpx;
  text-align: center;
}

.empty-state {
  padding: 56rpx 22rpx;
}

.loading-state {
  padding: 120rpx 24rpx;
}
