page {
  --color-bg: #f3f0e7;
  --color-surface: #fffdf7;
  --color-primary: #168f82;
  --color-primary-dark: #08766f;
  --color-primary-soft: #e5f4f0;
  --color-night: #19323a;
  --color-night-soft: #2e4b52;
  --color-accent: #ffd166;
  --color-coral: #f36f61;
  --color-mint: #43c6b7;
  --color-text: #19323a;
  --color-muted: #718087;
  --color-border: #d7d0c2;
  --color-ink: #19323a;
  --color-success: #128472;
  --color-warning: #b9741f;
  --color-danger: #d85f56;
  min-height: 100%;
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
  line-height: 1.4;
  transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
}

button::after {
  border: none;
}

button:active {
  opacity: 0.92;
  transform: translateY(3rpx);
}

.card-pressed,
.hero-pressed,
.level-pressed {
  opacity: 0.92;
  transform: translateY(3rpx);
}

.page-shell {
  min-height: 100vh;
  padding: 30rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
}

.surface {
  border: 3rpx solid var(--color-ink);
  border-radius: 26rpx;
  background: var(--color-surface);
  box-shadow: 7rpx 7rpx 0 rgba(41, 45, 58, 0.1);
}

.page-title {
  color: var(--color-text);
  font-size: 48rpx;
  font-weight: 850;
  letter-spacing: -2rpx;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 23rpx;
  line-height: 1.55;
}

.page-kicker {
  display: flex;
  align-items: center;
  gap: 9rpx;
  margin-bottom: 8rpx;
  color: var(--color-primary-dark);
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.page-kicker::before {
  width: 18rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: var(--color-coral);
  content: "";
}

.section-title {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 800;
}

.primary-button,
.secondary-button,
.danger-button {
  width: 100%;
  min-height: 88rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 760;
  line-height: 88rpx;
  text-align: center;
}

.primary-button {
  background: var(--color-primary);
  color: #ffffff;
  box-shadow: 6rpx 6rpx 0 var(--color-ink);
}

.secondary-button {
  background: var(--color-surface);
  color: var(--color-primary-dark);
  box-shadow: 5rpx 5rpx 0 rgba(41, 45, 58, 0.12);
}

.danger-button {
  background: #fff3f1;
  color: var(--color-danger);
}

.primary-button:active,
.secondary-button:active {
  box-shadow: 2rpx 2rpx 0 var(--color-ink);
}

.primary-button[disabled],
.secondary-button[disabled],
.danger-button[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

.text-input {
  width: 100%;
  height: 86rpx;
  padding: 0 26rpx;
  border: 3rpx solid #cfc8bb;
  border-radius: 18rpx;
  background: var(--color-surface);
  color: var(--color-text);
  font-size: 29rpx;
}

.text-input:focus {
  border-color: var(--color-primary);
  background: #ffffff;
  box-shadow: 0 0 0 5rpx rgba(22, 143, 130, 0.12);
}

.empty-state,
.loading-state {
  color: #8a8790;
  font-size: 24rpx;
  text-align: center;
}

.empty-state {
  padding: 56rpx 22rpx;
}

.loading-state {
  padding: 120rpx 24rpx;
}

/* Unified typography and control scale */
page {
  --font-display: 44rpx;
  --font-section: 30rpx;
  --font-body: 24rpx;
  --font-control: 27rpx;
  --font-caption: 20rpx;
  --control-height: 84rpx;
  font-size: 26rpx;
}

.page-title {
  font-size: var(--font-display);
  line-height: 1.18;
}

.page-subtitle {
  font-size: var(--font-body);
  line-height: 1.5;
}

.page-kicker {
  font-size: 18rpx;
}

.section-title {
  font-size: var(--font-section);
}

.primary-button,
.secondary-button,
.danger-button {
  min-height: var(--control-height);
  font-size: var(--font-control);
  line-height: var(--control-height);
}

.text-input {
  height: var(--control-height);
  font-size: 26rpx;
}

.control-disabled {
  opacity: 0.38;
  box-shadow: none !important;
  transform: none !important;
}
