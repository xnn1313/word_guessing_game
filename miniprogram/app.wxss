page {
  --color-bg: #f1f3ff;
  --color-surface: #ffffff;
  --color-surface-soft: #f8f9ff;
  --color-primary: #3157ff;
  --color-primary-dark: #2342d8;
  --color-primary-soft: #dfe5ff;
  --color-yellow: #ffd84d;
  --color-yellow-soft: #fff4bd;
  --color-coral: #ff7f75;
  --color-coral-soft: #ffe2df;
  --color-aqua: #63ddd0;
  --color-aqua-soft: #dff9f5;
  --color-violet: #b6a4ff;
  --color-violet-soft: #eeeaff;
  --color-ink: #151b3a;
  --color-text: #17204a;
  --color-muted: #646c89;
  --color-subtle: #9299b0;
  --color-border: #cbd1e6;
  --color-success: #148f80;
  --color-warning: #9d6a00;
  --color-danger: #c63f48;
  --shadow-hard: 8rpx 8rpx 0 #151b3a;
  --shadow-soft: 0 14rpx 34rpx rgba(40, 55, 130, 0.11);
  --radius-card: 28rpx;
  --radius-control: 18rpx;
  --font-display: 48rpx;
  --font-title: 36rpx;
  --font-section: 31rpx;
  --font-body: 27rpx;
  --font-control: 27rpx;
  --font-label: 23rpx;
  --font-caption: 20rpx;
  --control-height: 88rpx;
  min-height: 100%;
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: var(--font-body);
  line-height: 1.5;
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

button {
  min-width: 0;
  max-width: 100%;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
  line-height: 1.4;
  transition: opacity 140ms ease, transform 140ms ease, background-color 180ms ease, box-shadow 180ms ease;
}

button::after {
  border: none;
}

button:active {
  opacity: 0.9;
  transform: translate(2rpx, 2rpx);
}

.card-pressed,
.hero-pressed,
.level-pressed,
.nav-pressed {
  opacity: 0.9;
  transform: translate(4rpx, 4rpx);
}

.page-shell {
  width: 100%;
  min-height: 100vh;
  padding: 30rpx 32rpx calc(44rpx + env(safe-area-inset-bottom));
}

.surface,
.block-card {
  border: 3rpx solid var(--color-ink);
  border-radius: var(--radius-card);
  background: var(--color-surface);
  box-shadow: var(--shadow-hard);
}

.page-kicker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  color: var(--color-primary-dark);
  font-size: 19rpx;
  font-weight: 850;
  letter-spacing: 3rpx;
  line-height: 1.3;
}

.page-kicker::before {
  width: 24rpx;
  height: 7rpx;
  flex: 0 0 auto;
  border-radius: 99rpx;
  background: var(--color-coral);
  content: "";
}

.page-title {
  color: var(--color-ink);
  font-size: var(--font-display);
  font-weight: 900;
  letter-spacing: -2rpx;
  line-height: 1.14;
}

.page-subtitle,
.game-hint {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: var(--font-body);
  line-height: 1.55;
}

.section-title {
  color: var(--color-ink);
  font-size: var(--font-section);
  font-weight: 850;
  line-height: 1.25;
}

.primary-button,
.secondary-button,
.danger-button {
  display: grid;
  width: 100%;
  min-height: var(--control-height);
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: var(--radius-control);
  font-size: var(--font-control);
  font-weight: 850;
  line-height: 1.25;
  text-align: center;
}

.primary-button {
  background: var(--color-primary);
  color: #ffffff;
  box-shadow: 6rpx 6rpx 0 var(--color-ink);
}

.secondary-button {
  background: var(--color-yellow);
  color: var(--color-ink);
  box-shadow: 5rpx 5rpx 0 var(--color-ink);
}

.danger-button {
  border-color: var(--color-danger);
  background: var(--color-coral-soft);
  color: var(--color-danger);
}

.primary-button[disabled],
.secondary-button[disabled],
.danger-button[disabled],
.control-disabled {
  opacity: 0.4;
  box-shadow: none !important;
  transform: none !important;
}

.text-input {
  width: 100%;
  height: var(--control-height);
  padding: 0 24rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: var(--radius-control);
  background: var(--color-surface);
  color: var(--color-ink);
  font-size: 27rpx;
}

.text-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(49, 87, 255, 0.14);
}

.loading-state,
.empty-state {
  color: var(--color-muted);
  font-size: 24rpx;
  text-align: center;
}

.loading-state {
  margin: 32rpx 0;
  padding: 54rpx 24rpx;
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-card);
  background: rgba(255, 255, 255, 0.66);
}

.empty-state {
  padding: 56rpx 22rpx;
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  overflow: hidden;
  border: 3rpx solid var(--color-ink);
  border-radius: 22rpx;
  background: var(--color-ink);
  color: #ffffff;
}

.status-strip > view {
  display: flex;
  min-height: 94rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border-right: 2rpx solid rgba(255, 255, 255, 0.16);
}

.status-strip > view:last-child {
  border-right: none;
}

.status-strip > view > text:first-child {
  color: #c9cee5;
  font-size: 19rpx;
}

.status-strip > view > text:last-child {
  margin-top: 4rpx;
  color: var(--color-yellow);
  font-size: 29rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.segmented-control {
  display: grid;
  padding: 6rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  background: var(--color-primary-soft);
}

.segmented-control button {
  min-height: 88rpx;
  border-radius: 14rpx;
  color: var(--color-muted);
  font-weight: 800;
}

.segmented-control button.active {
  background: var(--color-surface);
  color: var(--color-primary-dark);
  box-shadow: 0 4rpx 0 rgba(21, 27, 58, 0.16);
}

.app-tabbar {
  position: fixed;
  z-index: 30;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  min-height: calc(126rpx + env(safe-area-inset-bottom));
  padding: 8rpx 28rpx calc(8rpx + env(safe-area-inset-bottom));
  border: 3rpx solid var(--color-ink);
  border-bottom: 0;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -10rpx 28rpx rgba(21, 27, 58, 0.1);
}

.app-tab-item {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  flex-direction: column;
  border-radius: 18rpx;
  color: var(--color-muted);
  font-size: 20rpx;
  font-weight: 750;
}

.app-tab-item.active {
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
}

.nav-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  color: currentColor;
}

.nav-games {
  border: 3rpx solid currentColor;
  border-radius: 9rpx;
}

.nav-games::before {
  position: absolute;
  top: 7rpx;
  left: 7rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 11rpx 0 0 currentColor, 0 11rpx 0 currentColor, 11rpx 11rpx 0 currentColor;
  content: "";
}

.nav-records {
  border: 3rpx solid currentColor;
  border-radius: 7rpx;
}

.nav-records::before,
.nav-records::after {
  position: absolute;
  right: 6rpx;
  left: 6rpx;
  height: 3rpx;
  background: currentColor;
  content: "";
}

.nav-records::before { top: 9rpx; }
.nav-records::after { top: 18rpx; }

.nav-profile::before {
  position: absolute;
  top: 1rpx;
  left: 9rpx;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  content: "";
}

.nav-profile::after {
  position: absolute;
  right: 3rpx;
  bottom: 0;
  left: 3rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
  content: "";
}

@media (max-height: 700px) {
  .page-shell {
    padding-top: 22rpx;
  }

  .page-title {
    font-size: 43rpx;
  }
}

@media (prefers-reduced-motion: reduce) {
  button,
  .card-pressed,
  .hero-pressed,
  .level-pressed,
  .nav-pressed {
    transition-duration: 0.01ms !important;
  }
}
