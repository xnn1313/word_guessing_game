{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "typeRoots": ["./typings"]
  },
  "include": ["**/*.ts", "typings/**/*.d.ts"],
  "exclude": ["node_modules", "miniprogram_npm"]
}
