.hub-page {
  position: relative;
  padding-bottom: calc(174rpx + env(safe-area-inset-bottom));
}

.hub-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hub-heading {
  min-width: 0;
  flex: 1;
}

.hub-heading .page-title {
  display: flex;
  max-width: 500rpx;
  flex-direction: column;
  font-size: 54rpx;
}

.account-button {
  display: grid;
  width: 94rpx;
  height: 94rpx;
  flex: 0 0 auto;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 50%;
  background: var(--color-aqua-soft);
  box-shadow: 5rpx 5rpx 0 var(--color-ink);
}

.account-avatar {
  display: grid;
  width: 58rpx;
  height: 58rpx;
  place-items: center;
  border-radius: 50%;
  background: var(--color-aqua);
  color: var(--color-ink);
  font-size: 26rpx;
  font-weight: 900;
  text-transform: uppercase;
}

.account-button.signed .account-avatar {
  background: var(--color-yellow);
}

.training-summary {
  position: relative;
  display: flex;
  min-height: 230rpx;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 34rpx;
  overflow: hidden;
  padding: 34rpx 34rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 30rpx;
  background: var(--color-primary);
  box-shadow: var(--shadow-hard);
  color: #ffffff;
}

.training-summary::before,
.training-summary::after {
  position: absolute;
  border: 18rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
  content: "";
}

.training-summary::before {
  top: -70rpx;
  right: 120rpx;
  width: 180rpx;
  height: 180rpx;
}

.training-summary::after {
  right: -50rpx;
  bottom: -90rpx;
  width: 210rpx;
  height: 210rpx;
}

.training-copy {
  position: relative;
  z-index: 1;
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.training-label {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.training-value {
  margin-top: 7rpx;
  color: var(--color-yellow);
  font-size: 43rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.training-note {
  max-width: 420rpx;
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 22rpx;
}

.training-ring {
  position: relative;
  z-index: 1;
  display: flex;
  width: 116rpx;
  height: 116rpx;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  flex-direction: column;
  border: 13rpx solid var(--color-yellow);
  border-radius: 50%;
  background: var(--color-primary-dark);
}

.training-ring::after {
  position: absolute;
  top: -13rpx;
  right: -13rpx;
  bottom: -13rpx;
  left: -13rpx;
  border: 13rpx solid transparent;
  border-top-color: var(--color-aqua);
  border-right-color: var(--color-aqua);
  border-radius: 50%;
  content: "";
}

.training-ring text:first-child {
  font-size: 31rpx;
  font-weight: 900;
}

.training-ring text:last-child {
  color: #ffffff;
  font-size: 17rpx;
}

.library-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 44rpx 0 20rpx;
}

.library-count {
  color: var(--color-muted);
  font-size: 22rpx;
}

.game-library {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.game-card {
  position: relative;
  display: flex;
  min-height: 238rpx;
  padding: 22rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 26rpx;
  box-shadow: 7rpx 7rpx 0 var(--color-ink);
  flex-direction: column;
}

.game-card:nth-child(1) { background: var(--color-yellow); }
.game-card:nth-child(2) { background: var(--color-aqua); }
.game-card:nth-child(3) { background: var(--color-coral); }
.game-card:nth-child(4) { background: var(--color-violet); }
.game-card:nth-child(5) { background: var(--color-primary-soft); }
.game-card.word-search-card { min-height: 188rpx; grid-column: 1 / -1; }
.word-search-card .game-copy { max-width: 76%; }
.word-search-card .game-progress { max-width: 340rpx; }

.game-icon {
  display: grid;
  width: 62rpx;
  height: 62rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.38);
  color: var(--color-ink);
  font-size: 28rpx;
  font-weight: 900;
}

.game-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  margin-top: 18rpx;
  flex-direction: column;
}

.game-name {
  color: var(--color-ink);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.game-description {
  display: -webkit-box;
  margin-top: 7rpx;
  overflow: hidden;
  color: rgba(21, 27, 58, 0.72);
  font-size: 20rpx;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.game-progress {
  width: 88%;
  height: 7rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border: 2rpx solid var(--color-ink);
  border-radius: 99rpx;
  background: rgba(255, 255, 255, 0.45);
}

.game-progress > view {
  min-width: 5rpx;
  height: 100%;
  background: var(--color-primary);
}

.game-action {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  display: grid;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 50%;
  background: #ffffff;
}

.game-action.status-text {
  width: auto;
  padding: 0 12rpx;
  border-radius: 14rpx;
  font-size: 18rpx;
  font-weight: 800;
}

.arrow-icon {
  position: relative;
  width: 20rpx;
  height: 3rpx;
  background: var(--color-ink);
}

.arrow-icon::after {
  position: absolute;
  top: -5rpx;
  right: 0;
  width: 10rpx;
  height: 10rpx;
  border-top: 3rpx solid var(--color-ink);
  border-right: 3rpx solid var(--color-ink);
  transform: rotate(45deg);
  content: "";
}

.game-card.unavailable {
  opacity: 0.62;
}

@media (max-height: 700px) {
  .training-summary { min-height: 204rpx; margin-top: 24rpx; }
  .library-heading { margin-top: 34rpx; }
  .game-card { min-height: 220rpx; }
}
