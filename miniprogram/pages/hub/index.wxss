.hub-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  padding-top: 24rpx;
  background:
    radial-gradient(circle at 5% 4%, rgba(67, 198, 183, 0.12), transparent 24%),
    radial-gradient(circle at 96% 3%, rgba(255, 209, 102, 0.14), transparent 22%),
    var(--color-bg);
}

.hub-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.hub-heading {
  min-width: 0;
  flex: 1;
}

.account-button {
  display: grid;
  width: 74rpx;
  min-width: 74rpx;
  max-width: 74rpx;
  height: 74rpx;
  min-height: 74rpx;
  max-height: 74rpx;
  flex: 0 0 auto;
  padding: 0;
  overflow: hidden;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 4rpx 4rpx 0 var(--color-ink);
  line-height: 1;
}

.account-avatar {
  color: var(--color-ink);
  font-size: 27rpx;
  font-weight: 850;
}

.account-button.signed {
  background: var(--color-primary-soft);
}

.training-summary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 120rpx;
  gap: 24rpx;
  align-items: center;
  min-height: 222rpx;
  margin-top: 36rpx;
  padding: 30rpx 32rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 28rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 8rpx 8rpx 0 var(--color-primary);
}

.training-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.training-label {
  color: rgba(255, 255, 255, 0.62);
  font-size: 21rpx;
}

.training-value {
  margin-top: 8rpx;
  color: var(--color-accent);
  font-size: 42rpx;
  font-weight: 880;
  line-height: 1.15;
}

.training-note {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 19rpx;
  line-height: 1.45;
}

.training-ring {
  display: flex;
  width: 112rpx;
  height: 112rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border: 12rpx solid rgba(255, 255, 255, 0.14);
  border-top-color: var(--color-accent);
  border-right-color: var(--color-mint);
  border-radius: 50%;
}

.training-ring text:first-child {
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1;
}

.training-ring text:last-child {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 17rpx;
}

.library-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 42rpx;
}

.library-filter {
  display: flex;
  gap: 4rpx;
  padding: 5rpx;
  border-radius: 999rpx;
  background: #e4e0d7;
}

.library-filter text {
  min-width: 62rpx;
  padding: 8rpx 13rpx;
  border-radius: 999rpx;
  color: var(--color-muted);
  font-size: 19rpx;
  text-align: center;
}

.library-filter .active {
  background: var(--color-surface);
  color: var(--color-text);
  font-weight: 750;
  box-shadow: 0 2rpx 7rpx rgba(25, 50, 58, 0.08);
}

.game-library {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-top: 20rpx;
}

.game-card {
  display: grid;
  grid-template-columns: 82rpx minmax(0, 1fr) 104rpx;
  gap: 20rpx;
  align-items: center;
  min-height: 138rpx;
  padding: 20rpx 22rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 24rpx;
  background: var(--color-surface);
}

.game-card.playable {
  box-shadow: 6rpx 6rpx 0 rgba(25, 50, 58, 0.13);
}

.game-card.card-pressed {
  box-shadow: 2rpx 2rpx 0 rgba(25, 50, 58, 0.13);
}

.game-icon {
  display: grid;
  width: 82rpx;
  height: 82rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 22rpx;
  color: var(--color-ink);
  font-size: 31rpx;
  font-weight: 850;
}

.game-icon.word { background: var(--color-accent); }
.game-icon.sudoku { background: #dceffb; }
.game-icon.idiom { background: #fee1dc; }
.game-icon.memory { background: #eee6ff; }

.game-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.game-name {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 820;
}

.game-description {
  overflow: hidden;
  margin-top: 7rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-progress {
  width: 180rpx;
  height: 7rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 7rpx;
  background: #e6e1d8;
}

.game-progress view {
  min-width: 8rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--color-primary);
}

.game-action {
  display: grid;
  width: 58rpx;
  height: 58rpx;
  justify-self: end;
  place-items: center;
  border: 2rpx solid var(--color-ink);
  border-radius: 50%;
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
  font-size: 25rpx;
  font-weight: 850;
}

.upcoming {
  border-color: #9c9a93;
  box-shadow: none;
}

.coming-tag {
  justify-self: end;
  color: var(--color-coral);
  font-size: 19rpx;
  font-weight: 750;
  white-space: nowrap;
}

.coming-tag.planned {
  color: var(--color-muted);
}

.hub-nav {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: auto;
  padding: 20rpx 10rpx 0;
  border-top: 2rpx solid rgba(25, 50, 58, 0.14);
}

.hub-nav-item {
  display: flex;
  align-items: center;
  gap: 7rpx;
  flex-direction: column;
  color: var(--color-muted);
  font-size: 19rpx;
}

.hub-nav-item > text:first-child {
  font-size: 20rpx;
}

.hub-nav-item.active {
  color: var(--color-primary-dark);
  font-weight: 800;
}

@media (max-height: 700px) {
  .training-summary {
    min-height: 176rpx;
    margin-top: 26rpx;
    padding-top: 24rpx;
    padding-bottom: 24rpx;
  }

  .library-heading {
    margin-top: 32rpx;
  }

  .game-card {
    min-height: 120rpx;
  }
}
