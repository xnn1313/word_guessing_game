.hub-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  background:
    linear-gradient(180deg, rgba(223, 244, 239, 0.82) 0, rgba(242, 246, 243, 0) 300rpx),
    var(--color-bg);
}

.hub-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hub-heading {
  min-width: 0;
  flex: 1;
}

.account-button {
  display: grid;
  width: 88rpx;
  height: 88rpx;
  flex: 0 0 auto;
  place-items: center;
  border: 2rpx solid var(--color-border-strong);
  border-radius: 50%;
  background: var(--color-surface);
  box-shadow: 0 8rpx 22rpx rgba(22, 54, 58, 0.1);
}

.account-avatar {
  color: var(--color-primary-dark);
  font-size: 28rpx;
  font-weight: 800;
}

.account-button.signed {
  border-color: #87cfc4;
  background: var(--color-primary-soft);
}

.training-summary {
  position: relative;
  display: grid;
  min-height: 208rpx;
  grid-template-columns: minmax(0, 1fr) 120rpx;
  gap: 28rpx;
  align-items: center;
  margin-top: 34rpx;
  padding: 30rpx 32rpx 30rpx 38rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(22, 54, 58, 0.17);
}

.training-summary::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 8rpx;
  background: linear-gradient(180deg, var(--color-mint), var(--color-accent));
  content: "";
}

.training-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.training-label {
  color: rgba(255, 255, 255, 0.66);
  font-size: var(--font-label);
}

.training-value {
  margin-top: 8rpx;
  color: var(--color-accent);
  font-size: 40rpx;
  font-weight: 820;
  font-variant-numeric: tabular-nums;
  line-height: 1.18;
}

.training-note {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: var(--font-caption);
  line-height: 1.45;
}

.training-ring {
  display: flex;
  width: 112rpx;
  height: 112rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border: 10rpx solid rgba(255, 255, 255, 0.12);
  border-top-color: var(--color-accent);
  border-right-color: var(--color-mint);
  border-radius: 50%;
}

.training-ring text:first-child {
  font-size: 32rpx;
  font-weight: 820;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.training-ring text:last-child {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 19rpx;
}

.library-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
}

.library-filter {
  display: flex;
  gap: 4rpx;
  padding: 5rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 999rpx;
  background: #e7eeeb;
}

.library-filter text {
  min-width: 68rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: var(--color-muted);
  font-size: 19rpx;
  text-align: center;
}

.library-filter .active {
  background: var(--color-surface);
  color: var(--color-text);
  font-weight: 740;
  box-shadow: 0 3rpx 9rpx rgba(22, 54, 58, 0.08);
}

.game-library {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.game-card {
  display: grid;
  min-height: 136rpx;
  grid-template-columns: 84rpx minmax(0, 1fr) 68rpx;
  gap: 20rpx;
  align-items: center;
  padding: 20rpx 22rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 22rpx rgba(22, 54, 58, 0.07);
  transition: opacity 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.game-card.card-pressed {
  box-shadow: 0 3rpx 10rpx rgba(22, 54, 58, 0.08);
}

.game-card.unavailable {
  border-color: #d5deda;
  opacity: 0.62;
  box-shadow: none;
}

.game-icon {
  display: grid;
  width: 84rpx;
  height: 84rpx;
  place-items: center;
  border-radius: 21rpx;
  color: var(--color-ink);
  font-size: 31rpx;
  font-weight: 820;
}

.game-icon.word { background: #ffe3a0; }
.game-icon.sudoku { background: #dceef7; }
.game-icon.idiom { background: #fbdedb; }
.game-icon.memory { background: #e9e4f7; }

.game-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.game-name {
  color: var(--color-text);
  font-size: 29rpx;
  font-weight: 780;
  line-height: 1.25;
}

.game-description {
  overflow: hidden;
  margin-top: 7rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-progress {
  width: 184rpx;
  height: 7rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e3ebe8;
}

.game-progress view {
  min-width: 8rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--color-primary);
}

.game-action {
  display: grid;
  width: 62rpx;
  height: 62rpx;
  justify-self: end;
  place-items: center;
  border: 2rpx solid #aad5ce;
  border-radius: 50%;
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
}

.game-action.status-text {
  width: auto;
  min-width: 66rpx;
  padding: 0 10rpx;
  border-color: var(--color-border);
  border-radius: 999rpx;
  background: #edf1ef;
  color: var(--color-muted);
  font-size: 18rpx;
}

.arrow-icon,
.inline-arrow {
  position: relative;
  width: 22rpx;
  height: 18rpx;
}

.arrow-icon::before,
.inline-arrow::before {
  position: absolute;
  top: 8rpx;
  left: 1rpx;
  width: 19rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
  content: "";
}

.arrow-icon::after,
.inline-arrow::after {
  position: absolute;
  top: 3rpx;
  right: 0;
  width: 10rpx;
  height: 10rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  content: "";
}

.hub-nav {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: auto;
  padding-top: 30rpx;
  padding-bottom: 6rpx;
  border-top: 2rpx solid rgba(22, 54, 58, 0.1);
}

.hub-nav-item {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  flex-direction: column;
  border-radius: 16rpx;
  color: var(--color-muted);
  font-size: 19rpx;
  transition: opacity 150ms ease, background-color 150ms ease;
}

.hub-nav-item.nav-pressed {
  background: rgba(15, 143, 130, 0.08);
  opacity: 0.76;
}

.hub-nav-item.active {
  color: var(--color-primary-dark);
  font-weight: 760;
}

.nav-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  color: currentColor;
}

.nav-games {
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
}

.nav-games::before {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 2rpx;
  background: currentColor;
  box-shadow: 10rpx 0 0 currentColor, 0 10rpx 0 currentColor, 10rpx 10rpx 0 currentColor;
  content: "";
}

.nav-records {
  border: 3rpx solid currentColor;
  border-radius: 7rpx;
}

.nav-records::before,
.nav-records::after {
  position: absolute;
  right: 5rpx;
  left: 5rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: currentColor;
  content: "";
}

.nav-records::before { top: 8rpx; }
.nav-records::after { top: 17rpx; }

.nav-profile::before {
  position: absolute;
  top: 1rpx;
  left: 9rpx;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  content: "";
}

.nav-profile::after {
  position: absolute;
  right: 2rpx;
  bottom: 0;
  left: 2rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
  content: "";
}

@media (max-height: 700px) {
  .training-summary {
    min-height: 176rpx;
    margin-top: 26rpx;
    padding-top: 22rpx;
    padding-bottom: 22rpx;
  }

  .library-heading {
    margin-top: 30rpx;
  }

  .game-card {
    min-height: 122rpx;
  }
}
