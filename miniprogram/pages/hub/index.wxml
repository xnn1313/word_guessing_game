<view class="page-shell hub-page">
  <view class="hub-header">
    <view class="hub-heading">
      <view class="page-kicker">HELLO · {{loggedIn ? username : 'PLAYER'}}</view>
      <view class="page-title"><text>今天玩点</text><text>不一样的</text></view>
      <view class="page-subtitle">五款益智游戏，随手挑一块开始。</view>
    </view>
    <view class="account-button {{loggedIn ? 'signed' : ''}}" bindtap="openProfile" aria-label="打开个人中心">
      <view class="account-avatar">{{avatarText}}</view>
    </view>
  </view>

  <view class="training-summary">
    <view class="training-copy">
      <text class="training-label">{{trainingLabel}}</text>
      <text class="training-value">{{trainingValue}}</text>
      <text class="training-note">{{trainingNote}}</text>
    </view>
    <view class="training-ring">
      <text>{{availableGames}}</text>
      <text>款可玩</text>
    </view>
  </view>

  <view class="library-heading">
    <text class="section-title">选择游戏</text>
    <text class="library-count">{{availableGames}} 款可玩</text>
  </view>

  <view class="game-library">
    <view class="game-card playable {{wordGame.availability !== 'available' ? 'unavailable' : ''}}" bindtap="openWordGame" hover-class="card-pressed">
      <view class="game-icon word">词</view>
      <view class="game-copy">
        <text class="game-name">猜词实验室</text>
        <text class="game-description">{{wordGame.progress_text}} · 好友竞速</text>
        <view class="game-progress"><view style="width: {{wordGame.progress_percent}}%"></view></view>
      </view>
      <view class="game-action {{wordGame.availability === 'available' ? '' : 'status-text'}}">
        <view class="arrow-icon" wx:if="{{wordGame.availability === 'available'}}"></view>
        <text wx:else>{{wordGame.availability === 'maintenance' ? '维护' : '待开放'}}</text>
      </view>
    </view>

    <view class="game-card playable {{sudokuGame.availability !== 'available' ? 'unavailable' : ''}}" bindtap="openSudoku" hover-class="card-pressed">
      <view class="game-icon sudoku">▦</view>
      <view class="game-copy"><text class="game-name">每日数独</text><text class="game-description">{{sudokuGame.progress_text}} · 三种难度</text></view>
      <view class="game-action {{sudokuGame.availability === 'available' ? '' : 'status-text'}}">
        <view class="arrow-icon" wx:if="{{sudokuGame.availability === 'available'}}"></view>
        <text wx:else>{{sudokuGame.availability === 'maintenance' ? '维护' : '待开放'}}</text>
      </view>
    </view>

    <view class="game-card playable {{idiomGame.availability !== 'available' ? 'unavailable' : ''}}" bindtap="openIdiom" hover-class="card-pressed">
      <view class="game-icon idiom">成</view>
      <view class="game-copy"><text class="game-name">成语填字</text><text class="game-description">{{idiomGame.progress_text}} · 连续闯关</text></view>
      <view class="game-action {{idiomGame.availability === 'available' ? '' : 'status-text'}}">
        <view class="arrow-icon" wx:if="{{idiomGame.availability === 'available'}}"></view>
        <text wx:else>{{idiomGame.availability === 'maintenance' ? '维护' : '待开放'}}</text>
      </view>
    </view>

    <view class="game-card playable {{memoryGame.availability !== 'available' ? 'unavailable' : ''}}" bindtap="openMemory" hover-class="card-pressed">
      <view class="game-icon memory">◫</view>
      <view class="game-copy"><text class="game-name">记忆翻牌</text><text class="game-description">{{memoryGame.progress_text}} · 专注训练</text></view>
      <view class="game-action {{memoryGame.availability === 'available' ? '' : 'status-text'}}">
        <view class="arrow-icon" wx:if="{{memoryGame.availability === 'available'}}"></view>
        <text wx:else>{{memoryGame.availability === 'maintenance' ? '维护' : '待开放'}}</text>
      </view>
    </view>

    <view class="game-card word-search-card playable {{wordSearchGame.availability !== 'available' ? 'unavailable' : ''}}" bindtap="openWordSearch" hover-class="card-pressed">
      <view class="game-icon word-search">连</view>
      <view class="game-copy"><text class="game-name">成语连线</text><text class="game-description">{{wordSearchGame.progress_text}} · 横竖斜向字阵</text></view>
      <view class="game-action {{wordSearchGame.availability === 'available' ? '' : 'status-text'}}">
        <view class="arrow-icon" wx:if="{{wordSearchGame.availability === 'available'}}"></view>
        <text wx:else>{{wordSearchGame.availability === 'maintenance' ? '维护' : '待开放'}}</text>
      </view>
    </view>
  </view>

  <view class="app-tabbar">
    <view class="app-tab-item active"><view class="nav-icon nav-games"></view><text>游戏</text></view>
    <view class="app-tab-item" bindtap="openRecords" hover-class="nav-pressed"><view class="nav-icon nav-records"></view><text>记录</text></view>
    <view class="app-tab-item" bindtap="openProfile" hover-class="nav-pressed"><view class="nav-icon nav-profile"></view><text>我的</text></view>
  </view>
</view>
