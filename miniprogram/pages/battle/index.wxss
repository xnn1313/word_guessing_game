.battle-lobby {
  padding-top: 22rpx;
}

.battle-visual {
  position: relative;
  display: grid;
  min-height: 258rpx;
  grid-template-columns: 1fr 118rpx 1fr;
  align-items: center;
  margin-top: 28rpx;
  padding: 30rpx 28rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: var(--color-night);
  box-shadow: 0 16rpx 34rpx rgba(22, 54, 58, 0.18);
}

.battle-visual::before {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 7rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  content: "";
}

.player-side {
  position: relative;
  z-index: 2;
  display: flex;
  min-width: 0;
  align-items: center;
  flex-direction: column;
}

.player-side > text {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: var(--font-caption);
}

.player-orb {
  display: grid;
  width: 104rpx;
  height: 104rpx;
  place-items: center;
  border: 7rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  background: var(--color-primary);
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.18);
}

.player-side.right .player-orb {
  background: var(--color-accent);
  color: var(--color-ink);
}

.versus {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  flex-direction: column;
}

.versus > text {
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 850;
  font-style: italic;
}

.versus view {
  margin-top: 5rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 18rpx;
}

.battle-line {
  position: absolute;
  top: 111rpx;
  left: 23%;
  width: 54%;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.13);
}

.create-button {
  display: grid;
  width: 100%;
  height: var(--control-height);
  margin-top: 28rpx;
  place-items: center;
  border-radius: 18rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: var(--font-control);
  font-weight: 760;
  box-shadow: 0 10rpx 22rpx rgba(15, 143, 130, 0.2);
}

.join-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 32rpx;
}

.join-heading text:first-child {
  color: var(--color-text);
  font-size: var(--font-section);
  font-weight: 780;
}

.join-heading text:last-child {
  color: var(--color-muted);
  font-size: var(--font-caption);
  text-align: right;
}

.join-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 142rpx;
  gap: 14rpx;
  margin-top: 14rpx;
}

.room-input {
  width: 100%;
  min-width: 0;
  height: var(--control-height);
  padding: 0 22rpx;
  border: 2rpx solid var(--color-border-strong);
  border-radius: 18rpx;
  background: var(--color-surface);
  color: var(--color-text);
  font-size: 27rpx;
  font-weight: 760;
  letter-spacing: 7rpx;
  text-align: center;
}

.join-button {
  display: grid;
  width: 142rpx;
  height: var(--control-height);
  place-items: center;
  border: 2rpx solid #d9b44f;
  border-radius: 18rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: var(--font-control);
  font-weight: 760;
}

.battle-rules {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 30rpx;
}

.battle-rules > view {
  display: grid;
  min-height: 88rpx;
  grid-template-columns: 52rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: center;
  padding: 14rpx 18rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 18rpx;
  background: var(--color-surface);
}

.battle-rules > view > text {
  color: var(--color-primary);
  font-size: var(--font-caption);
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.battle-rules > view > view {
  display: grid;
  min-width: 0;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 8rpx;
  align-items: baseline;
}

.battle-rules view view text:first-child {
  color: var(--color-text);
  font-size: 23rpx;
  font-weight: 720;
}

.battle-rules view view text:last-child {
  color: var(--color-muted);
  font-size: 21rpx;
}

@media (max-height: 700px) {
  .battle-visual {
    min-height: 224rpx;
    margin-top: 20rpx;
  }

  .battle-rules {
    margin-top: 22rpx;
  }
}
