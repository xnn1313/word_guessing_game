.battle-lobby {
  background:
    radial-gradient(circle at 50% 0, rgba(116, 104, 223, 0.15), transparent 35%),
    #f4f6fb;
}

.battle-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 250rpx;
  margin-top: 32rpx;
  overflow: hidden;
  border: none;
  background: linear-gradient(145deg, #edf2ff, #f4efff);
}

.player-orb {
  position: relative;
  z-index: 2;
  display: grid;
  width: 104rpx;
  height: 104rpx;
  place-items: center;
  border: 8rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 780;
  box-shadow: 0 12rpx 28rpx rgba(64, 80, 128, 0.18);
}

.player-orb.left {
  background: #5b78c7;
}

.player-orb.right {
  background: #8a68c8;
}

.versus {
  position: relative;
  z-index: 3;
  margin: 0 34rpx;
  color: #59647b;
  font-size: 29rpx;
  font-weight: 850;
  font-style: italic;
}

.battle-line {
  position: absolute;
  top: 50%;
  left: 24%;
  width: 52%;
  height: 3rpx;
  background: rgba(92, 111, 168, 0.17);
}

.create-button {
  margin-top: 28rpx;
}

.join-divider {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 18rpx;
  margin: 28rpx 0;
  color: #969dab;
  font-size: 22rpx;
}

.join-divider text {
  height: 2rpx;
  background: #dfe3eb;
}

.join-panel {
  padding: 24rpx;
}

.room-input {
  width: 100%;
  height: 98rpx;
  border: 2rpx solid #dfe5f0;
  border-radius: 24rpx;
  background: #f9faff;
  color: #3e4e70;
  font-size: 34rpx;
  font-weight: 780;
  letter-spacing: 10rpx;
  text-align: center;
}

.join-panel .secondary-button {
  margin-top: 18rpx;
}

.battle-rules {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.battle-rules > view {
  display: flex;
  align-items: center;
  color: #777f90;
  font-size: 23rpx;
  line-height: 1.5;
}

.battle-rules text {
  display: grid;
  width: 40rpx;
  height: 40rpx;
  flex: 0 0 auto;
  margin-right: 16rpx;
  place-items: center;
  border-radius: 12rpx;
  background: #e9eefb;
  color: #5873bb;
  font-size: 20rpx;
  font-weight: 750;
}
