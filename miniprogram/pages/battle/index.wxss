.battle-lobby { padding-bottom: calc(54rpx + env(safe-area-inset-bottom)); }
.battle-visual { position: relative; display: grid; grid-template-columns: 1fr 110rpx 1fr; min-height: 270rpx; align-items: center; gap: 18rpx; margin-top: 30rpx; overflow: hidden; padding: 28rpx; border: 3rpx solid var(--color-ink); border-radius: 30rpx; background: var(--color-ink); box-shadow: 8rpx 8rpx 0 var(--color-primary); color: #ffffff; }
.battle-visual::before,.battle-visual::after { position: absolute; width: 170rpx; height: 170rpx; border: 17rpx solid rgba(255,255,255,0.08); border-radius: 50%; content: ""; }
.battle-visual::before { top: -80rpx; left: -50rpx; }
.battle-visual::after { right: -60rpx; bottom: -90rpx; }
.player-side { position: relative; z-index: 2; display: flex; align-items: center; gap: 12rpx; flex-direction: column; color: #ffffff; font-size: 21rpx; }
.player-orb { display: grid; width: 104rpx; height: 104rpx; place-items: center; border: 3rpx solid #ffffff; border-radius: 28rpx; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,0.35); color: var(--color-ink); font-size: 40rpx; font-weight: 900; transform: rotate(-4deg); }
.player-side.left .player-orb { background: var(--color-aqua); }
.player-side.right .player-orb { background: var(--color-yellow); transform: rotate(4deg); }
.versus { position: relative; z-index: 2; display: flex; align-items: center; flex-direction: column; }
.versus > text { color: #ffffff; font-size: 42rpx; font-weight: 900; }
.versus > view { color: #aeb5d0; font-size: 20rpx; }
.battle-line { position: absolute; z-index: 1; top: 50%; right: 90rpx; left: 90rpx; height: 3rpx; background: rgba(255,255,255,0.25); }
.create-button { display: grid; min-height: 96rpx; margin: 34rpx auto 0; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: var(--color-yellow); box-shadow: 7rpx 7rpx 0 var(--color-ink); color: var(--color-ink); font-size: 28rpx; font-weight: 900; }
.join-heading { display: flex; align-items: flex-end; justify-content: space-between; gap: 16rpx; margin-top: 42rpx; }
.join-heading text:first-child { color: var(--color-ink); font-size: 29rpx; font-weight: 900; }
.join-heading text:last-child { color: var(--color-muted); font-size: 20rpx; }
.join-panel { display: grid; grid-template-columns: minmax(0, 1fr) 170rpx; gap: 14rpx; margin-top: 15rpx; }
.room-input { height: 88rpx; padding: 0 22rpx; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: #ffffff; color: var(--color-ink); font-size: 29rpx; font-weight: 800; letter-spacing: 5rpx; text-align: center; text-transform: uppercase; }
.join-button { display: grid; min-height: 88rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-primary); color: #ffffff; font-size: 26rpx; font-weight: 900; }
.battle-rules { display: grid; gap: 14rpx; margin-top: 34rpx; }
.battle-rules > view { display: grid; grid-template-columns: 58rpx minmax(0, 1fr); align-items: center; gap: 18rpx; min-height: 94rpx; padding: 18rpx 22rpx; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: #ffffff; }
.battle-rules > view > text { color: var(--color-primary); font-size: 20rpx; font-weight: 900; letter-spacing: 2rpx; }
.battle-rules > view > view { display: grid; grid-template-columns: 150rpx minmax(0, 1fr); align-items: center; gap: 12rpx; }
.battle-rules > view > view text:first-child { color: var(--color-ink); font-size: 24rpx; font-weight: 850; }
.battle-rules > view > view text:last-child { color: var(--color-muted); font-size: 20rpx; }
