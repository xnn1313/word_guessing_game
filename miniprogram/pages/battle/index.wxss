.battle-lobby {
  padding-top: 22rpx;
}

.battle-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 274rpx;
  margin-top: 28rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #17343b;
  box-shadow: 0 16rpx 34rpx rgba(23, 52, 59, 0.17);
}

.battle-visual::before,
.battle-visual::after {
  position: absolute;
  width: 190rpx;
  height: 190rpx;
  border: 24rpx solid rgba(255, 255, 255, 0.035);
  border-radius: 50%;
  content: "";
}

.battle-visual::before {
  top: -96rpx;
  left: -65rpx;
}

.battle-visual::after {
  right: -64rpx;
  bottom: -105rpx;
}

.player-side {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  flex-direction: column;
}

.player-side > text {
  margin-top: 12rpx;
  color: #a7bfba;
  font-size: 19rpx;
}

.player-orb {
  display: grid;
  width: 104rpx;
  height: 104rpx;
  place-items: center;
  border: 7rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  background: #12a37f;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 830;
}

.player-side.right .player-orb {
  background: #ffc857;
  color: #233637;
}

.versus {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  width: 128rpx;
  flex-direction: column;
}

.versus > text {
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 880;
  font-style: italic;
}

.versus view {
  margin-top: 5rpx;
  color: #8eaaa4;
  font-size: 18rpx;
}

.battle-line {
  position: absolute;
  top: 111rpx;
  left: 23%;
  width: 54%;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.12);
}

.create-button {
  margin-top: 22rpx;
}

.join-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 30rpx;
}

.join-heading text:first-child {
  color: #263a37;
  font-size: 27rpx;
  font-weight: 760;
}

.join-heading text:last-child {
  color: #8b9894;
  font-size: 19rpx;
}

.join-panel {
  display: flex;
  gap: 11rpx;
  margin-top: 14rpx;
}

.room-input {
  min-width: 0;
  height: 84rpx;
  flex: 1;
  padding: 0 24rpx;
  border: 2rpx solid #d6e3df;
  border-radius: 20rpx;
  background: #ffffff;
  color: #203633;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 9rpx;
  text-align: center;
}

.join-button {
  width: 116rpx;
  height: 84rpx;
  flex: 0 0 auto;
  border: 2rpx solid #a9d2c5;
  border-radius: 20rpx;
  background: #e4f6f0;
  color: #08735c;
  font-size: 25rpx;
  font-weight: 780;
  line-height: 80rpx;
}

.join-button[disabled] {
  opacity: 0.42;
}

.battle-rules {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
  padding: 24rpx 22rpx;
  border-top: 2rpx solid #dfe8e5;
}

.battle-rules > view {
  display: flex;
  align-items: center;
}

.battle-rules > view > text {
  width: 54rpx;
  flex: 0 0 auto;
  color: #12a37f;
  font-size: 19rpx;
  font-weight: 820;
}

.battle-rules > view > view {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: baseline;
}

.battle-rules view view text:first-child {
  width: 132rpx;
  flex: 0 0 auto;
  color: #2c403d;
  font-size: 22rpx;
  font-weight: 700;
}

.battle-rules view view text:last-child {
  color: #7c8b87;
  font-size: 20rpx;
}

@media (max-height: 700px) {
  .battle-visual {
    min-height: 236rpx;
    margin-top: 20rpx;
  }

  .battle-rules {
    gap: 14rpx;
    margin-top: 22rpx;
    padding-top: 18rpx;
  }
}

/* Visual refresh */
.battle-lobby .battle-visual {
  border: 3rpx solid var(--color-ink);
  border-radius: 28rpx;
  background: var(--color-night);
  box-shadow: 9rpx 9rpx 0 var(--color-primary);
}

.battle-lobby .battle-visual::before,
.battle-lobby .battle-visual::after {
  border-color: rgba(255, 202, 75, 0.1);
}

.battle-lobby .player-side > text {
  color: #c3c6d6;
}

.battle-lobby .player-orb {
  border: 3rpx solid var(--color-ink);
  background: var(--color-primary);
  box-shadow: 5rpx 5rpx 0 rgba(0, 0, 0, 0.3);
}

.battle-lobby .player-side.right .player-orb {
  background: var(--color-accent);
  color: var(--color-ink);
}

.battle-lobby .versus view {
  color: #aeb2c5;
}

.battle-lobby .battle-line {
  height: 3rpx;
  background: rgba(255, 255, 255, 0.2);
}

.battle-lobby .create-button {
  margin-top: 30rpx;
}

.battle-lobby .join-heading text:first-child {
  color: var(--color-text);
  font-weight: 820;
}

.battle-lobby .join-heading text:last-child {
  color: var(--color-muted);
}

.battle-lobby .room-input {
  border: 3rpx solid var(--color-ink);
  border-radius: 18rpx;
  background: var(--color-surface);
  color: var(--color-text);
  box-shadow: 4rpx 4rpx 0 rgba(41, 45, 58, 0.12);
}

.battle-lobby .join-button {
  border: 3rpx solid var(--color-ink);
  border-radius: 18rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  box-shadow: 4rpx 4rpx 0 var(--color-ink);
}

.battle-lobby .join-button:active {
  box-shadow: 1rpx 1rpx 0 var(--color-ink);
}

.battle-lobby .battle-rules {
  gap: 14rpx;
  padding: 24rpx 0 0;
  border-top: none;
}

.battle-lobby .battle-rules > view {
  min-height: 74rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid var(--color-ink);
  border-radius: 16rpx;
  background: var(--color-surface);
}

.battle-lobby .battle-rules > view > text {
  color: var(--color-primary);
  font-weight: 880;
}

.battle-lobby .battle-rules view view text:first-child {
  color: var(--color-text);
  font-weight: 760;
}

.battle-lobby .battle-rules view view text:last-child {
  color: var(--color-muted);
}

/* Unified control sizing */
.battle-lobby .battle-visual {
  min-height: 258rpx;
}

.battle-lobby .create-button {
  display: grid;
  width: 100%;
  min-width: 100%;
  max-width: 100%;
  height: var(--control-height);
  margin-top: 30rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 18rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: var(--font-control);
  font-weight: 800;
  line-height: 1;
  box-shadow: 6rpx 6rpx 0 var(--color-ink);
}

.battle-lobby .create-button.card-pressed {
  box-shadow: 2rpx 2rpx 0 var(--color-ink);
}

.battle-lobby .join-heading text:first-child {
  font-size: var(--font-section);
}

.battle-lobby .join-heading text:last-child {
  font-size: var(--font-caption);
}

.battle-lobby .join-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 14rpx;
}

.battle-lobby .room-input {
  width: 100%;
  min-width: 0;
  height: var(--control-height);
  font-size: 26rpx;
  letter-spacing: 7rpx;
}

.battle-lobby .join-button {
  display: grid;
  width: 150rpx;
  min-width: 150rpx;
  max-width: 150rpx;
  height: var(--control-height);
  place-items: center;
  font-size: var(--font-control);
  line-height: 1;
}

.battle-lobby .join-button.card-pressed {
  box-shadow: 1rpx 1rpx 0 var(--color-ink);
}

.battle-lobby .battle-rules > view > text {
  font-size: var(--font-caption);
}

.battle-lobby .battle-rules view view text:first-child {
  font-size: 23rpx;
}

.battle-lobby .battle-rules view view text:last-child {
  font-size: 21rpx;
}
