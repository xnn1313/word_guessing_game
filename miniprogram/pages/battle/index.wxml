<view class="page-shell battle-lobby">
  <view class="page-title">双人竞速</view>
  <view class="page-subtitle">同一个隐藏词，90 秒内率先猜中者获胜。</view>

  <view class="battle-visual">
    <view class="player-side left">
      <view class="player-orb">你</view>
      <text>我的进度</text>
    </view>
    <view class="versus">
      <text>VS</text>
      <view>90 秒</view>
    </view>
    <view class="player-side right">
      <view class="player-orb">友</view>
      <text>好友进度</text>
    </view>
    <view class="battle-line"></view>
  </view>

  <button class="primary-button create-button" loading="{{creating}}" disabled="{{creating || checking}}" bindtap="createRoom">创建房间，邀请好友</button>

  <view class="join-heading">
    <text>已有房间码？</text>
    <text>输入好友发来的 6 位代码</text>
  </view>

  <view class="join-panel">
    <input class="room-input" value="{{joinCode}}" maxlength="6" placeholder="房间码" bindinput="onCodeInput" confirm-type="done" bindconfirm="joinRoom" />
    <button class="join-button" loading="{{joining}}" disabled="{{joining || joinCode.length !== 6}}" bindtap="joinRoom">加入</button>
  </view>

  <view class="battle-rules">
    <view><text>01</text><view><text>等待好友</text><text>两人到齐后，由房主开始比赛</text></view></view>
    <view><text>02</text><view><text>实时追赶</text><text>同步双方次数和最高相似度</text></view></view>
    <view><text>03</text><view><text>原房再战</text><text>比赛结束后可直接再来一局</text></view></view>
  </view>
</view>
