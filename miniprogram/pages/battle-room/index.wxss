.room-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 16rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
}

.room-bar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 72rpx;
}

.room-code {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: flex-start;
  flex-direction: column;
  text-align: left;
}

.room-code text {
  color: #85938f;
  font-size: 17rpx;
}

.room-code view {
  margin-top: 1rpx;
  color: #173d36;
  font-size: 31rpx;
  font-weight: 850;
  letter-spacing: 6rpx;
}

.room-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 0 16rpx;
  color: #96641e;
  font-size: 19rpx;
  font-weight: 700;
}

.room-status text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #dda43c;
}

.room-status.status-playing {
  color: #08735c;
}

.room-status.status-playing text {
  background: #12a37f;
  box-shadow: 0 0 0 5rpx rgba(18, 163, 127, 0.1);
}

.room-status.status-finished {
  color: #697974;
}

.room-status.status-finished text {
  background: #91a09c;
}

.leave-button {
  color: #bd5a60;
  font-size: 20rpx;
}

.score-grid {
  display: grid;
  flex: 0 0 auto;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 10rpx;
}

.player-card {
  min-width: 0;
  padding: 16rpx 17rpx;
  border: 2rpx solid #d8e5e0;
  border-radius: 19rpx;
  background: #ffffff;
}

.player-card.self {
  border-color: #9fd3c3;
  background: #f2fbf8;
}

.player-card.empty {
  border-style: dashed;
  background: #f7f9f8;
}

.player-head {
  min-width: 0;
}

.player-name {
  overflow: hidden;
  color: #233936;
  font-size: 24rpx;
  font-weight: 770;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-role {
  overflow: hidden;
  min-height: 28rpx;
  margin-top: 2rpx;
  color: #82908c;
  font-size: 16rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 10rpx;
}

.player-score > view:first-child {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.score-number {
  overflow: hidden;
  color: #087d62;
  font-size: 27rpx;
  font-weight: 840;
  font-variant-numeric: tabular-nums;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.opponent .score-number {
  color: #b87520;
}

.score-label {
  color: #8a9793;
  font-size: 15rpx;
}

.attempt-count {
  flex: 0 0 auto;
  color: #7d8b87;
  font-size: 17rpx;
}

.attempt-count text {
  color: #334844;
  font-size: 25rpx;
  font-weight: 800;
}

.player-track {
  height: 6rpx;
  margin-top: 9rpx;
  overflow: hidden;
  border-radius: 6rpx;
  background: #e4ece9;
}

.player-track view {
  min-width: 3rpx;
  height: 100%;
  border-radius: 6rpx;
  background: #12a37f;
}

.opponent .player-track view {
  background: #e1a039;
}

.waiting-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 14rpx;
  padding: 30rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
  text-align: center;
}

.waiting-rings {
  display: flex;
  gap: 12rpx;
}

.waiting-rings text {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #12a37f;
  opacity: 0.25;
  animation: pulse 1.2s ease-in-out infinite;
}

.waiting-rings text:nth-child(2) { animation-delay: 0.2s; }
.waiting-rings text:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse {
  50% { opacity: 1; transform: translateY(-5rpx); }
}

.waiting-title {
  margin-top: 22rpx;
  color: #243936;
  font-size: 31rpx;
  font-weight: 780;
}

.waiting-note {
  margin: 10rpx 0 26rpx;
  color: #82908c;
  font-size: 21rpx;
  line-height: 1.5;
}

.waiting-panel .primary-button {
  width: 100%;
}

.guest-wait {
  color: #537d72;
  font-size: 23rpx;
}

.arena,
.result-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 12rpx;
  padding: 16rpx 20rpx 8rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
  overflow: hidden;
}

.timer-row {
  position: relative;
  display: flex;
  flex: 0 0 auto;
  align-items: baseline;
  justify-content: center;
  gap: 7rpx;
  padding-bottom: 14rpx;
  color: #7d8b87;
  font-size: 18rpx;
}

.timer-value {
  color: #087d62;
  font-size: 43rpx;
  font-weight: 860;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.timer-value.urgent {
  color: #d2535a;
}

.timer-line {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 5rpx;
  overflow: hidden;
  border-radius: 5rpx;
  background: #e6eeeb;
}

.timer-line view {
  height: 100%;
  border-radius: 5rpx;
  background: #12a37f;
}

.guess-row {
  display: flex;
  flex: 0 0 auto;
  gap: 10rpx;
  margin-top: 13rpx;
}

.guess-row .text-input {
  min-width: 0;
  height: 78rpx;
  flex: 1;
}

.guess-button {
  width: 104rpx;
  height: 78rpx;
  border-radius: 18rpx;
  background: #12a37f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 770;
  line-height: 78rpx;
}

.guess-button[disabled] {
  opacity: 0.4;
}

.history-heading {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.history-heading > text:last-child {
  color: #8b9894;
  font-size: 18rpx;
}

.battle-history {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 6rpx;
}

.result-panel {
  padding-top: 18rpx;
}

.result-summary {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
}

.result-emblem {
  display: grid;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 20rpx;
  background: #fff0cc;
  font-size: 35rpx;
}

.result-summary > view:last-child {
  min-width: 0;
  margin-left: 16rpx;
  text-align: left;
}

.result-title {
  color: #243936;
  font-size: 29rpx;
  font-weight: 800;
}

.result-answer {
  margin-top: 4rpx;
  color: #6f7f7a;
  font-size: 22rpx;
}

.rematch-button {
  flex: 0 0 auto;
  margin-top: 16rpx;
}

.result-history {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  width: 100%;
  text-align: left;
}

.finished-history {
  height: auto;
}

@media (max-height: 650px) {
  .player-card {
    padding-top: 12rpx;
    padding-bottom: 12rpx;
  }

  .room-bar {
    min-height: 64rpx;
  }

  .arena,
  .result-panel {
    margin-top: 9rpx;
  }
}
