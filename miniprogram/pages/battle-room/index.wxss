.room-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 14rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: var(--color-bg);
}

.room-bar {
  display: flex;
  min-height: 88rpx;
  flex: 0 0 auto;
  align-items: center;
}

.room-code {
  display: flex;
  min-width: 0;
  min-height: 88rpx;
  flex: 1;
  align-items: flex-start;
  justify-content: center;
  flex-direction: column;
  text-align: left;
}

.room-code text {
  color: var(--color-muted);
  font-size: 18rpx;
}

.room-code view {
  margin-top: 2rpx;
  color: var(--color-primary-dark);
  font-size: 31rpx;
  font-weight: 820;
  font-variant-numeric: tabular-nums;
  letter-spacing: 6rpx;
}

.room-status {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 8rpx;
  margin: 0 12rpx;
  padding: 8rpx 12rpx;
  border: 2rpx solid #e8cb8e;
  border-radius: 999rpx;
  background: #fff4d8;
  color: #845a15;
  font-size: 19rpx;
  font-weight: 680;
}

.room-status text {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #dca33d;
}

.room-status.status-playing {
  border-color: #9fd7cd;
  background: #e4f7f2;
  color: var(--color-primary-dark);
}

.room-status.status-playing text {
  background: var(--color-mint);
}

.room-status.status-finished {
  border-color: var(--color-border);
  background: #e9efec;
  color: var(--color-muted);
}

.room-status.status-finished text {
  background: #91a09c;
}

.leave-button {
  min-width: 78rpx;
  min-height: 72rpx;
  color: var(--color-danger);
  font-size: 20rpx;
  font-weight: 680;
  line-height: 72rpx;
}

.score-grid {
  display: grid;
  flex: 0 0 auto;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 10rpx;
}

.player-card {
  min-width: 0;
  padding: 17rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 19rpx;
  background: var(--color-surface);
  box-shadow: 0 6rpx 18rpx rgba(22, 54, 58, 0.06);
}

.player-card.self {
  border-color: #90cfc4;
  background: var(--color-primary-soft);
}

.player-card.opponent {
  border-color: #e9cf90;
  background: #fff7df;
}

.player-card.empty {
  border-style: dashed;
  background: #edf1ef;
  box-shadow: none;
}

.player-name {
  overflow: hidden;
  color: var(--color-text);
  font-size: 25rpx;
  font-weight: 760;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.winner-badge {
  display: inline-grid;
  width: 30rpx;
  height: 30rpx;
  margin-right: 7rpx;
  place-items: center;
  border-radius: 8rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: 18rpx;
  font-weight: 800;
}

.player-role {
  overflow: hidden;
  min-height: 28rpx;
  margin-top: 2rpx;
  color: var(--color-muted);
  font-size: 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 10rpx;
}

.player-score > view:first-child {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.score-number {
  overflow: hidden;
  color: var(--color-primary-dark);
  font-size: 28rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.opponent .score-number {
  color: #a36c14;
}

.score-label,
.attempt-count {
  color: var(--color-muted);
  font-size: 18rpx;
}

.attempt-count {
  flex: 0 0 auto;
}

.attempt-count text {
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 760;
}

.player-track {
  height: 7rpx;
  margin-top: 9rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dce6e2;
}

.player-track view {
  min-width: 3rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--color-primary);
}

.opponent .player-track view {
  background: #d8a135;
}

.waiting-panel,
.arena,
.result-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 16rpx;
  overflow: hidden;
  border: 2rpx solid var(--color-border);
  border-radius: 22rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 22rpx rgba(22, 54, 58, 0.06);
}

.waiting-panel {
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  text-align: center;
}

.waiting-rings {
  display: flex;
  gap: 12rpx;
}

.waiting-rings text {
  width: 15rpx;
  height: 15rpx;
  border-radius: 50%;
  background: var(--color-primary);
  opacity: 0.25;
  animation: pulse 1.2s ease-in-out infinite;
}

.waiting-rings text:nth-child(2) { background: var(--color-coral); animation-delay: 0.2s; }
.waiting-rings text:nth-child(3) { background: var(--color-accent); animation-delay: 0.4s; }

@keyframes pulse {
  50% { opacity: 1; transform: translateY(-5rpx); }
}

.waiting-title {
  margin-top: 22rpx;
  color: var(--color-text);
  font-size: 31rpx;
  font-weight: 780;
}

.waiting-note {
  margin: 10rpx 0 26rpx;
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.5;
}

.waiting-panel .primary-button {
  width: 100%;
}

.guest-wait {
  color: var(--color-primary-dark);
  font-size: 23rpx;
}

.arena,
.result-panel {
  padding: 17rpx 20rpx 8rpx;
}

.timer-row {
  position: relative;
  display: flex;
  flex: 0 0 auto;
  align-items: baseline;
  justify-content: center;
  gap: 7rpx;
  padding-bottom: 15rpx;
  color: var(--color-muted);
  font-size: 18rpx;
}

.timer-value {
  color: var(--color-primary-dark);
  font-size: 43rpx;
  font-weight: 820;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.timer-value.urgent {
  color: var(--color-danger);
}

.timer-line {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 6rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dfe8e5;
}

.timer-line view {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--color-primary), var(--color-coral));
}

.guess-row {
  display: grid;
  flex: 0 0 auto;
  grid-template-columns: minmax(0, 1fr) 136rpx;
  gap: 12rpx;
  margin-top: 13rpx;
}

.guess-row .text-input {
  width: 100%;
  min-width: 0;
  height: 82rpx;
}

.guess-button {
  display: grid;
  width: 136rpx;
  height: 82rpx;
  place-items: center;
  border-radius: 17rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 750;
}

.history-heading {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.history-heading > text:last-child {
  color: var(--color-muted);
  font-size: 18rpx;
}

.battle-history {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 6rpx;
}

.result-summary {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
}

.result-emblem {
  display: grid;
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 20rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: 30rpx;
  font-weight: 820;
}

.result-summary > view:last-child {
  min-width: 0;
  margin-left: 16rpx;
  text-align: left;
}

.result-title {
  color: var(--color-text);
  font-size: 29rpx;
  font-weight: 790;
}

.result-answer {
  margin-top: 4rpx;
  color: var(--color-muted);
  font-size: 22rpx;
}

.rematch-button {
  flex: 0 0 auto;
  margin-top: 16rpx;
}

.result-history {
  display: flex;
  width: 100%;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  text-align: left;
}

.finished-history {
  height: auto;
}

@media (max-height: 650px) {
  .player-card {
    padding-top: 12rpx;
    padding-bottom: 12rpx;
  }

  .waiting-panel,
  .arena,
  .result-panel {
    margin-top: 10rpx;
  }
}
