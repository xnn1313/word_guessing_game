.room-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 16rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
}

.room-bar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 72rpx;
}

.room-code {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: flex-start;
  flex-direction: column;
  text-align: left;
}

.room-code text {
  color: #85938f;
  font-size: 17rpx;
}

.room-code view {
  margin-top: 1rpx;
  color: #173d36;
  font-size: 31rpx;
  font-weight: 850;
  letter-spacing: 6rpx;
}

.room-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 0 16rpx;
  color: #96641e;
  font-size: 19rpx;
  font-weight: 700;
}

.room-status text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #dda43c;
}

.room-status.status-playing {
  color: #08735c;
}

.room-status.status-playing text {
  background: #12a37f;
  box-shadow: 0 0 0 5rpx rgba(18, 163, 127, 0.1);
}

.room-status.status-finished {
  color: #697974;
}

.room-status.status-finished text {
  background: #91a09c;
}

.leave-button {
  color: #bd5a60;
  font-size: 20rpx;
}

.score-grid {
  display: grid;
  flex: 0 0 auto;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 10rpx;
}

.player-card {
  min-width: 0;
  padding: 16rpx 17rpx;
  border: 2rpx solid #d8e5e0;
  border-radius: 19rpx;
  background: #ffffff;
}

.player-card.self {
  border-color: #9fd3c3;
  background: #f2fbf8;
}

.player-card.empty {
  border-style: dashed;
  background: #f7f9f8;
}

.player-head {
  min-width: 0;
}

.player-name {
  overflow: hidden;
  color: #233936;
  font-size: 24rpx;
  font-weight: 770;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-role {
  overflow: hidden;
  min-height: 28rpx;
  margin-top: 2rpx;
  color: #82908c;
  font-size: 16rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 10rpx;
}

.player-score > view:first-child {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.score-number {
  overflow: hidden;
  color: #087d62;
  font-size: 27rpx;
  font-weight: 840;
  font-variant-numeric: tabular-nums;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.opponent .score-number {
  color: #b87520;
}

.score-label {
  color: #8a9793;
  font-size: 15rpx;
}

.attempt-count {
  flex: 0 0 auto;
  color: #7d8b87;
  font-size: 17rpx;
}

.attempt-count text {
  color: #334844;
  font-size: 25rpx;
  font-weight: 800;
}

.player-track {
  height: 6rpx;
  margin-top: 9rpx;
  overflow: hidden;
  border-radius: 6rpx;
  background: #e4ece9;
}

.player-track view {
  min-width: 3rpx;
  height: 100%;
  border-radius: 6rpx;
  background: #12a37f;
}

.opponent .player-track view {
  background: #e1a039;
}

.waiting-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 14rpx;
  padding: 30rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
  text-align: center;
}

.waiting-rings {
  display: flex;
  gap: 12rpx;
}

.waiting-rings text {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #12a37f;
  opacity: 0.25;
  animation: pulse 1.2s ease-in-out infinite;
}

.waiting-rings text:nth-child(2) { animation-delay: 0.2s; }
.waiting-rings text:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse {
  50% { opacity: 1; transform: translateY(-5rpx); }
}

.waiting-title {
  margin-top: 22rpx;
  color: #243936;
  font-size: 31rpx;
  font-weight: 780;
}

.waiting-note {
  margin: 10rpx 0 26rpx;
  color: #82908c;
  font-size: 21rpx;
  line-height: 1.5;
}

.waiting-panel .primary-button {
  width: 100%;
}

.guest-wait {
  color: #537d72;
  font-size: 23rpx;
}

.arena,
.result-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 12rpx;
  padding: 16rpx 20rpx 8rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
  overflow: hidden;
}

.timer-row {
  position: relative;
  display: flex;
  flex: 0 0 auto;
  align-items: baseline;
  justify-content: center;
  gap: 7rpx;
  padding-bottom: 14rpx;
  color: #7d8b87;
  font-size: 18rpx;
}

.timer-value {
  color: #087d62;
  font-size: 43rpx;
  font-weight: 860;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.timer-value.urgent {
  color: #d2535a;
}

.timer-line {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 5rpx;
  overflow: hidden;
  border-radius: 5rpx;
  background: #e6eeeb;
}

.timer-line view {
  height: 100%;
  border-radius: 5rpx;
  background: #12a37f;
}

.guess-row {
  display: flex;
  flex: 0 0 auto;
  gap: 10rpx;
  margin-top: 13rpx;
}

.guess-row .text-input {
  min-width: 0;
  height: 78rpx;
  flex: 1;
}

.guess-button {
  width: 104rpx;
  height: 78rpx;
  border-radius: 18rpx;
  background: #12a37f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 770;
  line-height: 78rpx;
}

.guess-button[disabled] {
  opacity: 0.4;
}

.history-heading {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.history-heading > text:last-child {
  color: #8b9894;
  font-size: 18rpx;
}

.battle-history {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 6rpx;
}

.result-panel {
  padding-top: 18rpx;
}

.result-summary {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
}

.result-emblem {
  display: grid;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 20rpx;
  background: #fff0cc;
  font-size: 35rpx;
}

.result-summary > view:last-child {
  min-width: 0;
  margin-left: 16rpx;
  text-align: left;
}

.result-title {
  color: #243936;
  font-size: 29rpx;
  font-weight: 800;
}

.result-answer {
  margin-top: 4rpx;
  color: #6f7f7a;
  font-size: 22rpx;
}

.rematch-button {
  flex: 0 0 auto;
  margin-top: 16rpx;
}

.result-history {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  width: 100%;
  text-align: left;
}

.finished-history {
  height: auto;
}

@media (max-height: 650px) {
  .player-card {
    padding-top: 12rpx;
    padding-bottom: 12rpx;
  }

  .room-bar {
    min-height: 64rpx;
  }

  .arena,
  .result-panel {
    margin-top: 9rpx;
  }
}

/* Visual refresh */
.room-page {
  background: var(--color-bg);
}

.room-page .room-code text {
  color: var(--color-muted);
}

.room-page .room-code view {
  color: var(--color-primary-dark);
}

.room-page .room-status {
  padding: 7rpx 11rpx;
  border: 2rpx solid var(--color-ink);
  border-radius: 999rpx;
  background: #fff0be;
  color: #7f590f;
}

.room-page .room-status.status-playing {
  background: #dcf7ef;
  color: #176f5a;
}

.room-page .room-status.status-playing text {
  background: var(--color-mint);
  box-shadow: 0 0 0 5rpx rgba(53, 199, 165, 0.12);
}

.room-page .room-status.status-finished {
  background: #e7e2d9;
  color: #65636a;
}

.room-page .leave-button {
  color: var(--color-danger);
  font-weight: 720;
}

.room-page .score-grid {
  gap: 12rpx;
  margin-top: 14rpx;
}

.room-page .player-card {
  border: 3rpx solid var(--color-ink);
  border-radius: 18rpx;
  background: var(--color-surface);
  box-shadow: 4rpx 4rpx 0 rgba(41, 45, 58, 0.11);
}

.room-page .player-card.self {
  border-color: var(--color-ink);
  background: var(--color-primary-soft);
  box-shadow: 4rpx 4rpx 0 var(--color-primary);
}

.room-page .player-card.opponent {
  background: #fff3c9;
  box-shadow: 4rpx 4rpx 0 #e3a82a;
}

.room-page .player-card.empty {
  border-color: #8f8b84;
  background: #eae6de;
  box-shadow: none;
}

.room-page .player-name {
  color: var(--color-text);
  font-weight: 820;
}

.room-page .player-role,
.room-page .score-label,
.room-page .attempt-count {
  color: var(--color-muted);
}

.room-page .score-number {
  color: var(--color-primary-dark);
}

.room-page .opponent .score-number {
  color: #a56a0b;
}

.room-page .player-track {
  border: 1rpx solid rgba(41, 45, 58, 0.35);
  background: #ddd7cd;
}

.room-page .player-track view {
  background: var(--color-primary);
}

.room-page .opponent .player-track view {
  background: var(--color-accent);
}

.room-page .waiting-panel,
.room-page .arena,
.room-page .result-panel {
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  background: var(--color-surface);
  box-shadow: 6rpx 6rpx 0 rgba(41, 45, 58, 0.11);
}

.room-page .waiting-rings text {
  background: var(--color-primary);
}

.room-page .waiting-rings text:nth-child(2) { background: var(--color-coral); }
.room-page .waiting-rings text:nth-child(3) { background: var(--color-accent); }

.room-page .waiting-title,
.room-page .result-title {
  color: var(--color-text);
  font-weight: 840;
}

.room-page .waiting-note,
.room-page .result-answer,
.room-page .history-heading > text:last-child {
  color: var(--color-muted);
}

.room-page .guest-wait {
  color: var(--color-primary-dark);
}

.room-page .timer-value {
  color: var(--color-primary-dark);
}

.room-page .timer-value.urgent {
  color: var(--color-danger);
}

.room-page .timer-line {
  border: 1rpx solid rgba(41, 45, 58, 0.35);
  background: #e3ddd3;
}

.room-page .timer-line view {
  background: linear-gradient(90deg, var(--color-primary), var(--color-coral));
}

.room-page .guess-button {
  border: 3rpx solid var(--color-ink);
  border-radius: 16rpx;
  background: var(--color-primary);
  box-shadow: 4rpx 4rpx 0 var(--color-ink);
}

.room-page .result-emblem {
  border: 3rpx solid var(--color-ink);
  background: var(--color-accent);
  box-shadow: 3rpx 3rpx 0 rgba(41, 45, 58, 0.14);
}

/* Unified room typography and compact waiting state */
.room-page .room-code text {
  font-size: 19rpx;
}

.room-page .room-code view {
  font-size: 31rpx;
}

.room-page .room-status,
.room-page .leave-button {
  font-size: 20rpx;
}

.room-page .player-card {
  padding: 18rpx;
}

.room-page .player-name {
  font-size: 25rpx;
}

.room-page .player-role {
  font-size: 18rpx;
}

.room-page .score-number {
  font-size: 29rpx;
}

.room-page .score-label,
.room-page .attempt-count {
  font-size: 17rpx;
}

.room-page .attempt-count text {
  font-size: 25rpx;
}

.room-page .waiting-panel {
  min-height: 410rpx;
  flex: 0 0 auto;
  margin-top: 20rpx;
  padding: 34rpx;
}

.room-page .waiting-title {
  font-size: 32rpx;
}

.room-page .waiting-note {
  margin-top: 12rpx;
  margin-bottom: 28rpx;
  font-size: 23rpx;
}

.room-page .waiting-panel .primary-button {
  min-width: 100%;
  max-width: 100%;
}

.room-page .guest-wait {
  font-size: 24rpx;
}

.room-page .guess-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 136rpx;
  gap: 12rpx;
}

.room-page .guess-row .text-input {
  width: 100%;
  min-width: 0;
  height: 80rpx;
  font-size: 25rpx;
}

.room-page .guess-button {
  display: grid;
  width: 136rpx;
  min-width: 136rpx;
  max-width: 136rpx;
  height: 80rpx;
  place-items: center;
  font-size: 25rpx;
  line-height: 1;
}
