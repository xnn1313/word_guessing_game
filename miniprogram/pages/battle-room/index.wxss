.room-page { padding-bottom: calc(50rpx + env(safe-area-inset-bottom)); }
.room-bar { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 12rpx; }
.room-code { min-height: 88rpx; padding: 10rpx 18rpx; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-yellow); color: var(--color-ink); text-align: left; }
.room-code > text { display: block; font-size: 17rpx; font-weight: 700; }
.room-code > view { font-size: 27rpx; font-weight: 900; letter-spacing: 5rpx; text-transform: uppercase; }
.room-status { display: flex; min-height: 62rpx; align-items: center; gap: 7rpx; padding: 0 14rpx; border: 3rpx solid var(--color-ink); border-radius: 15rpx; background: #ffffff; color: var(--color-muted); font-size: 18rpx; font-weight: 800; }
.room-status > text { width: 10rpx; height: 10rpx; border: 2rpx solid var(--color-ink); border-radius: 50%; background: var(--color-yellow); }
.status-playing > text { background: var(--color-aqua); }
.status-finished > text { background: var(--color-coral); }
.leave-button { display: grid; min-height: 88rpx; place-items: center; padding: 0 13rpx; color: var(--color-danger); font-size: 20rpx; font-weight: 850; text-align: center; }
.score-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; margin-top: 24rpx; }
.player-card { padding: 20rpx; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: #ffffff; box-shadow: 5rpx 5rpx 0 var(--color-ink); }
.player-card.self { background: var(--color-primary-soft); }
.player-card.opponent { background: var(--color-yellow-soft); }
.player-card.empty { background: #e9ebf3; color: var(--color-subtle); box-shadow: none; }
.player-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 10rpx; }
.player-name { overflow: hidden; color: var(--color-ink); font-size: 25rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.winner-badge { display: inline-grid; min-width: 36rpx; height: 36rpx; margin-right: 7rpx; place-items: center; border: 2rpx solid var(--color-ink); border-radius: 9rpx; background: var(--color-yellow); font-size: 17rpx; }
.player-role { color: var(--color-muted); font-size: 17rpx; white-space: nowrap; }
.player-score { display: flex; align-items: flex-end; justify-content: space-between; margin-top: 20rpx; }
.player-score > view:first-child { display: flex; flex-direction: column; }
.score-number { color: var(--color-primary); font-size: 36rpx; font-weight: 900; font-variant-numeric: tabular-nums; }
.score-label { color: var(--color-muted); font-size: 17rpx; }
.attempt-count { color: var(--color-muted); font-size: 18rpx; }
.attempt-count text { color: var(--color-ink); font-size: 28rpx; font-weight: 900; }
.player-track { height: 10rpx; margin-top: 14rpx; overflow: hidden; border: 2rpx solid var(--color-ink); border-radius: 99rpx; background: #ffffff; }
.player-track > view { min-width: 4rpx; height: 100%; background: var(--color-primary); }
.waiting-panel { display: flex; min-height: 520rpx; align-items: center; justify-content: center; margin-top: 24rpx; padding: 36rpx; border: 3rpx solid var(--color-ink); border-radius: 28rpx; background: #ffffff; box-shadow: var(--shadow-hard); flex-direction: column; text-align: center; }
.waiting-rings { display: flex; gap: 12rpx; }
.waiting-rings text { width: 30rpx; height: 30rpx; border: 5rpx solid var(--color-primary); border-radius: 8rpx; transform: rotate(8deg); }
.waiting-rings text:nth-child(2) { border-color: var(--color-coral); transform: rotate(-8deg); }
.waiting-rings text:nth-child(3) { border-color: var(--color-yellow); }
.waiting-title { margin-top: 28rpx; color: var(--color-ink); font-size: 35rpx; font-weight: 900; }
.waiting-note { max-width: 520rpx; margin: 10rpx 0 30rpx; color: var(--color-muted); font-size: 22rpx; }
.guest-wait { padding: 22rpx 26rpx; border: 3rpx dashed var(--color-primary); border-radius: 18rpx; color: var(--color-primary-dark); font-size: 23rpx; font-weight: 800; }
.arena { margin-top: 24rpx; }
.timer-row { display: grid; grid-template-columns: auto 74rpx auto minmax(0, 1fr); align-items: center; gap: 8rpx; padding: 18rpx 22rpx; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: var(--color-ink); color: #d9deef; font-size: 19rpx; }
.timer-value { color: var(--color-yellow); font-size: 35rpx; font-weight: 900; text-align: right; }
.timer-value.urgent { color: var(--color-coral); }
.timer-line { height: 12rpx; margin-left: 12rpx; overflow: hidden; border-radius: 99rpx; background: rgba(255,255,255,0.18); }
.timer-line > view { height: 100%; background: var(--color-aqua); }
.guess-row { display: grid; grid-template-columns: minmax(0, 1fr) 148rpx; gap: 12rpx; margin-top: 16rpx; }
.guess-button { display: grid; min-height: var(--control-height); place-items: center; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-yellow); color: var(--color-ink); font-weight: 900; }
.history-heading { display: flex; align-items: flex-end; justify-content: space-between; margin: 28rpx 0 12rpx; }
.history-heading > text:last-child { color: var(--color-muted); font-size: 19rpx; }
.battle-history { height: 430rpx; padding: 10rpx 18rpx; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: #ffffff; }
.result-panel { margin-top: 24rpx; }
.result-summary { display: flex; align-items: center; gap: 22rpx; padding: 26rpx; border: 3rpx solid var(--color-ink); border-radius: 26rpx; background: var(--color-aqua-soft); box-shadow: 6rpx 6rpx 0 var(--color-ink); }
.result-emblem { display: grid; width: 86rpx; height: 86rpx; flex: 0 0 auto; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: var(--color-yellow); color: var(--color-ink); font-size: 36rpx; font-weight: 900; transform: rotate(-5deg); }
.result-title { color: var(--color-ink); font-size: 32rpx; font-weight: 900; }
.result-answer { margin-top: 5rpx; color: var(--color-muted); font-size: 22rpx; }
.rematch-button { margin-top: 24rpx; }
.result-history { margin-top: 26rpx; }
.finished-history { height: 350rpx; }
@media (max-height: 700px) { .waiting-panel { min-height: 420rpx; } .battle-history { height: 340rpx; } }
