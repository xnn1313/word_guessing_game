.sokoban-page { padding-bottom: calc(46rpx + env(safe-area-inset-bottom)); }
.game-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.warehouse-mark { display: grid; width: 88rpx; height: 88rpx; flex: 0 0 auto; padding: 9rpx; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: var(--color-yellow); box-shadow: 5rpx 5rpx 0 var(--color-ink); grid-template-columns: repeat(2,1fr); gap: 5rpx; transform: rotate(-2deg); }
.warehouse-mark view { border: 2rpx solid var(--color-ink); border-radius: 5rpx; background: #ffffff; }
.compact-controls { margin-top: 20rpx; padding: 10rpx; border-radius: 22rpx; box-shadow: 5rpx 5rpx 0 var(--color-ink); }
.control-row { display: grid; gap: 8rpx; }
.control-row + .control-row { margin-top: 8rpx; }
.two-columns { grid-template-columns: repeat(2,minmax(0,1fr)); }
.three-columns { grid-template-columns: repeat(3,minmax(0,1fr)); }
.control-row button { display: flex; height: 66rpx; align-items: center; justify-content: center; border: 3rpx solid transparent; border-radius: 13rpx; color: var(--color-muted); font-size: 20rpx; font-weight: 850; }
.control-row button.active { border-color: var(--color-ink); color: var(--color-ink); box-shadow: 3rpx 3rpx 0 var(--color-ink); }
.control-row button.mode-active { background: var(--color-primary); color: #ffffff; }
.control-row button.difficulty-active { background: var(--color-yellow); }
.sokoban-status { margin-top: 18rpx; }
.board-caption { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; margin: 19rpx 0 11rpx; }
.board-caption > view:first-child { display: flex; min-width: 0; flex: 1; flex-direction: column; }
.board-caption text:first-child { color: var(--color-ink); font-size: 26rpx; font-weight: 900; }
.board-caption text:last-child { color: var(--color-muted); font-size: 18rpx; }
.caption-actions { display: grid; flex: 0 0 auto; grid-template-columns: repeat(2,92rpx); gap: 8rpx; }
.caption-actions button { display: flex; height: 60rpx; align-items: center; justify-content: center; border: 3rpx solid var(--color-ink); border-radius: 13rpx; background: #ffffff; box-shadow: 3rpx 3rpx 0 var(--color-ink); font-size: 19rpx; font-weight: 850; }
.caption-actions button:last-child { background: var(--color-coral-soft); }
.caption-actions button[disabled] { opacity: .35; box-shadow: none; }
.sokoban-board { display: grid; width: 100%; overflow: hidden; border: 4rpx solid var(--color-ink); border-radius: 23rpx; background: var(--color-ink); box-shadow: 7rpx 7rpx 0 var(--color-ink); touch-action: none; }
.warehouse-cell { position: relative; display: grid; min-width: 0; aspect-ratio: 1; place-items: center; overflow: hidden; }
.warehouse-cell.floor { border-right: 1rpx solid rgba(21,27,58,.15); border-bottom: 1rpx solid rgba(21,27,58,.15); background: #f9f3df; }
.warehouse-cell.floor::before { position: absolute; right: 0; bottom: 0; width: 45%; height: 45%; border-top: 1rpx solid rgba(21,27,58,.08); border-left: 1rpx solid rgba(21,27,58,.08); content: ""; }
.warehouse-cell.wall { background: var(--color-primary-dark); box-shadow: inset 0 0 0 4rpx rgba(255,255,255,.1); }
.warehouse-cell.wall::before { width: 70%; height: 42%; border: 3rpx solid rgba(255,255,255,.35); border-radius: 5rpx; content: ""; }
.target-ring { width: 42%; height: 42%; border: 4rpx dashed var(--color-coral); border-radius: 50%; background: rgba(255,127,117,.12); }
.crate { position: relative; z-index: 2; display: grid; width: 76%; height: 76%; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 10rpx; background: var(--color-yellow); box-shadow: 3rpx 3rpx 0 rgba(21,27,58,.78); }
.crate::before,.crate::after { position: absolute; width: 78%; height: 3rpx; background: rgba(21,27,58,.65); content: ""; }
.crate::before { transform: rotate(45deg); }
.crate::after { transform: rotate(-45deg); }
.crate text { position: relative; z-index: 1; color: transparent; }
.box-done .crate { background: var(--color-aqua); box-shadow: inset 0 0 0 5rpx rgba(255,255,255,.45),3rpx 3rpx 0 var(--color-ink); }
.worker { position: relative; z-index: 3; display: grid; width: 62%; height: 62%; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 50% 50% 44% 44%; background: var(--color-primary); box-shadow: 3rpx 3rpx 0 var(--color-ink); }
.worker::before { position: absolute; top: 13%; width: 50%; height: 29%; border-radius: 50%; background: #ffffff; content: ""; }
.worker view { position: absolute; bottom: 15%; width: 48%; height: 17%; border-radius: 99rpx; background: var(--color-yellow); }
.move-console { display: flex; min-height: 180rpx; align-items: center; justify-content: space-between; gap: 24rpx; margin-top: 20rpx; padding: 20rpx 24rpx; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: #ffffff; box-shadow: 5rpx 5rpx 0 var(--color-ink); }
.console-copy { display: flex; flex-direction: column; }
.console-copy text:first-child { color: var(--color-ink); font-size: 25rpx; font-weight: 900; }
.console-copy text:last-child { color: var(--color-muted); font-size: 18rpx; }
.direction-pad { position: relative; display: grid; width: 174rpx; height: 174rpx; flex: 0 0 auto; grid-template: repeat(3,1fr)/repeat(3,1fr); gap: 4rpx; }
.direction { display: grid; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 12rpx; background: var(--color-primary-soft); box-shadow: 3rpx 3rpx 0 var(--color-ink); color: var(--color-ink); font-size: 31rpx; font-weight: 900; }
.direction.up { grid-area: 1/2; }.direction.left { grid-area: 2/1; }.direction.down { grid-area: 3/2; }.direction.right { grid-area: 2/3; }
.pad-center { grid-area: 2/2; border: 3rpx solid var(--color-ink); border-radius: 12rpx; background: var(--color-yellow); }
.warehouse-complete { margin-top: 25rpx; padding: 29rpx; text-align: center; }
.complete-badge { display: grid; width: 68rpx; height: 68rpx; margin: 0 auto 13rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 16rpx; background: var(--color-aqua); box-shadow: 4rpx 4rpx 0 var(--color-ink); font-size: 35rpx; font-weight: 900; }
.complete-title { color: var(--color-ink); font-size: 33rpx; font-weight: 900; }
.complete-stars { margin-top: 6rpx; color: var(--color-warning); font-size: 39rpx; letter-spacing: 5rpx; }
.complete-detail { margin: 6rpx 0 20rpx; color: var(--color-muted); font-size: 20rpx; }
.complete-actions { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 12rpx; }
@media (max-height: 700px) { .sokoban-page .page-subtitle { display: none; } .compact-controls { margin-top: 13rpx; } .control-row button { height: 59rpx; } .sokoban-status { margin-top: 14rpx; } .move-console { min-height: 152rpx; } .direction-pad { width: 148rpx; height: 148rpx; } }
