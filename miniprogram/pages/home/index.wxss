.home-page {
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(245, 199, 91, 0.08) 0, rgba(242, 246, 243, 0) 260rpx),
    var(--color-bg);
}

.home-header,
.brand-block {
  width: 100%;
}

.hero {
  position: relative;
  display: flex;
  width: 100%;
  min-height: 340rpx;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
  padding: 38rpx 32rpx 38rpx 36rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(22, 54, 58, 0.18);
  transition: opacity 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.hero::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 8rpx;
  background: linear-gradient(180deg, var(--color-coral), var(--color-accent));
  content: "";
}

.hero::after {
  position: absolute;
  right: -104rpx;
  bottom: -130rpx;
  width: 300rpx;
  height: 300rpx;
  border: 28rpx solid rgba(66, 191, 174, 0.11);
  border-radius: 50%;
  content: "";
}

.hero.hero-pressed {
  box-shadow: 0 8rpx 18rpx rgba(22, 54, 58, 0.16);
}

.hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  min-width: 0;
  max-width: 380rpx;
  flex: 1;
  flex-direction: column;
}

.hero-title {
  font-size: 39rpx;
  font-weight: 820;
  letter-spacing: -1rpx;
  line-height: 1.22;
}

.hero-note {
  margin-top: 15rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 23rpx;
  line-height: 1.55;
}

.hero-cta {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  align-self: flex-start;
  gap: 16rpx;
  margin-top: 28rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: 24rpx;
  font-weight: 780;
}

.inline-arrow {
  position: relative;
  width: 22rpx;
  height: 18rpx;
  color: currentColor;
}

.inline-arrow::before {
  position: absolute;
  top: 8rpx;
  left: 1rpx;
  width: 19rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
  content: "";
}

.inline-arrow::after {
  position: absolute;
  top: 3rpx;
  right: 0;
  width: 10rpx;
  height: 10rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  content: "";
}

.word-stack {
  position: relative;
  z-index: 2;
  width: 150rpx;
  height: 170rpx;
  flex: 0 0 auto;
  margin-left: 16rpx;
}

.hero-word,
.word-shadow {
  position: absolute;
  display: grid;
  width: 104rpx;
  height: 116rpx;
  place-items: center;
  border: 2rpx solid rgba(22, 54, 58, 0.6);
  border-radius: 22rpx;
  font-size: 46rpx;
  font-weight: 820;
  box-shadow: 0 9rpx 18rpx rgba(0, 0, 0, 0.2);
}

.hero-word {
  right: 0;
  bottom: 0;
  z-index: 3;
  background: var(--color-accent);
  color: var(--color-ink);
  transform: rotate(5deg);
}

.word-shadow.middle {
  top: 25rpx;
  left: 13rpx;
  z-index: 2;
  background: var(--color-coral);
  color: #ffffff;
  transform: rotate(-7deg);
}

.word-shadow.back {
  top: 0;
  left: 0;
  z-index: 1;
  background: var(--color-mint);
  color: var(--color-ink);
  transform: rotate(-14deg);
}

.mode-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 42rpx;
}

.mode-heading text:first-child {
  font-size: var(--font-section);
  font-weight: 780;
}

.mode-heading text:last-child {
  color: var(--color-muted);
  font-size: var(--font-label);
}

.mode-list {
  display: flex;
  width: 100%;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.mode-row {
  display: flex;
  width: 100%;
  min-width: 0;
  min-height: 136rpx;
  align-items: center;
  padding: 20rpx 22rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 22rpx rgba(22, 54, 58, 0.07);
  transition: opacity 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.mode-row.card-pressed {
  box-shadow: 0 3rpx 10rpx rgba(22, 54, 58, 0.08);
}

.mode-icon {
  display: grid;
  width: 80rpx;
  height: 80rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 20rpx;
  color: var(--color-ink);
  font-size: 29rpx;
  font-weight: 820;
}

.campaign .mode-icon { background: #ffe3a0; }
.battle .mode-icon { background: #fbdedb; }

.mode-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 20rpx;
}

.mode-title {
  color: var(--color-text);
  font-size: 29rpx;
  font-weight: 780;
}

.mode-description {
  margin-top: 7rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  line-height: 1.45;
}

.mode-arrow {
  display: grid;
  width: 60rpx;
  height: 60rpx;
  flex: 0 0 auto;
  margin-left: 12rpx;
  place-items: center;
  border: 2rpx solid #aad5ce;
  border-radius: 50%;
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
}

.save-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 28rpx;
  color: #8e6d28;
  font-size: 21rpx;
}

.save-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-accent);
}

.save-hint.saved {
  color: var(--color-primary-dark);
}

.save-hint.saved .save-dot {
  background: var(--color-mint);
}

@media (max-height: 700px) {
  .hero {
    min-height: 292rpx;
    margin-top: 24rpx;
    padding-top: 30rpx;
    padding-bottom: 30rpx;
  }

  .mode-heading {
    margin-top: 30rpx;
  }

  .mode-row {
    min-height: 118rpx;
  }
}
