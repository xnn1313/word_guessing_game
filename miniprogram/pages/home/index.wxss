.home-page {
  overflow: hidden;
  background:
    radial-gradient(circle at 96% 2%, rgba(116, 104, 223, 0.13), transparent 34%),
    #f4f6fb;
}

.home-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.account-button {
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 210rpx;
  min-height: 64rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e5f0;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #5e687c;
  font-size: 24rpx;
}

.account-button text:last-child {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-dot {
  width: 12rpx;
  height: 12rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: #c1c6d0;
}

.account-dot.online {
  background: #41a16e;
  box-shadow: 0 0 0 6rpx rgba(65, 161, 110, 0.1);
}

.hero {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 260rpx;
  margin-top: 34rpx;
  padding: 34rpx 32rpx;
  overflow: hidden;
  border: none;
  background: linear-gradient(135deg, #5a74c7 0%, #7369da 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 46rpx rgba(72, 86, 164, 0.24);
}

.hero-word {
  position: relative;
  z-index: 2;
  display: grid;
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 auto;
  place-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 64rpx;
  font-weight: 800;
  box-shadow: inset 0 0 30rpx rgba(255, 255, 255, 0.08);
}

.hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  margin-left: 28rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 750;
}

.hero-note {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.hero-orbit {
  position: absolute;
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
}

.orbit-one {
  top: -100rpx;
  right: -40rpx;
  width: 330rpx;
  height: 330rpx;
}

.orbit-two {
  right: 20rpx;
  bottom: -130rpx;
  width: 250rpx;
  height: 250rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 34rpx;
}

.mode-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 146rpx;
  padding: 24rpx;
  border: 2rpx solid #e6eaf2;
  border-radius: 28rpx;
  background: #ffffff;
  text-align: left;
  box-shadow: 0 10rpx 28rpx rgba(43, 57, 88, 0.055);
}

.mode-icon {
  display: grid;
  width: 82rpx;
  height: 82rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.classic .mode-icon {
  background: #edf3ff;
  color: #4e70c1;
}

.campaign .mode-icon {
  background: #edf8f1;
  color: #3b8d62;
}

.battle .mode-icon {
  background: #f4efff;
  color: #7658bd;
}

.mode-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 22rpx;
}

.mode-title {
  color: #2e394f;
  font-size: 30rpx;
  font-weight: 730;
}

.mode-description {
  margin-top: 8rpx;
  color: #8991a1;
  font-size: 23rpx;
  line-height: 1.45;
}

.mode-arrow {
  margin-left: 14rpx;
  color: #a8afbd;
  font-size: 48rpx;
  font-weight: 300;
}

.save-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 30rpx;
  color: #9a7a3d;
  font-size: 23rpx;
}

.save-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #d59a42;
}

.save-hint.saved {
  color: #4f8c69;
}

.save-hint.saved .save-dot {
  background: #41a16e;
}
