.home-page {
  overflow: hidden;
  background: #f3f7f5;
}

.home-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.brand-block {
  min-width: 0;
  flex: 1;
}

.account-button {
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 202rpx;
  min-height: 62rpx;
  padding: 7rpx 16rpx 7rpx 8rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 32rpx;
  background: #ffffff;
  color: #61726e;
  font-size: 22rpx;
}

.account-button text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-avatar {
  display: grid;
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 50%;
  background: #e9efed;
  color: #758480;
  font-size: 21rpx;
  font-weight: 750;
}

.account-button.signed .account-avatar {
  background: #dff5ee;
  color: #08735c;
}

.hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 306rpx;
  margin-top: 34rpx;
  padding: 38rpx 32rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background: #17343b;
  color: #ffffff;
  text-align: left;
  box-shadow: 0 18rpx 36rpx rgba(23, 52, 59, 0.18);
}

.hero::after {
  position: absolute;
  right: -80rpx;
  bottom: -120rpx;
  width: 310rpx;
  height: 310rpx;
  border: 34rpx solid rgba(255, 255, 255, 0.035);
  border-radius: 50%;
  content: "";
}

.hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  max-width: 390rpx;
  flex-direction: column;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 820;
  line-height: 1.25;
}

.hero-note {
  margin-top: 15rpx;
  color: #b9cfcb;
  font-size: 22rpx;
  line-height: 1.55;
}

.hero-cta {
  display: flex;
  align-items: center;
  align-self: flex-start;
  margin-top: 30rpx;
  padding: 15rpx 22rpx;
  border-radius: 18rpx;
  background: #ffc857;
  color: #233637;
  font-size: 24rpx;
  font-weight: 780;
}

.hero-cta text {
  margin-left: 16rpx;
  font-size: 28rpx;
}

.word-stack {
  position: relative;
  z-index: 2;
  width: 160rpx;
  height: 184rpx;
  flex: 0 0 auto;
  margin-left: 8rpx;
}

.hero-word,
.word-shadow {
  position: absolute;
  display: grid;
  width: 116rpx;
  height: 128rpx;
  place-items: center;
  border-radius: 24rpx;
  font-size: 54rpx;
  font-weight: 850;
}

.hero-word {
  right: 0;
  bottom: 0;
  z-index: 3;
  background: #ffffff;
  color: #17343b;
  transform: rotate(5deg);
}

.word-shadow.middle {
  top: 25rpx;
  left: 13rpx;
  z-index: 2;
  background: #16a681;
  color: rgba(255, 255, 255, 0.75);
  transform: rotate(-7deg);
}

.word-shadow.back {
  top: 0;
  left: 0;
  z-index: 1;
  background: #31555c;
  color: rgba(255, 255, 255, 0.35);
  transform: rotate(-15deg);
}

.mode-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 38rpx;
}

.mode-heading text:first-child {
  font-size: 30rpx;
  font-weight: 790;
}

.mode-heading text:last-child {
  color: #8a9894;
  font-size: 21rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.mode-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 126rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: left;
}

.mode-icon {
  display: grid;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 20rpx;
  font-size: 29rpx;
  font-weight: 820;
}

.campaign .mode-icon {
  background: #e2f6ef;
  color: #0b8265;
}

.battle .mode-icon {
  background: #fff0cc;
  color: #9a6517;
}

.mode-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 20rpx;
}

.mode-title {
  color: #203331;
  font-size: 29rpx;
  font-weight: 760;
}

.mode-description {
  margin-top: 7rpx;
  color: #82908c;
  font-size: 21rpx;
  line-height: 1.45;
}

.mode-arrow {
  display: grid;
  width: 54rpx;
  height: 54rpx;
  margin-left: 12rpx;
  place-items: center;
  border-radius: 50%;
  background: #f1f5f3;
  color: #5f716c;
  font-size: 25rpx;
}

.save-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 26rpx;
  color: #9a7435;
  font-size: 21rpx;
}

.save-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #d69b3c;
}

.save-hint.saved {
  color: #4e806f;
}

.save-hint.saved .save-dot {
  background: #12a37f;
}

@media (max-height: 700px) {
  .hero {
    min-height: 270rpx;
    margin-top: 24rpx;
  }

  .mode-heading {
    margin-top: 28rpx;
  }

  .mode-row {
    min-height: 112rpx;
  }
}
