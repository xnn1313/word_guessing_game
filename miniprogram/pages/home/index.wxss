.home-page {
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.home-header {
  margin-bottom: 28rpx;
}

.hero {
  position: relative;
  display: flex;
  min-height: 310rpx;
  align-items: stretch;
  overflow: hidden;
  padding: 34rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 30rpx;
  background: var(--color-primary);
  box-shadow: var(--shadow-hard);
  color: #ffffff;
}

.hero::before,
.hero::after {
  position: absolute;
  border: 18rpx solid rgba(255, 255, 255, 0.13);
  border-radius: 50%;
  content: "";
}

.hero::before { top: -90rpx; right: 30rpx; width: 220rpx; height: 220rpx; }
.hero::after { right: -100rpx; bottom: -100rpx; width: 260rpx; height: 260rpx; }

.hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  width: 67%;
  justify-content: center;
  flex-direction: column;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.15;
}

.hero-note {
  margin-top: 13rpx;
  color: #ffffff;
  font-size: 23rpx;
  line-height: 1.5;
}

.hero-cta {
  display: flex;
  width: auto;
  max-width: 100%;
  align-self: flex-start;
  min-height: 88rpx;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 22rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 17rpx;
  background: var(--color-yellow);
  box-shadow: 5rpx 5rpx 0 var(--color-ink);
  color: var(--color-ink);
  font-size: 24rpx;
  font-weight: 900;
}

.inline-arrow {
  position: relative;
  width: 24rpx;
  height: 3rpx;
  background: currentColor;
}

.inline-arrow::after {
  position: absolute;
  top: -6rpx;
  right: 0;
  width: 11rpx;
  height: 11rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  content: "";
}

.word-stack {
  position: absolute;
  z-index: 1;
  right: 26rpx;
  bottom: 32rpx;
  width: 150rpx;
  height: 172rpx;
}

.word-shadow,
.hero-word {
  position: absolute;
  display: grid;
  width: 104rpx;
  height: 118rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  box-shadow: 5rpx 5rpx 0 rgba(21, 27, 58, 0.8);
  color: var(--color-ink);
  font-size: 38rpx;
  font-weight: 900;
}

.word-shadow.back { top: 0; left: 0; background: var(--color-aqua); transform: rotate(-12deg); }
.word-shadow.middle { top: 24rpx; left: 28rpx; background: var(--color-coral); transform: rotate(4deg); }
.hero-word { right: 0; bottom: 0; background: var(--color-yellow); transform: rotate(7deg); }

.mode-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 44rpx 0 18rpx;
}

.mode-heading text:first-child {
  color: var(--color-ink);
  font-size: var(--font-section);
  font-weight: 900;
}

.mode-heading text:last-child {
  color: var(--color-muted);
  font-size: 21rpx;
}

.mode-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.mode-row {
  position: relative;
  display: flex;
  min-height: 210rpx;
  padding: 22rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 24rpx;
  box-shadow: 6rpx 6rpx 0 var(--color-ink);
  flex-direction: column;
}

.mode-row.campaign { background: var(--color-yellow); }
.mode-row.battle { background: var(--color-aqua); }

.mode-icon {
  display: grid;
  width: 60rpx;
  height: 60rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 15rpx;
  background: rgba(255,255,255,0.45);
  font-size: 28rpx;
  font-weight: 900;
}

.mode-copy { display: flex; margin-top: 16rpx; flex-direction: column; }
.mode-title { color: var(--color-ink); font-size: 28rpx; font-weight: 900; }
.mode-description { margin-top: 5rpx; color: rgba(21,27,58,0.7); font-size: 19rpx; line-height: 1.35; }
.mode-arrow { position: absolute; right: 20rpx; bottom: 22rpx; color: var(--color-ink); }

.save-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 28rpx;
  color: var(--color-muted);
  font-size: 21rpx;
}

.save-dot { width: 13rpx; height: 13rpx; border: 3rpx solid var(--color-ink); border-radius: 50%; background: var(--color-coral); }
.save-hint.saved .save-dot { background: var(--color-aqua); }

.lab-rules {
  display: grid;
  gap: 12rpx;
  margin-top: 28rpx;
  padding: 22rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 24rpx;
  background: #ffffff;
}

.lab-rules > view {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  gap: 18rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.lab-rules > view:last-child { border-bottom: none; }
.lab-rules > view text:first-child { color: var(--color-primary); font-size: 18rpx; font-weight: 900; letter-spacing: 2rpx; }
.lab-rules > view text:last-child { color: var(--color-text); font-size: 23rpx; font-weight: 700; }

@media (max-height: 700px) {
  .hero { min-height: 280rpx; }
  .mode-heading { margin-top: 34rpx; }
}
