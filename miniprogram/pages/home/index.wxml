<view class="page-shell home-page">
  <view class="home-header">
    <view class="brand-block">
      <view class="page-kicker">WORD LAB · 猜词专区</view>
      <view class="page-title">猜词实验室</view>
      <view class="page-subtitle">从一个词开始，慢慢靠近答案。</view>
    </view>
  </view>

  <view class="hero" bindtap="openClassic" hover-class="hero-pressed">
    <view class="hero-copy">
      <text class="hero-title">今天能几次猜中？</text>
      <text class="hero-note">输入相关词，关联度越高就越接近答案</text>
      <view class="hero-cta">开始经典猜词 <view class="inline-arrow"></view></view>
    </view>
    <view class="word-stack">
      <view class="word-shadow back">猜</view>
      <view class="word-shadow middle">近</view>
      <view class="hero-word">词</view>
    </view>
  </view>

  <view class="mode-heading">
    <text>更多玩法</text>
    <text>选择一种挑战</text>
  </view>

  <view class="mode-list">
    <view class="mode-row campaign" bindtap="openCampaign" hover-class="card-pressed">
      <view class="mode-icon">关</view>
      <view class="mode-copy">
        <text class="mode-title">分类闯关</text>
        <text class="mode-description">13 个分类 · 260 关 · 难度递增</text>
      </view>
      <view class="mode-arrow"><view class="inline-arrow"></view></view>
    </view>

    <view class="mode-row battle" bindtap="openBattle" hover-class="card-pressed">
      <view class="mode-icon">竞</view>
      <view class="mode-copy">
        <text class="mode-title">双人竞速</text>
        <text class="mode-description">邀请好友 · 90 秒实时对决</text>
      </view>
      <view class="mode-arrow"><view class="inline-arrow"></view></view>
    </view>
  </view>

  <view class="save-hint {{loggedIn ? 'saved' : ''}}">
    <text class="save-dot"></text>
    <text>{{loggedIn ? '游戏进度会自动保存' : '登录后保存闯关与对战记录'}}</text>
  </view>

  <view class="lab-rules">
    <view><text>01</text><text>从熟悉的词开始</text></view>
    <view><text>02</text><text>根据关联度调整方向</text></view>
    <view><text>03</text><text>越接近答案，颜色越亮</text></view>
  </view>
</view>
