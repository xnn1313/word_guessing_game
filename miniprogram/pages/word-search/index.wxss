.word-search-page { padding-bottom: calc(58rpx + env(safe-area-inset-bottom)); }
.search-controls { margin-top: 22rpx; padding: 12rpx; border-radius: 24rpx; box-shadow: 6rpx 6rpx 0 var(--color-ink); }
.control-row { display: grid; gap: 8rpx; }
.mode-row { grid-template-columns: repeat(2,minmax(0,1fr)); }
.difficulty-row { margin-top: 8rpx; grid-template-columns: repeat(3,minmax(0,1fr)); }
.control-row button { display: flex; height: 76rpx; align-items: center; justify-content: center; padding: 0 12rpx; border: 3rpx solid transparent; border-radius: 14rpx; color: var(--color-muted); font-size: 21rpx; font-weight: 850; line-height: 1; text-align: center; }
.control-row button.active { border-color: var(--color-ink); background: var(--color-yellow); color: var(--color-ink); box-shadow: 3rpx 3rpx 0 var(--color-ink); }
.mode-row button.active { background: var(--color-primary); color: #ffffff; }
.theme-scroll { width: 100%; margin-top: 10rpx; white-space: nowrap; }
.theme-list { display: inline-flex; gap: 8rpx; padding-right: 16rpx; }
.theme-chip { display: inline-flex; min-width: 148rpx; height: 72rpx; align-items: center; justify-content: center; padding: 0 18rpx; border: 3rpx solid var(--color-border); border-radius: 14rpx; background: var(--color-surface-soft); color: var(--color-muted); font-size: 20rpx; font-weight: 800; line-height: 1; text-align: center; vertical-align: top; }
.theme-chip.active { border-color: var(--color-ink); background: var(--color-aqua); color: var(--color-ink); }
.search-status { margin-top: 20rpx; }
.board-heading { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin: 22rpx 0 12rpx; }
.board-heading-copy { display: flex; min-width: 0; flex: 1; flex-direction: column; }
.board-heading-copy text:first-child { color: var(--color-ink); font-size: 27rpx; font-weight: 900; }
.board-heading-copy text:last-child { color: var(--color-muted); font-size: 19rpx; }
.board-heading-actions { display: grid; flex: 0 0 auto; grid-template-columns: repeat(2,120rpx); gap: 10rpx; }
.board-heading-actions button { display: flex; width: 120rpx; height: 88rpx; align-items: center; justify-content: center; padding: 0 10rpx; border: 3rpx solid var(--color-ink); border-radius: 15rpx; box-shadow: 3rpx 3rpx 0 var(--color-ink); color: var(--color-ink); font-size: 20rpx; font-weight: 850; line-height: 1; text-align: center; }
.hint-button { background: var(--color-yellow); }
.refresh-board { background: var(--color-violet-soft); }
.board-heading-actions button[disabled] { opacity: 0.38; box-shadow: none; transform: none; }
.word-search-board { display: grid; width: 100%; overflow: hidden; border: 4rpx solid var(--color-ink); border-radius: 24rpx; background: var(--color-ink); box-shadow: 7rpx 7rpx 0 var(--color-ink); touch-action: none; transition: border-color 160ms ease, box-shadow 160ms ease; }
.word-search-board.columns-8 { width: calc(100% + 32rpx); margin-left: -16rpx; }
.search-cell { display: flex; min-width: 0; aspect-ratio: 1; align-items: center; justify-content: center; padding: 0; border-right: 2rpx solid #d8ddef; border-bottom: 2rpx solid #d8ddef; background: #ffffff; color: var(--color-ink); font-size: 39rpx; font-weight: 900; line-height: 1; text-align: center; transition: background-color 140ms ease, color 140ms ease, box-shadow 140ms ease; }
.columns-7 .search-cell { font-size: 34rpx; }
.columns-8 .search-cell { font-size: 30rpx; }
.search-cell.found { background: var(--color-yellow-soft); color: var(--color-warning); }
.search-cell.selected { position: relative; z-index: 2; background: var(--color-aqua); color: var(--color-ink); box-shadow: inset 0 0 0 4rpx var(--color-primary-dark); }
.search-cell.selected.endpoint { background: var(--color-primary); color: #ffffff; }
.word-search-board.invalid { border-color: var(--color-danger); box-shadow: 7rpx 7rpx 0 var(--color-danger); }
.word-search-board.invalid .search-cell.selected { background: var(--color-coral); box-shadow: inset 0 0 0 4rpx var(--color-danger); }
.selection-feedback { display: flex; min-height: 70rpx; align-items: center; justify-content: center; gap: 12rpx; margin-top: 15rpx; padding: 10rpx 18rpx; border: 3rpx dashed var(--color-border); border-radius: 16rpx; background: rgba(255,255,255,0.66); color: var(--color-muted); font-size: 20rpx; font-weight: 700; text-align: center; }
.selection-feedback.active { border-style: solid; border-color: var(--color-primary); background: var(--color-primary-soft); color: var(--color-primary-dark); }
.selection-feedback.invalid { border-color: var(--color-danger); background: var(--color-coral-soft); color: var(--color-danger); }
.feedback-dot { width: 12rpx; height: 12rpx; flex: 0 0 auto; border-radius: 50%; background: var(--color-aqua); box-shadow: 0 0 0 5rpx rgba(99,221,208,0.2); }
.selection-feedback.active .feedback-dot { background: var(--color-primary); }
.selection-feedback.invalid .feedback-dot { background: var(--color-danger); }
.complete-panel { display: flex; align-items: center; margin-top: 26rpx; padding: 28rpx; flex-direction: column; text-align: center; }
.complete-title { color: var(--color-ink); font-size: 33rpx; font-weight: 900; }
.complete-stars { margin-top: 7rpx; color: var(--color-warning); font-size: 39rpx; letter-spacing: 5rpx; }
.complete-detail { margin: 5rpx 0 20rpx; color: var(--color-muted); font-size: 20rpx; }
.complete-actions { display: grid; width: 100%; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 12rpx; }
@media (max-height: 700px) { .word-search-page .page-subtitle { display: none; } .search-controls { margin-top: 14rpx; } .control-row button { height: 68rpx; } .theme-chip { height: 66rpx; } }
@media (prefers-reduced-motion: reduce) { .word-search-board,.search-cell { transition-duration: 0.01ms !important; } }
