.idiom-page {
  padding-top: 22rpx;
}

.idiom-page.game-view {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}

.game-view .character-bank {
  margin-top: auto;
  padding-top: 20rpx;
}

.daily-card {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 16rpx;
  margin-top: 26rpx;
  padding: 26rpx 26rpx 24rpx 32rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(22, 54, 58, 0.16);
}

.daily-card::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: var(--color-coral);
  content: "";
}

.daily-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.daily-copy text:first-child {
  color: var(--color-accent);
  font-size: 31rpx;
  font-weight: 800;
}

.daily-copy text:last-child {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 18rpx;
}

.daily-start {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  align-self: center;
  min-height: 72rpx;
  border-radius: 16rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: 21rpx;
  font-weight: 760;
  line-height: 72rpx;
}

.daily-options {
  display: grid;
  grid-column: 1 / 3;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 7rpx;
}

.daily-options button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 58rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 18rpx;
  line-height: 58rpx;
}

.daily-options button.active {
  border-color: #80cdc1;
  background: var(--color-primary);
  color: #ffffff;
  font-weight: 760;
}

.catalog-summary {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: baseline;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 20rpx;
  background: var(--color-surface);
}

.catalog-summary > text,
.catalog-summary > view:nth-child(2) {
  color: var(--color-muted);
  font-size: 19rpx;
}

.catalog-summary > view:nth-child(2) text {
  color: var(--color-primary-dark);
  font-size: 29rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.summary-track {
  height: 10rpx;
  grid-column: 1 / 3;
  margin-top: 17rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dfe8e5;
}

.summary-track view {
  min-width: 4rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--color-primary);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.category-card {
  overflow: hidden;
  border: 2rpx solid var(--color-border);
  border-radius: 22rpx;
  background: var(--color-surface);
  box-shadow: 0 7rpx 20rpx rgba(22, 54, 58, 0.06);
}

.category-header {
  display: grid;
  width: 100%;
  min-height: 116rpx;
  grid-template-columns: 62rpx minmax(0, 1fr) auto 32rpx;
  gap: 14rpx;
  align-items: center;
  padding: 17rpx 19rpx;
  text-align: left;
}

.category-number {
  display: grid;
  width: 60rpx;
  height: 60rpx;
  place-items: center;
  border-radius: 17rpx;
  background: #ffe3a0;
  color: var(--color-ink);
  font-size: 24rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.category-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.category-copy text:first-child { font-size: 27rpx; font-weight: 780; }
.category-copy text:last-child { overflow: hidden; margin-top: 4rpx; color: var(--color-muted); font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.category-score { color: var(--color-primary-dark); font-size: 19rpx; font-weight: 720; font-variant-numeric: tabular-nums; }
.category-arrow { color: var(--color-primary-dark); font-size: 28rpx; transition: transform 200ms ease; }
.category-arrow.open { transform: rotate(180deg); }

.level-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  padding: 16rpx;
  border-top: 2rpx solid var(--color-border);
  background: var(--color-surface-soft);
}

.level-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 82rpx;
  padding: 8rpx 2rpx;
  border: 2rpx solid var(--color-border-strong);
  border-radius: 13rpx;
  background: var(--color-surface);
  line-height: 1.15;
}

.level-button text { display: block; }
.level-button text:first-child { font-size: 23rpx; font-weight: 800; font-variant-numeric: tabular-nums; }
.level-button text:last-child { margin-top: 5rpx; color: var(--color-primary-dark); font-size: 17rpx; }
.level-button.completed { border-color: #92cfc4; background: var(--color-primary-soft); }
.level-button.locked { border-color: #d1dad6; background: #e9eeeb; color: #96a19e; }
.level-button.locked text:last-child { color: #96a19e; }

.back-button {
  min-height: 68rpx;
  margin-bottom: 10rpx;
  color: var(--color-primary-dark);
  font-size: 21rpx;
  font-weight: 700;
  line-height: 68rpx;
  text-align: left;
}

.game-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.difficulty-chip {
  flex: 0 0 auto;
  padding: 9rpx 14rpx;
  border: 2rpx solid #dfbd68;
  border-radius: 12rpx;
  background: #fff0c7;
  color: var(--color-ink);
  font-size: 18rpx;
  font-weight: 700;
}

.game-status {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 20rpx;
  padding: 16rpx 12rpx 16rpx 18rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(22, 54, 58, 0.15);
}

.game-status::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: var(--color-coral);
  content: "";
}

.game-status view { display: flex; align-items: center; flex-direction: column; border-right: 2rpx solid rgba(255, 255, 255, 0.13); }
.game-status view:last-child { border: none; }
.game-status text:first-child { color: rgba(255, 255, 255, 0.62); font-size: 18rpx; }
.game-status text:last-child { margin-top: 4rpx; color: var(--color-accent); font-size: 25rpx; font-weight: 800; font-variant-numeric: tabular-nums; }

.crossword-wrap {
  display: flex;
  justify-content: center;
  margin-top: 22rpx;
}

.crossword-board {
  display: grid;
  width: 410rpx;
  height: 410rpx;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  grid-template-rows: repeat(4, 1fr);
  gap: 8rpx;
}

.idiom-cell {
  display: grid;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  padding: 0;
  overflow: hidden;
  place-items: center;
  border: 2rpx solid var(--color-border-strong);
  border-radius: 15rpx;
  background: var(--color-surface);
  font-size: 43rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(22, 54, 58, 0.06);
}

.idiom-cell.fixed { border-color: var(--color-night); background: var(--color-night); color: #ffffff; }
.idiom-cell.active-entry { background: var(--color-primary-soft); }
.idiom-cell.selected { border-color: #d9b248; background: var(--color-accent); color: var(--color-ink); }
.idiom-cell.invalid { border-color: #e7aaa5; background: #ffe5e2; color: var(--color-danger); }

.clue-list {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.clue-card {
  display: inline-flex;
  width: 76%;
  min-height: 104rpx;
  margin-right: 10rpx;
  padding: 15rpx 18rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 17rpx;
  background: var(--color-surface);
  flex-direction: column;
  text-align: left;
  white-space: normal;
  vertical-align: top;
}

.clue-card text:first-child { color: var(--color-primary-dark); font-size: 18rpx; font-weight: 760; }
.clue-card text:last-child { margin-top: 7rpx; color: var(--color-text); font-size: 20rpx; line-height: 1.4; }
.clue-card.active { border-color: #86c8bd; background: var(--color-primary-soft); }

.character-bank {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 17rpx;
}

.character-bank button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 70rpx;
  border: 2rpx solid var(--color-border-strong);
  border-radius: 13rpx;
  background: var(--color-surface);
  font-size: 28rpx;
  font-weight: 780;
  line-height: 70rpx;
}

.game-tools {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 2fr);
  gap: 9rpx;
  margin-top: 15rpx;
}

.game-tools button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 76rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 15rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
  font-size: 21rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.game-tools .submit {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: #ffffff;
}

.complete-panel {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  padding: 27rpx;
  flex-direction: column;
  text-align: center;
}

.complete-title { font-size: 31rpx; font-weight: 800; }
.complete-stars { margin-top: 9rpx; color: #b87913; font-size: 39rpx; letter-spacing: 5rpx; }
.complete-detail { margin: 7rpx 0 20rpx; color: var(--color-muted); font-size: 21rpx; }

@media (max-height: 700px) {
  .crossword-board { width: 350rpx; height: 350rpx; }
  .page-subtitle { display: none; }
  .game-status { margin-top: 13rpx; }
  .clue-card { min-height: 88rpx; }
}
