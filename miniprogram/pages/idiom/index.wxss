.idiom-page { padding-bottom: calc(50rpx + env(safe-area-inset-bottom)); }
.daily-card { display: grid; grid-template-columns: minmax(0,1fr) 178rpx; gap: 18rpx; margin-top: 28rpx; padding: 25rpx; border: 3rpx solid var(--color-ink); border-radius: 28rpx; background: var(--color-primary); box-shadow: var(--shadow-hard); color: #ffffff; }
.daily-copy { display: flex; justify-content: center; flex-direction: column; }
.daily-copy text:first-child { color: var(--color-yellow); font-size: 34rpx; font-weight: 900; }
.daily-copy text:last-child { margin-top: 5rpx; color: #ffffff; font-size: 20rpx; }
.daily-start { display: grid; min-height: 88rpx; align-self: center; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-yellow); box-shadow: 5rpx 5rpx 0 var(--color-ink); color: var(--color-ink); font-size: 24rpx; font-weight: 900; line-height: 1.2; text-align: center; }
.daily-options { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 10rpx; }
.daily-options button { display: grid; min-height: 88rpx; place-items: center; border: 2rpx solid rgba(255,255,255,0.75); border-radius: 13rpx; color: #ffffff; font-size: 20rpx; font-weight: 800; line-height: 1.2; text-align: center; }
.daily-options button.active { border-color: var(--color-ink); background: var(--color-aqua); color: var(--color-ink); box-shadow: 3rpx 3rpx 0 var(--color-ink); }
.catalog-summary { display: grid; grid-template-columns: 1fr auto; gap: 9rpx 18rpx; margin-top: 24rpx; padding: 20rpx 22rpx; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: #ffffff; }
.catalog-summary > text { color: var(--color-muted); font-size: 21rpx; }
.catalog-summary > view:not(.summary-track) { color: var(--color-muted); font-size: 21rpx; }
.catalog-summary > view:not(.summary-track) text { color: var(--color-primary); font-size: 29rpx; font-weight: 900; }
.summary-track { grid-column: 1 / -1; height: 13rpx; overflow: hidden; border: 2rpx solid var(--color-ink); border-radius: 99rpx; background: var(--color-primary-soft); }
.summary-track > view { min-width: 4rpx; height: 100%; background: var(--color-primary); }
.category-list { display: flex; gap: 18rpx; margin-top: 24rpx; flex-direction: column; }
.category-card { overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 24rpx; background: #ffffff; box-shadow: 5rpx 5rpx 0 rgba(21,27,58,0.16); }
.category-header { display: grid; width: 100%; min-height: 116rpx; grid-template-columns: 68rpx minmax(0,1fr) auto 42rpx; align-items: center; gap: 14rpx; padding: 17rpx 18rpx; text-align: left; }
.category-number { display: grid; width: 62rpx; height: 62rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 15rpx; background: var(--color-yellow); color: var(--color-ink); font-size: 25rpx; font-weight: 900; }
.category-card:nth-child(3n + 2) .category-number { background: var(--color-coral); }
.category-card:nth-child(3n) .category-number { background: var(--color-aqua); }
.category-copy { display: flex; min-width: 0; flex-direction: column; }
.category-copy text:first-child { color: var(--color-ink); font-size: 27rpx; font-weight: 900; }
.category-copy text:last-child { overflow: hidden; margin-top: 3rpx; color: var(--color-muted); font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.category-score { color: var(--color-primary-dark); font-size: 20rpx; font-weight: 850; white-space: nowrap; }
.category-arrow { display: grid; width: 40rpx; height: 40rpx; place-items: center; font-size: 25rpx; transition: transform 180ms ease; }
.category-arrow.open { transform: rotate(180deg); }
.level-grid { display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap: 11rpx; padding: 18rpx; border-top: 3rpx solid var(--color-ink); background: var(--color-surface-soft); }
.level-button { display: flex; min-height: 104rpx; align-items: center; justify-content: center; border: 3rpx solid var(--color-ink); border-radius: 15rpx; background: #ffffff; flex-direction: column; }
.level-button text:first-child { color: var(--color-ink); font-size: 27rpx; font-weight: 900; }
.level-button text:last-child { color: var(--color-primary-dark); font-size: 16rpx; }
.level-button.completed { border-top: 7rpx solid var(--color-aqua); }
.level-button.locked { border-color: #c7cbda; background: #e8eaf1; }
.level-button.locked text { color: var(--color-subtle); }

.back-button { display: inline-flex; min-height: 88rpx; align-items: center; justify-content: center; margin-bottom: 14rpx; padding: 0 8rpx; color: var(--color-primary-dark); font-size: 21rpx; font-weight: 850; }
.back-button::before { margin-right: 8rpx; content: "←"; }
.game-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.game-heading > view:first-child { min-width: 0; flex: 1; }
.difficulty-chip { min-width: 84rpx; margin-top: 5rpx; padding: 10rpx 14rpx; border: 3rpx solid var(--color-ink); border-radius: 14rpx; background: var(--color-yellow); color: var(--color-ink); font-size: 19rpx; font-weight: 900; text-align: center; }
.game-status { display: grid; grid-template-columns: repeat(3,1fr); margin-top: 20rpx; overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: var(--color-ink); }
.game-status > view { display: flex; min-height: 86rpx; align-items: center; justify-content: center; flex-direction: column; border-right: 2rpx solid rgba(255,255,255,0.16); }
.game-status > view:last-child { border-right: none; }
.game-status text:first-child { color: #bec5dc; font-size: 17rpx; }
.game-status text:last-child { color: var(--color-yellow); font-size: 27rpx; font-weight: 900; font-variant-numeric: tabular-nums; }
.crossword-wrap { display: flex; justify-content: center; margin-top: 20rpx; }
.crossword-board { display: grid; gap: 8rpx; }
.crossword-board.size-4 { width: 420rpx; height: 420rpx; grid-template-columns: repeat(4,minmax(0,1fr)); grid-template-rows: repeat(4,1fr); }
.crossword-board.size-5 { width: 470rpx; height: 470rpx; grid-template-columns: repeat(5,minmax(0,1fr)); grid-template-rows: repeat(5,1fr); }
.crossword-board.size-6 { width: 516rpx; height: 516rpx; grid-template-columns: repeat(6,minmax(0,1fr)); grid-template-rows: repeat(6,1fr); }
.crossword-board.size-7 { width: 554rpx; height: 554rpx; grid-template-columns: repeat(7,minmax(0,1fr)); grid-template-rows: repeat(7,1fr); }
.crossword-board.size-8 { width: 590rpx; height: 590rpx; grid-template-columns: repeat(8,minmax(0,1fr)); grid-template-rows: repeat(8,1fr); }
.idiom-cell { display: grid; min-width: 0; padding: 0; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 16rpx; background: #ffffff; color: var(--color-ink); font-size: 40rpx; font-weight: 900; line-height: 1; box-shadow: 4rpx 4rpx 0 rgba(21,27,58,0.14); }
.size-5 .idiom-cell { font-size: 36rpx; }
.size-6 .idiom-cell { border-radius: 13rpx; font-size: 32rpx; }
.size-7 .idiom-cell { border-radius: 11rpx; font-size: 28rpx; }
.size-8 .idiom-cell { border-radius: 9rpx; font-size: 25rpx; }
.idiom-cell.fixed { background: var(--color-yellow); }
.idiom-cell.active-entry { background: var(--color-aqua-soft); }
.idiom-cell.selected { background: var(--color-aqua); box-shadow: 5rpx 5rpx 0 var(--color-ink); }
.idiom-cell.invalid { background: var(--color-coral-soft); color: var(--color-danger); }
.clue-list { display: grid; width: 100%; margin-top: 18rpx; gap: 10rpx; }
.clue-card { display: flex; width: 100%; min-height: 96rpx; align-items: flex-start; justify-content: center; padding: 15rpx 18rpx; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: #ffffff; text-align: left; flex-direction: column; }
.clue-card.active { background: var(--color-primary-soft); box-shadow: 4rpx 4rpx 0 var(--color-primary); }
.clue-card text:first-child { color: var(--color-primary-dark); font-size: 18rpx; font-weight: 900; }
.clue-card text:last-child { margin-top: 3rpx; overflow: hidden; color: var(--color-ink); font-size: 22rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.character-bank { display: grid; grid-template-columns: repeat(6,minmax(0,1fr)); gap: 10rpx; margin-top: 18rpx; }
.character-bank button { display: grid; min-height: 88rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 15rpx; background: #ffffff; color: var(--color-ink); font-size: 29rpx; font-weight: 900; line-height: 1; text-align: center; }
.game-action-panel { margin-top: 14rpx; padding: 14rpx; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: #ffffff; }
.game-tools { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 10rpx; }
.game-tools button { display: grid; min-height: 88rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 16rpx; background: var(--color-violet-soft); color: var(--color-ink); font-size: 21rpx; font-weight: 850; line-height: 1.2; text-align: center; }
.idiom-submit { margin-top: 12rpx; }
.complete-panel { display: flex; align-items: center; margin-top: 24rpx; padding: 30rpx; flex-direction: column; text-align: center; }
.complete-title { color: var(--color-ink); font-size: 33rpx; font-weight: 900; }
.complete-stars { margin-top: 8rpx; color: var(--color-warning); font-size: 38rpx; letter-spacing: 5rpx; }
.complete-detail { margin: 5rpx 0 20rpx; color: var(--color-muted); font-size: 21rpx; }
@media (max-height: 700px) { .game-view .page-subtitle { display: none; } }
