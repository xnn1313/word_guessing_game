.idiom-page { padding-top: 22rpx; }

.daily-card {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 134rpx;
  gap: 16rpx;
  margin-top: 26rpx;
  padding: 26rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 24rpx;
  background: var(--color-night);
  color: #fff;
  box-shadow: 7rpx 7rpx 0 var(--color-primary);
}

.daily-copy { display: flex; flex-direction: column; }
.daily-copy text:first-child { color: var(--color-accent); font-size: 31rpx; font-weight: 850; }
.daily-copy text:last-child { margin-top: 7rpx; color: rgba(255,255,255,.58); font-size: 18rpx; }
.daily-start { align-self: center; height: 66rpx; border: 3rpx solid var(--color-ink); border-radius: 16rpx; background: var(--color-accent); color: var(--color-ink); font-size: 22rpx; font-weight: 820; line-height: 62rpx; }

.daily-options { display: grid; grid-column: 1 / 3; grid-template-columns: repeat(3, 1fr); gap: 7rpx; }
.daily-options button { height: 50rpx; border: 2rpx solid rgba(255,255,255,.22); border-radius: 12rpx; color: rgba(255,255,255,.6); font-size: 18rpx; line-height: 46rpx; }
.daily-options button.active { border-color: var(--color-accent); background: var(--color-primary); color: #fff; font-weight: 800; }

.catalog-summary { margin-top: 20rpx; padding: 20rpx 22rpx; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: var(--color-surface); }
.catalog-summary > text { color: var(--color-muted); font-size: 19rpx; }
.catalog-summary > view:nth-child(2) { float: right; color: var(--color-muted); font-size: 19rpx; }
.catalog-summary > view:nth-child(2) text { color: var(--color-primary-dark); font-size: 29rpx; font-weight: 850; }
.summary-track { height: 10rpx; margin-top: 17rpx; overflow: hidden; border-radius: 10rpx; background: #e5dfd4; }
.summary-track view { min-width: 4rpx; height: 100%; background: var(--color-primary); }

.category-list { display: flex; flex-direction: column; gap: 13rpx; margin-top: 18rpx; }
.category-card { overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: var(--color-surface); }
.category-header { display: grid; width: 100%; min-height: 112rpx; grid-template-columns: 64rpx 1fr auto 32rpx; gap: 14rpx; align-items: center; padding: 17rpx 19rpx; text-align: left; }
.category-number { display: grid; width: 60rpx; height: 60rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 17rpx; background: var(--color-accent); font-size: 24rpx; font-weight: 850; }
.category-copy { display: flex; min-width: 0; flex-direction: column; }
.category-copy text:first-child { font-size: 27rpx; font-weight: 820; }
.category-copy text:last-child { overflow: hidden; margin-top: 4rpx; color: var(--color-muted); font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.category-score { color: var(--color-primary-dark); font-size: 19rpx; font-weight: 780; }
.category-arrow { font-size: 28rpx; transition: transform .2s ease; }
.category-arrow.open { transform: rotate(180deg); }

.level-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8rpx; padding: 16rpx; border-top: 2rpx solid var(--color-border); background: #f4f0e7; }
.level-button { min-height: 76rpx; padding: 8rpx 2rpx; border: 2rpx solid var(--color-ink); border-radius: 12rpx; background: var(--color-surface); line-height: 1.15; }
.level-button text { display: block; }
.level-button text:first-child { font-size: 23rpx; font-weight: 850; }
.level-button text:last-child { margin-top: 5rpx; color: var(--color-primary-dark); font-size: 14rpx; }
.level-button.completed { background: #dff3ee; }
.level-button.locked { border-color: #b7b2a9; background: #e6e1d8; color: #99958d; }
.level-button.locked text:last-child { color: #99958d; }

.back-button { margin-bottom: 18rpx; color: var(--color-primary-dark); font-size: 21rpx; font-weight: 750; }
.game-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.difficulty-chip { flex: 0 0 auto; padding: 9rpx 14rpx; border: 2rpx solid var(--color-ink); border-radius: 12rpx; background: var(--color-accent); font-size: 18rpx; font-weight: 750; }

.game-status { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 20rpx; padding: 16rpx; border: 3rpx solid var(--color-ink); border-radius: 20rpx; background: var(--color-night); color: #fff; box-shadow: 6rpx 6rpx 0 var(--color-primary); }
.game-status view { display: flex; align-items: center; flex-direction: column; border-right: 2rpx solid rgba(255,255,255,.13); }
.game-status view:last-child { border: none; }
.game-status text:first-child { color: rgba(255,255,255,.55); font-size: 17rpx; }
.game-status text:last-child { margin-top: 4rpx; color: var(--color-accent); font-size: 25rpx; font-weight: 820; }

.crossword-wrap { display: flex; justify-content: center; margin-top: 22rpx; }
.crossword-board { display: grid; width: 410rpx; height: 410rpx; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(4, 1fr); gap: 7rpx; }
.idiom-cell { display: grid; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 15rpx; background: var(--color-surface); font-size: 43rpx; font-weight: 850; line-height: 1; box-shadow: 3rpx 3rpx 0 rgba(25,50,58,.12); }
.idiom-cell.fixed { background: var(--color-night); color: #fff; }
.idiom-cell.active-entry { background: #e0f3ef; }
.idiom-cell.selected { background: var(--color-accent); color: var(--color-ink); }
.idiom-cell.invalid { background: #ffe1dc; color: var(--color-danger); }

.clue-list { width: 100%; margin-top: 18rpx; white-space: nowrap; }
.clue-card { display: inline-flex; width: 76%; min-height: 104rpx; margin-right: 10rpx; padding: 15rpx 18rpx; border: 2rpx solid var(--color-ink); border-radius: 17rpx; background: var(--color-surface); flex-direction: column; text-align: left; white-space: normal; vertical-align: top; }
.clue-card text:first-child { color: var(--color-primary-dark); font-size: 17rpx; font-weight: 800; }
.clue-card text:last-child { margin-top: 7rpx; color: var(--color-text); font-size: 20rpx; line-height: 1.4; }
.clue-card.active { border-width: 3rpx; background: #e5f4f0; }

.character-bank { display: grid; grid-template-columns: repeat(7, 1fr); gap: 7rpx; margin-top: 17rpx; }
.character-bank button { height: 66rpx; border: 3rpx solid var(--color-ink); border-radius: 13rpx; background: var(--color-surface); font-size: 28rpx; font-weight: 820; line-height: 62rpx; box-shadow: 3rpx 3rpx 0 rgba(25,50,58,.12); }
.game-tools { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 9rpx; margin-top: 15rpx; }
.game-tools button { height: 68rpx; border: 3rpx solid var(--color-ink); border-radius: 15rpx; background: #e4f2ef; color: var(--color-primary-dark); font-size: 21rpx; font-weight: 760; line-height: 64rpx; }
.game-tools .submit { background: var(--color-primary); color: #fff; }

.complete-panel { display: flex; align-items: center; margin-top: 18rpx; padding: 27rpx; flex-direction: column; text-align: center; }
.complete-title { font-size: 31rpx; font-weight: 850; }
.complete-stars { margin-top: 9rpx; color: #d39822; font-size: 39rpx; letter-spacing: 5rpx; }
.complete-detail { margin: 7rpx 0 20rpx; color: var(--color-muted); font-size: 21rpx; }

@media (max-height: 700px) {
  .crossword-board { width: 350rpx; height: 350rpx; }
  .page-subtitle { display: none; }
  .game-status { margin-top: 13rpx; }
  .clue-card { min-height: 88rpx; }
}
