<view class="page-shell idiom-page {{view === 'game' ? 'game-view' : 'catalog-view'}}">
  <block wx:if="{{view === 'catalog'}}">
    <view class="page-kicker">IDIOM · 词汇挑战</view>
    <view class="page-title">成语填字</view>
    <view class="page-subtitle">顺着释义把两个相交的四字成语补完整。</view>

    <view class="daily-card">
      <view class="daily-copy">
        <text>每日一题</text>
        <text>同一天、同难度获得相同题目</text>
      </view>
      <button class="daily-start" bindtap="openDaily">开始挑战</button>
      <view class="daily-options">
        <button
          class="{{dailyDifficulty === item.value ? 'active' : ''}}"
          wx:for="{{dailyOptions}}"
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="switchDailyDifficulty"
        >{{item.label}}</button>
      </view>
    </view>

    <view class="catalog-summary">
      <text>闯关星级</text>
      <view><text>{{totalStars}}</text> / {{maxStars}} 星</view>
      <view class="summary-track"><view style="width: {{maxStars ? totalStars / maxStars * 100 : 0}}%"></view></view>
    </view>

    <view class="loading-state" wx:if="{{loading}}">正在读取成语关卡…</view>
    <view class="category-list" wx:else>
      <view class="category-card" wx:for="{{categories}}" wx:key="id" wx:for-item="category">
        <button class="category-header" data-id="{{category.id}}" bindtap="toggleCategory">
          <view class="category-number">{{index + 1}}</view>
          <view class="category-copy">
            <text>{{category.name}}</text>
            <text>{{category.description}}</text>
          </view>
          <view class="category-score">{{category.completed_levels}} / {{category.total_levels}}</view>
          <view class="category-arrow {{category.expanded ? 'open' : ''}}">⌄</view>
        </button>
        <view class="level-grid" wx:if="{{category.expanded}}">
          <button
            class="level-button {{level.unlocked ? '' : 'locked'}} {{level.stars ? 'completed' : ''}}"
            wx:for="{{category.levels}}"
            wx:key="id"
            wx:for-item="level"
            data-id="{{level.id}}"
            data-unlocked="{{level.unlocked}}"
            bindtap="openLevel"
          >
            <text>{{level.order}}</text>
            <text>{{level.starText || (level.unlocked ? level.difficulty : '锁定')}}</text>
          </button>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <button class="back-button" bindtap="backToCatalog">返回关卡</button>
    <view class="page-kicker">IDIOM · {{puzzleMode === 'daily' ? '每日挑战' : '连续闯关'}}</view>
    <view class="game-heading">
      <view><view class="page-title">{{puzzle.title}}</view><view class="page-subtitle">点击格子，再从字库选择文字。</view></view>
      <view class="difficulty-chip">{{puzzle.difficulty}}</view>
    </view>

    <view class="game-status">
      <view><text>用时</text><text>{{elapsedText}}</text></view>
      <view><text>错误</text><text>{{mistakes}}</text></view>
      <view><text>提示</text><text>{{hintsUsed}} / {{maxHints}}</text></view>
    </view>

    <view class="crossword-wrap">
      <view class="crossword-board size-{{puzzle.size}}">
        <button
          class="idiom-cell {{item.type === 'fixed' ? 'fixed' : ''}} {{item.selected ? 'selected' : ''}} {{item.invalid ? 'invalid' : ''}} {{item.activeEntry ? 'active-entry' : ''}}"
          wx:for="{{cells}}"
          wx:key="index"
          style="grid-row: {{item.gridRow}}; grid-column: {{item.gridColumn}};"
          data-index="{{item.index}}"
          bindtap="selectCell"
        >{{item.value}}</button>
      </view>
    </view>

    <scroll-view class="clue-list" scroll-x enhanced show-scrollbar="{{false}}">
      <button
        class="clue-card {{activeEntryId === item.id ? 'active' : ''}}"
        wx:for="{{entries}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectEntry"
      >
        <text>{{item.direction === 'across' ? '横向' : '纵向'}}</text>
        <text>{{item.clue}}</text>
      </button>
    </scroll-view>

    <block wx:if="{{!completed}}">
      <view class="character-bank">
        <button wx:for="{{characterBank}}" wx:key="index" data-value="{{item}}" bindtap="inputCharacter">{{item}}</button>
      </view>

      <view class="game-action-panel">
        <view class="game-tools">
          <button bindtap="eraseCharacter">擦除</button>
          <button loading="{{hinting}}" disabled="{{hintsUsed >= maxHints}}" bindtap="requestHint">提示</button>
        </view>
        <button class="primary-button idiom-submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitPuzzle">提交答案</button>
      </view>
    </block>

    <view class="complete-panel surface" wx:if="{{completed && result}}">
      <view class="complete-title">成语挑战完成</view>
      <view class="complete-stars">{{result.stars === 3 ? '★★★' : result.stars === 2 ? '★★☆' : '★☆☆'}}</view>
      <view class="complete-detail">{{result.score}} 分 · {{elapsedText}}</view>
      <button class="primary-button" bindtap="goNext">{{puzzleMode === 'level' && result.next_level_id ? '进入下一关' : '返回关卡目录'}}</button>
    </view>
  </block>
</view>
