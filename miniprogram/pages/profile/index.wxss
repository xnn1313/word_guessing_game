.profile-page {
  padding-top: 22rpx;
}

.profile-hero {
  position: relative;
  display: flex;
  min-height: 196rpx;
  align-items: center;
  padding: 30rpx 32rpx 30rpx 38rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(22, 54, 58, 0.17);
}

.profile-hero::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 8rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-accent));
  content: "";
}

.profile-avatar {
  display: grid;
  width: 94rpx;
  height: 94rpx;
  flex: 0 0 auto;
  place-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 23rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: 39rpx;
  font-weight: 800;
}

.guest .profile-avatar {
  background: var(--color-night-soft);
  color: rgba(255, 255, 255, 0.72);
}

.profile-info {
  position: relative;
  z-index: 2;
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 22rpx;
}

.profile-name {
  overflow: hidden;
  font-size: 32rpx;
  font-weight: 780;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-state {
  display: flex;
  align-items: center;
  gap: 9rpx;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 21rpx;
}

.profile-state text {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: var(--color-mint);
}

.guest-note {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 21rpx;
}

.profile-mark {
  position: relative;
  z-index: 1;
  display: grid;
  width: 74rpx;
  height: 82rpx;
  flex: 0 0 auto;
  margin-left: 16rpx;
  place-items: center;
  border-radius: 18rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: 34rpx;
  font-weight: 820;
  transform: rotate(7deg);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.18);
}

.progress-panel {
  margin-top: 24rpx;
  padding: 27rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 24rpx rgba(22, 54, 58, 0.06);
}

.progress-label-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.progress-label-row > view:first-child {
  display: flex;
  flex-direction: column;
}

.progress-note {
  margin-top: 6rpx;
  color: var(--color-muted);
  font-size: var(--font-caption);
}

.progress-number {
  flex: 0 0 auto;
  color: var(--color-muted);
  font-size: var(--font-caption);
  font-weight: 620;
}

.progress-number text {
  color: var(--color-primary-dark);
  font-size: 30rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.progress-track {
  height: 13rpx;
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dfe8e5;
}

.progress-fill {
  min-width: 4rpx;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--color-primary), var(--color-mint));
}

.progress-legend {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 19rpx;
}

.profile-action {
  margin-top: 24rpx;
}
