.profile-page {
  padding-bottom: calc(174rpx + env(safe-area-inset-bottom));
}

.profile-hero {
  position: relative;
  display: flex;
  min-height: 210rpx;
  align-items: center;
  gap: 24rpx;
  overflow: hidden;
  padding: 30rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 30rpx;
  background: var(--color-yellow);
  box-shadow: var(--shadow-hard);
}

.profile-hero.guest { background: var(--color-primary-soft); }
.profile-avatar { display: grid; width: 104rpx; height: 104rpx; flex: 0 0 auto; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 28rpx; background: #ffffff; color: var(--color-primary); font-size: 42rpx; font-weight: 900; transform: rotate(-4deg); }
.profile-info { position: relative; z-index: 1; display: flex; min-width: 0; flex-direction: column; }
.profile-name { color: var(--color-ink); font-size: 38rpx; font-weight: 900; }
.profile-state { display: flex; align-items: center; gap: 9rpx; margin-top: 8rpx; color: rgba(21,27,58,0.72); font-size: 22rpx; }
.profile-state text { width: 13rpx; height: 13rpx; border: 3rpx solid var(--color-ink); border-radius: 50%; background: var(--color-aqua); }
.guest-note { margin-top: 7rpx; color: var(--color-muted); font-size: 22rpx; }
.profile-mark { position: absolute; right: -18rpx; bottom: -36rpx; color: rgba(21,27,58,0.08); font-size: 180rpx; font-weight: 900; transform: rotate(10deg); }

.progress-panel {
  margin-top: 34rpx;
  padding: 28rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 28rpx;
  background: #ffffff;
}

.progress-label-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.progress-label-row > view:first-child { display: flex; min-width: 0; flex-direction: column; }
.progress-note { margin-top: 6rpx; color: var(--color-muted); font-size: 21rpx; }
.progress-number { color: var(--color-muted); font-size: 22rpx; white-space: nowrap; }
.progress-number text { color: var(--color-primary); font-size: 32rpx; font-weight: 900; }
.progress-track { height: 18rpx; margin-top: 26rpx; overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 99rpx; background: var(--color-primary-soft); }
.progress-fill { min-width: 4rpx; height: 100%; background: var(--color-primary); }
.progress-legend { display: flex; justify-content: space-between; margin-top: 8rpx; color: var(--color-muted); font-size: 18rpx; }
.profile-action { margin-top: 34rpx; }

.profile-tips {
  display: grid;
  gap: 14rpx;
  margin-top: 26rpx;
}

.profile-tips > view {
  display: flex;
  min-height: 108rpx;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 22rpx;
  background: #ffffff;
}

.profile-tips > view:first-child { background: var(--color-aqua-soft); }
.profile-tips > view text:first-child { color: var(--color-ink); font-size: 25rpx; font-weight: 850; }
.profile-tips > view text:last-child { max-width: 360rpx; color: var(--color-muted); font-size: 20rpx; text-align: right; }
