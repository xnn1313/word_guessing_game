<view class="page-shell profile-page">
  <view class="profile-hero" wx:if="{{loggedIn}}">
    <view class="profile-avatar">{{avatarText}}</view>
    <view class="profile-info">
      <text class="profile-name">{{username}}</text>
      <view class="profile-state"><text></text>进度已自动保存</view>
    </view>
    <view class="profile-mark">词</view>
  </view>

  <view class="profile-hero guest" wx:else>
    <view class="profile-avatar">?</view>
    <view class="profile-info">
      <text class="profile-name">尚未登录</text>
      <text class="guest-note">登录后可查看完整记录</text>
    </view>
    <view class="profile-mark">词</view>
  </view>

  <view class="progress-panel" wx:if="{{loggedIn}}">
    <view class="progress-label-row">
      <view>
        <text class="section-title">分类闯关进度</text>
        <text class="progress-note">13 个分类 · 260 关</text>
      </view>
      <view class="progress-number"><text>{{totalStars}}</text> / {{maxStars}} 星</view>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{maxStars ? totalStars / maxStars * 100 : 0}}%"></view>
    </view>
    <view class="progress-legend"><text>刚刚开始</text><text>全部完成</text></view>
  </view>

  <button class="primary-button profile-action" wx:if="{{!loggedIn}}" bindtap="goLogin">登录 / 注册</button>
  <button class="danger-button profile-action" wx:else bindtap="logout">退出登录</button>

  <view class="profile-tips" wx:if="{{loggedIn}}">
    <view><text>云端存档</text><text>换设备登录也能继续挑战</text></view>
    <view><text>训练记录</text><text>每款游戏的进度会分别保存</text></view>
  </view>

  <view class="app-tabbar">
    <view class="app-tab-item" bindtap="openHub" hover-class="nav-pressed"><view class="nav-icon nav-games"></view><text>游戏</text></view>
    <view class="app-tab-item" bindtap="openRecords" hover-class="nav-pressed"><view class="nav-icon nav-records"></view><text>记录</text></view>
    <view class="app-tab-item active"><view class="nav-icon nav-profile"></view><text>我的</text></view>
  </view>
</view>
