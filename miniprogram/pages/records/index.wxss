.records-page {
  padding-bottom: calc(174rpx + env(safe-area-inset-bottom));
}

.records-summary {
  display: grid;
  grid-template-columns: 1.35fr 0.8fr 0.8fr;
  margin-top: 30rpx;
  overflow: hidden;
  border: 3rpx solid var(--color-ink);
  border-radius: 28rpx;
  background: var(--color-primary);
  box-shadow: var(--shadow-hard);
  color: #ffffff;
}

.records-summary > view {
  display: flex;
  min-height: 142rpx;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  flex-direction: column;
  border-right: 2rpx solid rgba(255,255,255,0.2);
}

.records-summary > view:last-child { border-right: none; }
.summary-main { align-items: flex-start !important; }
.summary-main > text { color: #ffffff; font-size: 20rpx; }
.summary-main > view { margin-top: 5rpx; font-size: 24rpx; font-weight: 750; }
.summary-main > view text { color: var(--color-yellow); font-size: 40rpx; font-weight: 900; }
.summary-stat text:first-child { color: var(--color-yellow); font-size: 34rpx; font-weight: 900; }
.summary-stat text:last-child { color: #ffffff; font-size: 18rpx; }

.records-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 42rpx 0 18rpx;
}

.records-heading > text:last-child { color: var(--color-muted); font-size: 21rpx; }

.record-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.record-card {
  position: relative;
  display: flex;
  min-height: 235rpx;
  padding: 20rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 5rpx 5rpx 0 var(--color-ink);
  text-align: left;
  flex-direction: column;
}

.record-mark {
  display: grid;
  width: 58rpx;
  height: 58rpx;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 14rpx;
  color: var(--color-ink);
  font-size: 25rpx;
  font-weight: 900;
}

.record-mark.word { background: var(--color-yellow); }
.record-mark.sudoku { background: var(--color-aqua); }
.record-mark.idiom { background: var(--color-coral); }
.record-mark.memory { background: var(--color-violet); }
.record-mark.word_search { background: var(--color-primary-soft); }
.record-copy { min-width: 0; flex: 1; margin-top: 15rpx; }
.record-title-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 8rpx; flex-direction: column; }
.record-title-row text:first-child { color: var(--color-ink); font-size: 26rpx; font-weight: 900; }
.record-title-row text:last-child { color: var(--color-primary-dark); font-size: 19rpx; font-weight: 800; }
.record-track { height: 9rpx; margin-top: 13rpx; overflow: hidden; border: 2rpx solid var(--color-ink); border-radius: 99rpx; background: var(--color-primary-soft); }
.record-track > view { min-width: 4rpx; height: 100%; background: var(--color-primary); }
.record-meta { display: flex; margin-top: 12rpx; color: var(--color-muted); font-size: 18rpx; line-height: 1.35; flex-direction: column; }
.record-arrow { position: absolute; right: 18rpx; top: 22rpx; width: 16rpx; height: 16rpx; border-top: 3rpx solid var(--color-ink); border-right: 3rpx solid var(--color-ink); transform: rotate(45deg); }
