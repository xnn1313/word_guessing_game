.auth-page {
  display: flex;
  min-height: calc(100vh - 40rpx);
  justify-content: center;
  flex-direction: column;
}

.auth-intro {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 28rpx;
  background: var(--color-primary);
  box-shadow: var(--shadow-hard);
  color: #ffffff;
}

.auth-mark {
  display: grid;
  width: 94rpx;
  height: 94rpx;
  flex: 0 0 auto;
  place-items: center;
  border: 3rpx solid var(--color-ink);
  border-radius: 22rpx;
  background: var(--color-yellow);
  color: var(--color-ink);
  font-size: 42rpx;
  font-weight: 900;
  transform: rotate(-4deg);
}

.auth-title { font-size: 34rpx; font-weight: 900; }
.auth-subtitle { margin-top: 7rpx; color: #ffffff; font-size: 22rpx; line-height: 1.5; }

.auth-panel {
  margin-top: 34rpx;
  padding: 28rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 28rpx;
  background: #ffffff;
}

.auth-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 6rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 19rpx;
  background: var(--color-primary-soft);
}

.auth-tab { display: grid; min-height: 88rpx; place-items: center; border-radius: 13rpx; color: var(--color-muted); font-weight: 850; line-height: 1.2; text-align: center; }
.auth-tab.active { background: var(--color-yellow); color: var(--color-ink); box-shadow: 4rpx 4rpx 0 var(--color-ink); }
.field { margin-top: 26rpx; }
.field-label { display: block; margin-bottom: 10rpx; color: var(--color-ink); font-size: 23rpx; font-weight: 850; }
.submit-button { margin-top: 30rpx; }

.auth-footnote {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 28rpx;
  color: var(--color-muted);
  font-size: 21rpx;
}

.auth-footnote text { width: 12rpx; height: 12rpx; border: 3rpx solid var(--color-ink); border-radius: 50%; background: var(--color-aqua); }
