.auth-page {
  padding-top: 24rpx;
}

.auth-intro {
  position: relative;
  display: flex;
  min-height: 224rpx;
  align-items: center;
  padding: 34rpx 30rpx 34rpx 38rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(22, 54, 58, 0.17);
}

.auth-intro::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 8rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-accent));
  content: "";
}

.auth-mark {
  display: grid;
  width: 92rpx;
  height: 100rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 21rpx;
  background: var(--color-accent);
  color: var(--color-ink);
  font-size: 43rpx;
  font-weight: 820;
  transform: rotate(-5deg);
  box-shadow: 0 9rpx 18rpx rgba(0, 0, 0, 0.18);
}

.auth-intro > view:last-child {
  min-width: 0;
  margin-left: 26rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.auth-subtitle {
  margin-top: 11rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  line-height: 1.55;
}

.auth-panel {
  margin-top: 24rpx;
  padding: 26rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 24rpx rgba(22, 54, 58, 0.06);
}

.auth-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  margin-bottom: 28rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: #e8efec;
}

.auth-tab {
  min-height: 76rpx;
  border-radius: 14rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 76rpx;
}

.auth-tab.active {
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-weight: 760;
  box-shadow: 0 4rpx 12rpx rgba(22, 54, 58, 0.08);
}

.field + .field {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: 700;
}

.submit-button {
  margin-top: 30rpx;
}

.auth-footnote {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 26rpx;
  color: var(--color-muted);
  font-size: var(--font-caption);
}

.auth-footnote text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-mint);
}
