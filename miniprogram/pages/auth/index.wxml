<view class="page-shell auth-page">
  <view class="auth-intro">
    <view class="auth-mark">词</view>
    <view>
      <view class="auth-title">保存你的进度</view>
      <view class="auth-subtitle">登录后使用云端进度；游客记录会保留在本机，暂不自动合并。</view>
    </view>
  </view>

  <view class="auth-panel">
    <view class="auth-tabs">
      <button class="auth-tab {{mode === 'login' ? 'active' : ''}}" data-mode="login" bindtap="switchMode">登录</button>
      <button class="auth-tab {{mode === 'register' ? 'active' : ''}}" data-mode="register" bindtap="switchMode">注册</button>
    </view>

    <view class="field">
      <text class="field-label">用户名</text>
      <input class="text-input" value="{{username}}" maxlength="24" placeholder="输入 2–24 个字符" bindinput="onUsernameInput" />
    </view>
    <view class="field">
      <text class="field-label">密码</text>
      <input class="text-input" value="{{password}}" password maxlength="128" placeholder="至少 6 个字符" bindinput="onPasswordInput" confirm-type="done" bindconfirm="submit" />
    </view>

    <button class="primary-button submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">
      {{mode === 'login' ? '登录并恢复存档' : '注册并开始游戏'}}
    </button>
  </view>

  <view class="auth-footnote"><text></text>账号用于同步登录后的游戏数据</view>
</view>
