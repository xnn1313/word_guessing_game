<view class="page-shell level-page" wx:if="{{!loading && level}}">
  <view class="level-heading">
    <view class="level-icon">{{level.category_emoji}}</view>
    <view class="level-copy">
      <text class="level-category">{{level.category_name}} · 第 {{level.order}} 关</text>
      <text class="level-name">{{level.name}}</text>
    </view>
    <view class="difficulty-badge difficulty-{{level.difficulty}}">{{level.difficulty_label}}</view>
  </view>

  <view class="level-summary">
    <view><text>本关已猜</text><text class="summary-number">{{attempts}}</text><text class="summary-unit">次</text></view>
    <view class="summary-rule"></view>
    <view><text>累计获得</text><text class="summary-number accent">{{totalStars}}</text><text class="summary-unit">星</text></view>
    <view class="summary-hint"><text>完成越快</text><text>星级越高</text></view>
  </view>

  <view class="complete-panel" wx:if="{{completed}}">
    <view class="complete-emblem">✓</view>
    <text class="complete-title">闯关成功</text>
    <text class="complete-answer">{{resultText}}</text>
    <text class="complete-stars">{{earnedStars === 3 ? '★★★' : earnedStars === 2 ? '★★☆' : '★☆☆'}}</text>
    <button class="primary-button" bindtap="goNext">{{nextLevel ? '进入下一关' : '返回选关'}}</button>
    <button class="retry-button" bindtap="retry">再挑战一次</button>
  </view>

  <block wx:else>
    <view class="history-panel">
      <view class="history-title-row">
        <text class="section-title">我的猜测</text>
        <text>最新在前</text>
      </view>
      <scroll-view class="history-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <guess-history items="{{history}}" empty-text="输入一个相关词，开始挑战" />
      </scroll-view>
    </view>

    <view class="result-note" wx:if="{{resultText}}">{{resultText}}</view>

    <view class="guess-dock">
      <view class="guess-row">
        <input class="text-input" value="{{guess}}" maxlength="20" placeholder="输入你的猜测" confirm-type="send" bindinput="onGuessInput" bindconfirm="submitGuess" />
        <view class="guess-button {{submitting || !guess ? 'control-disabled' : ''}}" bindtap="submitGuess" hover-class="card-pressed">
          {{submitting ? '提交中' : '提交'}}
        </view>
      </view>
      <view class="level-actions">
        <button bindtap="revealAnswer">查看答案并重试</button>
        <button bindtap="retry">重新开始本关</button>
      </view>
    </view>
  </block>
</view>

<view class="loading-state" wx:else>正在准备关卡…</view>
