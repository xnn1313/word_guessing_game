.level-page { padding-bottom: calc(48rpx + env(safe-area-inset-bottom)); }
.level-heading { display: grid; grid-template-columns: 82rpx minmax(0, 1fr) auto; align-items: center; gap: 18rpx; padding: 20rpx; border: 3rpx solid var(--color-ink); border-radius: 24rpx; background: var(--color-yellow-soft); }
.level-icon { display: grid; width: 76rpx; height: 76rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-yellow); font-size: 38rpx; }
.level-copy { display: flex; min-width: 0; flex-direction: column; }
.level-category { color: var(--color-muted); font-size: 20rpx; }
.level-name { overflow: hidden; color: var(--color-ink); font-size: 30rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.difficulty-badge { min-width: 74rpx; padding: 10rpx 12rpx; border: 3rpx solid var(--color-ink); border-radius: 14rpx; background: #ffffff; color: var(--color-ink); font-size: 19rpx; font-weight: 850; text-align: center; }
.difficulty-badge.difficulty-easy { background: var(--color-aqua); }
.difficulty-badge.difficulty-medium { background: var(--color-yellow); }
.difficulty-badge.difficulty-hard { background: var(--color-coral); }

.level-summary { display: grid; grid-template-columns: 1fr 2rpx 1fr 1.1fr; align-items: center; gap: 20rpx; margin-top: 18rpx; padding: 19rpx 22rpx; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: var(--color-ink); color: #ffffff; }
.level-summary > view:not(.summary-rule):not(.summary-hint) { display: flex; align-items: baseline; gap: 6rpx; color: #c8cde0; font-size: 18rpx; }
.summary-number { color: var(--color-aqua); font-size: 31rpx; font-weight: 900; }
.summary-number.accent { color: var(--color-yellow); }
.summary-unit { color: #c8cde0; font-size: 18rpx; }
.summary-rule { width: 2rpx; height: 50rpx; background: rgba(255,255,255,0.2); }
.summary-hint { display: flex; align-items: flex-end; color: #c8cde0; font-size: 17rpx; flex-direction: column; }
.history-panel { margin-top: 18rpx; overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 24rpx; background: #ffffff; }
.history-title-row { display: flex; min-height: 72rpx; align-items: center; justify-content: space-between; padding: 12rpx 20rpx; border-bottom: 3rpx solid var(--color-ink); }
.history-title-row > text:last-child { color: var(--color-muted); font-size: 19rpx; }
.history-scroll { height: 500rpx; padding: 10rpx 18rpx; }
.result-note { margin-top: 14rpx; padding: 15rpx 20rpx; border: 3rpx solid var(--color-danger); border-radius: 16rpx; background: var(--color-coral-soft); color: var(--color-danger); font-size: 22rpx; text-align: center; }
.guess-dock { margin-top: 18rpx; padding: 17rpx; border: 3rpx solid var(--color-ink); border-radius: 22rpx; background: #ffffff; box-shadow: 5rpx 5rpx 0 var(--color-ink); }
.guess-row { display: grid; grid-template-columns: minmax(0, 1fr) 148rpx; gap: 12rpx; }
.guess-button { display: grid; min-height: var(--control-height); place-items: center; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-yellow); color: var(--color-ink); font-weight: 900; }
.level-actions { display: flex; justify-content: space-between; gap: 18rpx; margin-top: 13rpx; }
.level-actions button { display: inline-flex; min-height: 88rpx; align-items: center; justify-content: center; color: var(--color-primary-dark); font-size: 20rpx; font-weight: 750; text-align: center; }
.level-actions button:last-child { color: var(--color-danger); }
.complete-panel { display: flex; align-items: center; margin-top: 36rpx; padding: 42rpx 30rpx; border: 3rpx solid var(--color-ink); border-radius: 28rpx; background: var(--color-aqua-soft); box-shadow: var(--shadow-hard); flex-direction: column; text-align: center; }
.complete-emblem { display: grid; width: 94rpx; height: 94rpx; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 24rpx; background: var(--color-aqua); color: var(--color-ink); font-size: 50rpx; font-weight: 900; transform: rotate(-5deg); }
.complete-title { margin-top: 20rpx; color: var(--color-ink); font-size: 38rpx; font-weight: 900; }
.complete-answer { margin-top: 6rpx; color: var(--color-muted); font-size: 24rpx; }
.complete-stars { margin: 16rpx 0 26rpx; color: var(--color-warning); font-size: 43rpx; letter-spacing: 6rpx; }
.retry-button { display: grid; min-height: 88rpx; margin-top: 16rpx; place-items: center; color: var(--color-primary-dark); font-size: 22rpx; font-weight: 800; text-align: center; }
@media (max-height: 700px) { .history-scroll { height: 400rpx; } }
