.level-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 20rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.level-heading {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
}

.level-icon {
  display: grid;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 18rpx;
  background: #e3f5ef;
  font-size: 34rpx;
}

.level-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 16rpx;
}

.level-category {
  color: #768681;
  font-size: 20rpx;
}

.level-name {
  margin-top: 4rpx;
  color: #203633;
  font-size: 30rpx;
  font-weight: 790;
}

.difficulty-badge {
  margin-left: 12rpx;
  padding: 8rpx 13rpx;
  border-radius: 12rpx;
  background: #def4eb;
  color: #18765e;
  font-size: 18rpx;
  font-weight: 750;
}

.difficulty-badge.difficulty-3 { background: #fff0d1; color: #9d681d; }
.difficulty-badge.difficulty-4 { background: #ffeadf; color: #aa5e36; }
.difficulty-badge.difficulty-5 { background: #ffe3e5; color: #ad484e; }

.level-summary {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 106rpx;
  margin-top: 18rpx;
  padding: 16rpx 22rpx;
  border-radius: 22rpx;
  background: #17343b;
  color: #ffffff;
}

.level-summary > view {
  display: flex;
  align-items: baseline;
  color: #9fb8b3;
  font-size: 18rpx;
}

.level-summary .summary-number {
  margin-left: 10rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 830;
}

.level-summary .summary-number.accent {
  color: #ffc857;
}

.summary-unit {
  margin-left: 4rpx;
  color: #b4c9c5;
  font-size: 18rpx;
}

.summary-rule {
  width: 2rpx;
  height: 48rpx;
  margin: 0 18rpx;
  background: rgba(255, 255, 255, 0.14);
}

.summary-hint {
  margin-left: auto;
  color: #8fa9a4;
  font-size: 17rpx;
  line-height: 1.5;
  text-align: right;
}

.summary-hint text {
  display: block;
}

.history-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 14rpx;
  padding: 19rpx 22rpx 8rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
}

.history-title-row {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
}

.history-title-row > text:last-child {
  color: #8d9a96;
  font-size: 19rpx;
}

.history-scroll {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 9rpx;
}

.result-note {
  flex: 0 0 auto;
  margin-top: 11rpx;
  padding: 15rpx 20rpx;
  border-radius: 15rpx;
  background: #fff0d8;
  color: #96601f;
  font-size: 21rpx;
  text-align: center;
}

.guess-dock {
  flex: 0 0 auto;
  padding-top: 13rpx;
  background: #f3f7f5;
}

.guess-row {
  display: flex;
  gap: 11rpx;
}

.guess-row .text-input {
  min-width: 0;
  flex: 1;
  background: #ffffff;
}

.guess-button {
  width: 112rpx;
  height: 86rpx;
  border-radius: 20rpx;
  background: #12a37f;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 770;
  line-height: 86rpx;
  box-shadow: 0 8rpx 18rpx rgba(18, 163, 127, 0.18);
}

.guess-button[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

.level-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 0 4rpx;
}

.level-actions button,
.retry-button {
  color: #277d69;
  font-size: 20rpx;
  line-height: 1.5;
}

.complete-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  text-align: center;
}

.complete-emblem {
  display: grid;
  width: 104rpx;
  height: 104rpx;
  place-items: center;
  border-radius: 50%;
  background: #dff6ed;
  color: #0b8666;
  font-size: 48rpx;
  font-weight: 850;
}

.complete-title {
  margin-top: 24rpx;
  color: #173d36;
  font-size: 38rpx;
  font-weight: 820;
}

.complete-answer {
  margin-top: 10rpx;
  color: #6e7e79;
  font-size: 23rpx;
}

.complete-stars {
  margin: 22rpx 0 32rpx;
  color: #e3a22d;
  font-size: 54rpx;
  letter-spacing: 7rpx;
}

.complete-panel .primary-button {
  width: 100%;
}

.retry-button {
  margin-top: 20rpx;
}

@media (max-height: 650px) {
  .level-summary {
    min-height: 92rpx;
    margin-top: 13rpx;
    padding-top: 12rpx;
    padding-bottom: 12rpx;
  }
}

/* Visual refresh */
.level-page {
  background: var(--color-bg);
}

.level-page .level-icon {
  border: 3rpx solid var(--color-ink);
  border-radius: 16rpx;
  background: var(--color-accent);
  box-shadow: 3rpx 3rpx 0 rgba(41, 45, 58, 0.15);
}

.level-page .level-category {
  color: var(--color-muted);
  font-weight: 650;
}

.level-page .level-name {
  color: var(--color-text);
  font-weight: 840;
}

.level-page .difficulty-badge {
  border: 2rpx solid var(--color-ink);
  background: #dcf7ef;
  color: #176f5a;
  box-shadow: 2rpx 2rpx 0 rgba(41, 45, 58, 0.12);
}

.level-page .difficulty-badge.difficulty-3 { background: #fff0be; color: #82590e; }
.level-page .difficulty-badge.difficulty-4 { background: #ffe0c9; color: #934b24; }
.level-page .difficulty-badge.difficulty-5 { background: #ffd8dc; color: #9c3d46; }

.level-page .level-summary {
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  background: var(--color-night);
  box-shadow: 6rpx 6rpx 0 var(--color-primary);
}

.level-page .level-summary > view,
.level-page .summary-unit,
.level-page .summary-hint {
  color: #bdc1d3;
}

.level-page .level-summary .summary-number.accent {
  color: var(--color-accent);
}

.level-page .history-panel {
  margin-top: 20rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  background: var(--color-surface);
  box-shadow: 5rpx 5rpx 0 rgba(41, 45, 58, 0.1);
}

.level-page .history-title-row > text:last-child {
  color: var(--color-muted);
}

.level-page .result-note {
  border: 2rpx solid #bd7d18;
  background: #fff0bd;
  color: #83560e;
  font-weight: 680;
}

.level-page .guess-dock {
  padding-top: 17rpx;
  background: var(--color-bg);
}

.level-page .guess-button {
  border: 3rpx solid var(--color-ink);
  border-radius: 18rpx;
  background: var(--color-primary);
  box-shadow: 5rpx 5rpx 0 var(--color-ink);
}

.level-page .guess-button:active {
  box-shadow: 2rpx 2rpx 0 var(--color-ink);
}

.level-page .level-actions button,
.level-page .retry-button {
  color: var(--color-primary-dark);
  font-weight: 680;
}

.level-page .complete-emblem {
  border: 3rpx solid var(--color-ink);
  background: var(--color-mint);
  color: var(--color-ink);
  box-shadow: 7rpx 7rpx 0 var(--color-ink);
}

.level-page .complete-title {
  color: var(--color-text);
  font-size: 42rpx;
  font-weight: 880;
}

.level-page .complete-answer {
  color: var(--color-muted);
}

.level-page .complete-stars {
  color: #d98e0b;
  text-shadow: 3rpx 3rpx 0 #fff0b8;
}

/* Unified level controls */
.level-page .level-category,
.level-page .difficulty-badge {
  font-size: var(--font-caption);
}

.level-page .level-name {
  font-size: 30rpx;
}

.level-page .history-title-row > text:last-child {
  font-size: var(--font-caption);
}

.level-page .guess-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 14rpx;
}

.level-page .guess-row .text-input {
  width: 100%;
  min-width: 0;
  height: var(--control-height);
  font-size: 26rpx;
}

.level-page .guess-button {
  display: grid;
  width: 150rpx;
  min-width: 150rpx;
  max-width: 150rpx;
  height: var(--control-height);
  place-items: center;
  font-size: var(--font-control);
  line-height: 1;
}

.level-page .level-actions button,
.level-page .retry-button {
  font-size: 22rpx;
}
