.level-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 20rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
  background: var(--color-bg);
}

.level-heading {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
}

.level-icon {
  display: grid;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 18rpx;
  background: #ffe3a0;
  font-size: 34rpx;
}

.level-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 16rpx;
}

.level-category {
  color: var(--color-muted);
  font-size: var(--font-caption);
  font-weight: 620;
}

.level-name {
  margin-top: 3rpx;
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 790;
}

.difficulty-badge {
  margin-left: 12rpx;
  padding: 8rpx 13rpx;
  border: 2rpx solid #a7d8cb;
  border-radius: 12rpx;
  background: #e1f5ef;
  color: var(--color-primary-dark);
  font-size: var(--font-caption);
  font-weight: 720;
}

.difficulty-badge.difficulty-3 { border-color: #ebce8e; background: #fff3d0; color: #845a14; }
.difficulty-badge.difficulty-4 { border-color: #e8b99b; background: #ffeadc; color: #914d28; }
.difficulty-badge.difficulty-5 { border-color: #e5afb3; background: #ffe4e6; color: #983f46; }

.level-summary {
  position: relative;
  display: grid;
  min-height: 108rpx;
  flex: 0 0 auto;
  grid-template-columns: minmax(0, 1fr) 2rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 16rpx 24rpx 16rpx 30rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 11rpx 25rpx rgba(22, 54, 58, 0.15);
}

.level-summary::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: var(--color-primary);
  content: "";
}

.level-summary > view {
  display: flex;
  min-width: 0;
  align-items: baseline;
  color: rgba(255, 255, 255, 0.58);
  font-size: var(--font-caption);
}

.level-summary .summary-number {
  margin-left: 9rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.level-summary .summary-number.accent {
  color: var(--color-accent);
}

.summary-unit {
  margin-left: 4rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: var(--font-caption);
}

.summary-rule {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.14);
}

.summary-hint {
  display: none !important;
}

.history-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 18rpx;
  padding: 19rpx 22rpx 8rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 22rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 22rpx rgba(22, 54, 58, 0.06);
}

.history-title-row {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
}

.history-title-row > text:last-child {
  color: var(--color-muted);
  font-size: var(--font-caption);
}

.history-scroll {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 9rpx;
}

.result-note {
  flex: 0 0 auto;
  margin-top: 11rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid #e5bd7d;
  border-radius: 15rpx;
  background: #fff5df;
  color: #8b5b16;
  font-size: 21rpx;
  font-weight: 650;
  text-align: center;
}

.guess-dock {
  flex: 0 0 auto;
  padding-top: 15rpx;
  background: var(--color-bg);
}

.guess-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 142rpx;
  gap: 14rpx;
}

.guess-row .text-input {
  width: 100%;
  min-width: 0;
}

.guess-button {
  display: grid;
  width: 142rpx;
  height: var(--control-height);
  place-items: center;
  border-radius: 18rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: var(--font-control);
  font-weight: 760;
  box-shadow: 0 9rpx 20rpx rgba(15, 143, 130, 0.2);
}

.level-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 6rpx;
}

.level-actions button,
.retry-button {
  min-height: 76rpx;
  color: var(--color-primary-dark);
  font-size: 21rpx;
  font-weight: 650;
  line-height: 76rpx;
}

.complete-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
}

.complete-emblem {
  display: grid;
  width: 104rpx;
  height: 104rpx;
  place-items: center;
  border-radius: 50%;
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
  font-size: 48rpx;
  font-weight: 850;
  box-shadow: 0 12rpx 26rpx rgba(15, 143, 130, 0.16);
}

.complete-title {
  margin-top: 24rpx;
  color: var(--color-text);
  font-size: 40rpx;
  font-weight: 820;
}

.complete-answer {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 23rpx;
}

.complete-stars {
  margin: 22rpx 0 30rpx;
  color: #bc7f18;
  font-size: 50rpx;
  letter-spacing: 7rpx;
}

.complete-panel .primary-button {
  width: 100%;
}

.retry-button {
  margin-top: 10rpx;
}

@media (max-height: 650px) {
  .level-summary {
    min-height: 94rpx;
    margin-top: 13rpx;
    padding-top: 11rpx;
    padding-bottom: 11rpx;
  }
}
