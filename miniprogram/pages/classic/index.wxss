.game-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 22rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.game-topbar {
  display: flex;
  flex: 0 0 auto;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.game-hint {
  margin-top: 7rpx;
  color: #7e8d89;
  font-size: 22rpx;
}

.live-state {
  display: flex;
  align-items: center;
  gap: 9rpx;
  margin-top: 8rpx;
  color: #63736f;
  font-size: 20rpx;
}

.live-state text {
  width: 11rpx;
  height: 11rpx;
  border-radius: 50%;
  background: #12a37f;
  box-shadow: 0 0 0 6rpx rgba(18, 163, 127, 0.11);
}

.round-summary {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 126rpx;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: #17343b;
  color: #ffffff;
}

.summary-main {
  display: flex;
  align-items: baseline;
  min-width: 158rpx;
}

.summary-number {
  color: #ffc857;
  font-size: 54rpx;
  font-weight: 850;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.summary-label {
  margin-left: 8rpx;
  color: #b6cbc7;
  font-size: 20rpx;
}

.summary-divider {
  width: 2rpx;
  height: 58rpx;
  margin: 0 22rpx;
  background: rgba(255, 255, 255, 0.14);
}

.summary-side {
  display: flex;
  min-width: 142rpx;
  flex-direction: column;
  color: #9fb8b3;
  font-size: 19rpx;
}

.summary-side view {
  margin-top: 5rpx;
  color: #d8e5e2;
  font-size: 20rpx;
}

.summary-side view text {
  margin-right: 4rpx;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
}

.summary-tip {
  margin-left: auto;
  color: #8fa9a4;
  font-size: 18rpx;
  line-height: 1.55;
  text-align: right;
}

.summary-tip text {
  display: block;
}

.history-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 16rpx;
  padding: 20rpx 22rpx 8rpx;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
}

.history-toolbar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.sort-control {
  display: flex;
  gap: 4rpx;
  padding: 4rpx;
  border-radius: 16rpx;
  background: #edf3f1;
}

.sort-button {
  min-width: 82rpx;
  height: 46rpx;
  border-radius: 13rpx;
  color: #788783;
  font-size: 20rpx;
  line-height: 46rpx;
}

.sort-button.active {
  background: #ffffff;
  color: #08735c;
  font-weight: 760;
  box-shadow: 0 3rpx 10rpx rgba(29, 70, 61, 0.08);
}

.history-scroll {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 10rpx;
}

.result-banner {
  flex: 0 0 auto;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fff1db;
  color: #9a611f;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.result-banner.success {
  background: #dcf5eb;
  color: #08735c;
}

.guess-dock {
  flex: 0 0 auto;
  padding-top: 14rpx;
  background: #f3f7f5;
}

.guess-row {
  display: flex;
  gap: 12rpx;
}

.guess-input {
  min-width: 0;
  flex: 1;
  background: #ffffff;
}

.submit-guess {
  width: 112rpx;
  height: 86rpx;
  flex: 0 0 auto;
  border-radius: 20rpx;
  background: #12a37f;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 780;
  line-height: 86rpx;
  box-shadow: 0 8rpx 18rpx rgba(18, 163, 127, 0.18);
}

.submit-guess[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

.game-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 13rpx;
  padding: 0 4rpx;
}

.action-text {
  color: #277d69;
  font-size: 20rpx;
  line-height: 1.5;
}

.action-text.danger {
  color: #b86064;
}

@media (max-height: 650px) {
  .round-summary {
    min-height: 104rpx;
    margin-top: 14rpx;
    padding-top: 14rpx;
    padding-bottom: 14rpx;
  }

  .summary-number {
    font-size: 46rpx;
  }

  .history-panel {
    margin-top: 12rpx;
  }
}

/* Visual refresh */
.game-page {
  background: var(--color-bg);
}

.game-page .game-hint {
  color: var(--color-muted);
}

.game-page .live-state {
  padding: 8rpx 13rpx;
  border: 2rpx solid var(--color-ink);
  border-radius: 999rpx;
  background: var(--color-surface);
  color: var(--color-text);
  box-shadow: 3rpx 3rpx 0 rgba(41, 45, 58, 0.12);
}

.game-page .live-state text {
  background: var(--color-mint);
  box-shadow: 0 0 0 5rpx rgba(53, 199, 165, 0.14);
}

.game-page .round-summary {
  border: 3rpx solid var(--color-ink);
  border-radius: 22rpx;
  background: var(--color-night);
  box-shadow: 7rpx 7rpx 0 var(--color-primary);
}

.game-page .summary-number {
  color: var(--color-accent);
}

.game-page .summary-label,
.game-page .summary-side,
.game-page .summary-tip {
  color: #bdc1d3;
}

.game-page .summary-side view {
  color: #e7e9f2;
}

.game-page .history-panel {
  margin-top: 22rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 20rpx;
  background: var(--color-surface);
  box-shadow: 5rpx 5rpx 0 rgba(41, 45, 58, 0.1);
}

.game-page .sort-control {
  border: 2rpx solid #cfc8bb;
  background: #ece6dc;
}

.game-page .sort-button {
  color: var(--color-muted);
}

.game-page .sort-button.active {
  background: var(--color-primary);
  color: #ffffff;
  box-shadow: 3rpx 3rpx 0 rgba(41, 45, 58, 0.18);
}

.game-page .result-banner {
  border: 2rpx solid #b87413;
  background: #fff1c5;
  color: #82540f;
  font-weight: 700;
}

.game-page .result-banner.success {
  border-color: #267a66;
  background: #dff7ef;
  color: #176b57;
}

.game-page .guess-dock {
  padding-top: 18rpx;
  background: var(--color-bg);
}

.game-page .submit-guess {
  border: 3rpx solid var(--color-ink);
  border-radius: 18rpx;
  background: var(--color-primary);
  box-shadow: 5rpx 5rpx 0 var(--color-ink);
}

.game-page .submit-guess:active {
  box-shadow: 2rpx 2rpx 0 var(--color-ink);
}

.game-page .action-text {
  color: var(--color-primary-dark);
  font-weight: 680;
}

.game-page .action-text.danger {
  color: var(--color-danger);
}

/* Compact phone layout fixes from simulator review */
.game-page .game-topbar > view:first-child {
  min-width: 0;
  flex: 1;
}

.game-page .live-state {
  flex: 0 0 auto;
  white-space: nowrap;
}

.game-page .round-summary {
  min-height: 120rpx;
  padding: 18rpx 22rpx;
}

.game-page .summary-main,
.game-page .summary-side {
  min-width: 0;
  flex: 1;
}

.game-page .summary-label,
.game-page .summary-side,
.game-page .summary-side view {
  font-size: 21rpx;
}

.game-page .summary-tip {
  display: none;
}

.game-page .history-toolbar {
  align-items: stretch;
  flex-direction: column;
  gap: 14rpx;
}

.game-page .history-toolbar .section-title {
  flex: 0 0 auto;
  font-size: 29rpx;
  white-space: nowrap;
}

.game-page .sort-control {
  display: flex;
  width: 100%;
  min-width: 0;
}

.game-page .sort-button {
  display: grid;
  width: auto;
  min-width: 0;
  height: 52rpx;
  flex: 1;
  place-items: center;
  line-height: 1;
  text-align: center;
}

.game-page .history-scroll {
  margin-top: 12rpx;
}

.game-page .game-actions {
  margin-top: 16rpx;
}

.game-page .action-text {
  font-size: 21rpx;
}

/* Unified classic typography and input sizing */
.game-page .game-hint {
  font-size: var(--font-body);
}

.game-page .live-state {
  font-size: var(--font-caption);
}

.game-page .summary-number {
  font-size: 50rpx;
}

.game-page .summary-label,
.game-page .summary-side,
.game-page .summary-side view {
  font-size: 22rpx;
}

.game-page .summary-side view text {
  font-size: 30rpx;
}

.game-page .sort-button {
  font-size: 22rpx;
}

.game-page .guess-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 14rpx;
}

.game-page .guess-input {
  width: 100%;
  min-width: 0;
  height: var(--control-height);
  font-size: 26rpx;
}

.game-page .submit-guess {
  display: grid;
  width: 150rpx;
  min-width: 150rpx;
  max-width: 150rpx;
  height: var(--control-height);
  place-items: center;
  font-size: var(--font-control);
  line-height: 1;
}

.game-page .submit-guess.card-pressed {
  box-shadow: 2rpx 2rpx 0 var(--color-ink);
}

.game-page .action-text {
  font-size: 22rpx;
}
