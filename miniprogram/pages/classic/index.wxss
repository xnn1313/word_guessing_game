.game-page { padding-bottom: calc(46rpx + env(safe-area-inset-bottom)); }
.game-topbar { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.game-topbar > view:first-child { min-width: 0; flex: 1; }
.live-state { display: flex; min-height: 58rpx; align-items: center; gap: 8rpx; padding: 0 16rpx; border: 3rpx solid var(--color-ink); border-radius: 16rpx; background: var(--color-aqua-soft); color: var(--color-ink); font-size: 20rpx; font-weight: 800; white-space: nowrap; }
.live-state text { width: 12rpx; height: 12rpx; border: 2rpx solid var(--color-ink); border-radius: 50%; background: var(--color-aqua); }

.round-summary {
  display: grid;
  grid-template-columns: 1.1fr 2rpx 1fr 1fr;
  align-items: center;
  gap: 22rpx;
  margin-top: 28rpx;
  padding: 25rpx 28rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 26rpx;
  background: var(--color-ink);
  box-shadow: 7rpx 7rpx 0 var(--color-primary);
  color: #ffffff;
}

.summary-main { display: flex; align-items: baseline; gap: 9rpx; }
.summary-number { color: var(--color-yellow); font-size: 51rpx; font-weight: 900; font-variant-numeric: tabular-nums; }
.summary-label { color: #d8dced; font-size: 20rpx; }
.summary-divider { width: 2rpx; height: 68rpx; background: rgba(255,255,255,0.2); }
.summary-side { display: flex; flex-direction: column; }
.summary-side > text { color: #bfc5db; font-size: 18rpx; }
.summary-side > view { margin-top: 4rpx; font-size: 22rpx; }
.summary-side > view text { color: var(--color-aqua); font-size: 31rpx; font-weight: 900; }
.summary-tip { display: flex; align-items: flex-end; color: #bfc5db; font-size: 18rpx; text-align: right; flex-direction: column; }

.history-panel {
  margin-top: 28rpx;
  overflow: hidden;
  border: 3rpx solid var(--color-ink);
  border-radius: 26rpx;
  background: #ffffff;
}

.history-toolbar { display: flex; min-height: 84rpx; align-items: center; justify-content: space-between; gap: 18rpx; padding: 14rpx 18rpx 14rpx 24rpx; border-bottom: 3rpx solid var(--color-ink); }
.sort-control { display: grid; grid-template-columns: 1fr 1fr; padding: 4rpx; border: 2rpx solid var(--color-ink); border-radius: 14rpx; background: var(--color-primary-soft); }
.sort-button { display: grid; min-width: 104rpx; min-height: 88rpx; place-items: center; border-radius: 9rpx; color: var(--color-muted); font-size: 20rpx; font-weight: 750; }
.sort-button.active { background: var(--color-primary); color: #ffffff; }
.history-scroll { height: 470rpx; padding: 12rpx 18rpx; }
.result-banner { margin-top: 18rpx; padding: 18rpx 22rpx; border: 3rpx solid var(--color-danger); border-radius: 18rpx; background: var(--color-coral-soft); color: var(--color-danger); font-size: 23rpx; font-weight: 750; text-align: center; }
.result-banner.success { border-color: var(--color-ink); background: var(--color-aqua); color: var(--color-ink); }

.guess-dock { margin-top: 20rpx; padding: 18rpx; border: 3rpx solid var(--color-ink); border-radius: 24rpx; background: #ffffff; box-shadow: 6rpx 6rpx 0 var(--color-ink); }
.guess-row { display: grid; grid-template-columns: minmax(0, 1fr) 150rpx; gap: 12rpx; }
.submit-guess { display: grid; min-height: var(--control-height); place-items: center; border: 3rpx solid var(--color-ink); border-radius: 18rpx; background: var(--color-yellow); color: var(--color-ink); font-size: 25rpx; font-weight: 900; }
.game-actions { display: flex; justify-content: space-between; gap: 16rpx; margin-top: 16rpx; }
.action-text { display: inline-flex; min-height: 88rpx; align-items: center; justify-content: center; padding: 0 6rpx; color: var(--color-primary-dark); font-size: 21rpx; font-weight: 750; text-align: center; }
.action-text.danger { color: var(--color-danger); }

@media (max-height: 700px) { .history-scroll { height: 390rpx; } }
