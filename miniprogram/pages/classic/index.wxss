.game-page {
  display: flex;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  padding-top: 20rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
  background: var(--color-bg);
}

.game-topbar {
  display: flex;
  flex: 0 0 auto;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.game-topbar > view:first-child {
  min-width: 0;
  flex: 1;
}

.game-hint {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: var(--font-body);
}

.live-state {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 9rpx;
  margin-top: 7rpx;
  padding: 9rpx 14rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 999rpx;
  background: var(--color-surface);
  color: var(--color-text);
  font-size: var(--font-caption);
  white-space: nowrap;
}

.live-state text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-mint);
  box-shadow: 0 0 0 5rpx rgba(66, 191, 174, 0.13);
}

.round-summary {
  position: relative;
  display: grid;
  min-height: 118rpx;
  flex: 0 0 auto;
  grid-template-columns: minmax(0, 1fr) 2rpx minmax(0, 1fr);
  gap: 22rpx;
  align-items: center;
  margin-top: 20rpx;
  padding: 18rpx 26rpx 18rpx 30rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(22, 54, 58, 0.16);
}

.round-summary::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: var(--color-primary);
  content: "";
}

.summary-main {
  display: flex;
  min-width: 0;
  align-items: baseline;
}

.summary-number {
  color: var(--color-accent);
  font-size: 49rpx;
  font-weight: 820;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.summary-label {
  margin-left: 9rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: var(--font-label);
}

.summary-divider {
  width: 2rpx;
  height: 54rpx;
  background: rgba(255, 255, 255, 0.14);
}

.summary-side {
  display: flex;
  min-width: 0;
  flex-direction: column;
  color: rgba(255, 255, 255, 0.58);
  font-size: var(--font-caption);
}

.summary-side view {
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: var(--font-label);
}

.summary-side view text {
  margin-right: 5rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.summary-tip {
  display: none;
}

.history-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  margin-top: 18rpx;
  padding: 20rpx 22rpx 8rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 22rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 24rpx rgba(22, 54, 58, 0.06);
}

.history-toolbar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.sort-control {
  display: flex;
  min-width: 260rpx;
  gap: 4rpx;
  padding: 4rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 15rpx;
  background: #e9efec;
}

.sort-button {
  display: grid;
  min-width: 0;
  height: 54rpx;
  flex: 1;
  place-items: center;
  border-radius: 11rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  text-align: center;
}

.sort-button.active {
  background: var(--color-primary);
  color: #ffffff;
  font-weight: 740;
  box-shadow: 0 3rpx 8rpx rgba(15, 143, 130, 0.18);
}

.history-scroll {
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: 10rpx;
}

.result-banner {
  flex: 0 0 auto;
  margin-top: 12rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid #e5bd7d;
  border-radius: 15rpx;
  background: #fff5df;
  color: #8b5b16;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1.45;
  text-align: center;
}

.result-banner.success {
  border-color: #91cfc4;
  background: #e4f7f2;
  color: var(--color-primary-dark);
}

.guess-dock {
  flex: 0 0 auto;
  padding-top: 16rpx;
  background: var(--color-bg);
}

.guess-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 142rpx;
  gap: 14rpx;
}

.guess-input {
  width: 100%;
  min-width: 0;
}

.submit-guess {
  display: grid;
  width: 142rpx;
  height: var(--control-height);
  place-items: center;
  border-radius: 18rpx;
  background: var(--color-primary);
  color: #ffffff;
  font-size: var(--font-control);
  font-weight: 760;
  box-shadow: 0 9rpx 20rpx rgba(15, 143, 130, 0.2);
}

.game-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 6rpx;
}

.action-text {
  min-height: 76rpx;
  color: var(--color-primary-dark);
  font-size: 21rpx;
  font-weight: 650;
  line-height: 76rpx;
}

.action-text.danger {
  color: var(--color-danger);
}

@media (max-height: 650px) {
  .round-summary {
    min-height: 100rpx;
    margin-top: 14rpx;
    padding-top: 12rpx;
    padding-bottom: 12rpx;
  }

  .summary-number {
    font-size: 43rpx;
  }

  .history-panel {
    margin-top: 12rpx;
  }
}
