<view class="page-shell game-page">
  <view class="game-topbar">
    <view>
      <view class="page-kicker">CLASSIC · 无限模式</view>
      <view class="page-title">经典猜词</view>
      <view class="game-hint">沿着关联度寻找隐藏答案</view>
    </view>
    <view class="live-state"><text></text>本轮进行中</view>
  </view>

  <view class="round-summary">
    <view class="summary-main">
      <text class="summary-number">{{attempts}}</text>
      <text class="summary-label">次猜测</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-side">
      <text>累计猜中</text>
      <view><text>{{correctCount}}</text> 个词</view>
    </view>
    <view class="summary-tip"><text>相似度越高</text><text>离答案越近</text></view>
  </view>

  <view class="history-panel">
    <view class="history-toolbar">
      <text class="section-title">猜测记录</text>
      <view class="sort-control">
        <view class="sort-button {{sortMode === 'time' ? 'active' : ''}}" data-sort="time" bindtap="switchSort">最新</view>
        <view class="sort-button {{sortMode === 'similarity' ? 'active' : ''}}" data-sort="similarity" bindtap="switchSort">最接近</view>
      </view>
    </view>
    <scroll-view class="history-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <guess-history items="{{history}}" empty-text="输入一个相关词，开始靠近答案" />
    </scroll-view>
  </view>

  <view class="result-banner {{resultSuccess ? 'success' : ''}}" wx:if="{{resultText}}">{{resultText}}</view>

  <view class="guess-dock">
    <view class="guess-row">
      <input class="text-input guess-input" value="{{guess}}" maxlength="20" placeholder="输入任意中文词语" confirm-type="send" bindinput="onGuessInput" bindconfirm="submitGuess" />
      <view class="submit-guess {{submitting || !guess ? 'control-disabled' : ''}}" bindtap="submitGuess" hover-class="card-pressed">
        {{submitting ? '提交中' : '提交'}}
      </view>
    </view>
    <view class="game-actions">
      <button class="action-text" bindtap="revealAnswer">查看答案并换题</button>
      <button class="action-text danger" bindtap="resetGame">重置全部记录</button>
    </view>
  </view>
</view>
