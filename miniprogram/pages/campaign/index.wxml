<view class="page-shell campaign-page">
  <view class="campaign-header">
    <view>
      <view class="page-title">分类闯关</view>
      <view class="page-subtitle">每 4 关提升一档难度，完成当前关解锁下一关。</view>
    </view>
    <view class="star-total"><text>{{totalStars}}</text>/{{maxStars}} ★</view>
  </view>

  <view class="loading-state" wx:if="{{loading && !categories.length}}">正在读取关卡…</view>

  <view class="category-list" wx:else>
    <view class="category surface" wx:for="{{categories}}" wx:key="id" wx:for-item="category">
      <button class="category-header" data-id="{{category.id}}" bindtap="toggleCategory">
        <view class="category-emoji">{{category.emoji}}</view>
        <view class="category-copy">
          <text class="category-name">{{category.name}}</text>
          <text class="category-description">{{category.description}}</text>
        </view>
        <view class="category-right">
          <text class="category-stars">{{category.progressText}}</text>
          <text class="category-chevron {{category.expanded ? 'open' : ''}}">⌄</text>
        </view>
      </button>

      <view class="level-area" wx:if="{{category.expanded}}">
        <view class="difficulty-line">
          <text>难度递增</text>
          <view class="difficulty-dots"><view></view><view></view><view></view><view></view><view></view></view>
        </view>
        <view class="level-grid">
          <button
            class="level-button difficulty-{{level.difficulty}} {{level.unlocked ? '' : 'locked'}}"
            wx:for="{{category.levels}}"
            wx:key="id"
            wx:for-item="level"
            data-id="{{level.id}}"
            data-unlocked="{{level.unlocked}}"
            bindtap="openLevel"
          >
            <text class="level-number">{{level.order}}</text>
            <text class="level-label">{{level.difficulty_label}}</text>
            <text class="level-stars">{{level.unlocked ? level.starText : '锁定'}}</text>
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
