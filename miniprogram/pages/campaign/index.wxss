.campaign-page { padding-bottom: calc(52rpx + env(safe-area-inset-bottom)); }
.campaign-progress { margin-top: 28rpx; padding: 28rpx; border: 3rpx solid var(--color-ink); border-radius: 28rpx; background: var(--color-primary); box-shadow: var(--shadow-hard); color: #ffffff; }
.progress-copy { display: flex; align-items: flex-end; justify-content: space-between; gap: 18rpx; }
.progress-copy > view { font-size: 24rpx; font-weight: 750; }
.progress-copy > view text { color: var(--color-yellow); font-size: 43rpx; font-weight: 900; }
.progress-copy > text { color: #ffffff; font-size: 21rpx; }
.progress-track { height: 16rpx; margin-top: 22rpx; overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 99rpx; background: #ffffff; }
.progress-fill { min-width: 5rpx; height: 100%; background: var(--color-yellow); }
.category-list { display: flex; gap: 20rpx; margin-top: 32rpx; flex-direction: column; }
.category { overflow: hidden; border: 3rpx solid var(--color-ink); border-radius: 26rpx; background: #ffffff; box-shadow: 5rpx 5rpx 0 rgba(21,27,58,0.18); }
.category-header { display: flex; min-height: 146rpx; align-items: center; gap: 20rpx; padding: 20rpx; }
.category-header.expanded { background: var(--color-primary-soft); border-bottom: 3rpx solid var(--color-ink); }
.category-emoji { display: grid; width: 80rpx; height: 80rpx; flex: 0 0 auto; place-items: center; border: 3rpx solid var(--color-ink); border-radius: 19rpx; background: var(--color-yellow); font-size: 40rpx; }
.category:nth-child(4n + 2) .category-emoji { background: var(--color-aqua); }
.category:nth-child(4n + 3) .category-emoji { background: var(--color-coral); }
.category:nth-child(4n) .category-emoji { background: var(--color-violet); }
.category-copy { display: flex; min-width: 0; flex: 1; flex-direction: column; }
.category-name { color: var(--color-ink); font-size: 29rpx; font-weight: 900; }
.category-description { overflow: hidden; margin-top: 3rpx; color: var(--color-muted); font-size: 21rpx; text-overflow: ellipsis; white-space: nowrap; }
.category-track { width: 72%; height: 8rpx; margin-top: 11rpx; overflow: hidden; border-radius: 99rpx; background: var(--color-primary-soft); }
.category-track > view { min-width: 4rpx; height: 100%; background: var(--color-primary); }
.category-right { display: flex; flex: 0 0 auto; align-items: flex-end; flex-direction: column; }
.category-stars { color: var(--color-primary-dark); font-size: 21rpx; font-weight: 850; }
.category-chevron { display: grid; width: 48rpx; height: 48rpx; margin-top: 8rpx; place-items: center; border: 2rpx solid var(--color-ink); border-radius: 50%; font-size: 28rpx; transition: transform 180ms ease; }
.category-chevron.open { transform: rotate(180deg); }
.level-area { padding: 20rpx; background: var(--color-surface-soft); }
.difficulty-line { display: flex; align-items: center; justify-content: center; gap: 14rpx; margin-bottom: 16rpx; color: var(--color-muted); font-size: 19rpx; }
.difficulty-dots { display: flex; align-items: center; gap: 18rpx; }
.difficulty-dots view { width: 10rpx; height: 10rpx; border: 2rpx solid var(--color-ink); border-radius: 50%; background: var(--color-aqua); }
.difficulty-dots view:nth-child(2) { background: #9dd957; }
.difficulty-dots view:nth-child(3) { background: var(--color-yellow); }
.difficulty-dots view:nth-child(4) { background: #ffad4b; }
.difficulty-dots view:nth-child(5) { background: var(--color-coral); }
.level-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12rpx; }
.level-button { display: flex; min-height: 118rpx; align-items: center; justify-content: center; padding: 9rpx 4rpx; border: 3rpx solid var(--color-ink); border-radius: 17rpx; background: #ffffff; flex-direction: column; }
.level-number { color: var(--color-ink); font-size: 29rpx; font-weight: 900; }
.level-label { color: var(--color-muted); font-size: 17rpx; }
.level-stars { color: var(--color-warning); font-size: 18rpx; }
.level-button.locked { border-color: #c5cad9; background: #e8eaf1; color: var(--color-subtle); }
.level-button.locked text { color: var(--color-subtle); }
.level-button.difficulty-easy:not(.locked) { border-top: 8rpx solid var(--color-aqua); }
.level-button.difficulty-medium:not(.locked) { border-top: 8rpx solid var(--color-yellow); }
.level-button.difficulty-hard:not(.locked) { border-top: 8rpx solid var(--color-coral); }
