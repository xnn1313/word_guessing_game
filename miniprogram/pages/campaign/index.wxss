.campaign-page {
  padding-top: 22rpx;
}

.campaign-progress {
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #17343b;
  color: #ffffff;
}

.progress-copy {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.progress-copy view {
  color: #b4cbc6;
  font-size: 21rpx;
}

.progress-copy view text {
  color: #ffc857;
  font-size: 37rpx;
  font-weight: 840;
}

.progress-copy > text {
  color: #9fb8b3;
  font-size: 20rpx;
}

.progress-track {
  height: 12rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.12);
}

.progress-fill {
  min-width: 4rpx;
  height: 100%;
  border-radius: 12rpx;
  background: #ffc857;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 20rpx;
}

.category {
  overflow: hidden;
  border: 2rpx solid #dce7e3;
  border-radius: 22rpx;
  background: #ffffff;
}

.category-header {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 116rpx;
  padding: 18rpx 20rpx;
  text-align: left;
}

.category-header.expanded {
  background: #f8fbfa;
}

.category-emoji {
  display: grid;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 18rpx;
  background: #e5f5ef;
  font-size: 34rpx;
}

.category-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 17rpx;
}

.category-name {
  color: #203633;
  font-size: 28rpx;
  font-weight: 770;
}

.category-description {
  overflow: hidden;
  margin-top: 4rpx;
  color: #83918d;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-track {
  width: 150rpx;
  height: 6rpx;
  margin-top: 9rpx;
  overflow: hidden;
  border-radius: 6rpx;
  background: #e7eeeb;
}

.category-track view {
  min-width: 3rpx;
  height: 100%;
  border-radius: 6rpx;
  background: #12a37f;
}

.category-right {
  display: flex;
  flex: 0 0 auto;
  align-items: flex-end;
  flex-direction: column;
  margin-left: 12rpx;
}

.category-stars {
  color: #4f746b;
  font-size: 19rpx;
  font-weight: 700;
}

.category-chevron {
  margin-top: 4rpx;
  color: #85938f;
  font-size: 29rpx;
  transition: transform 0.2s ease;
}

.category-chevron.open {
  transform: rotate(180deg);
}

.level-area {
  padding: 0 18rpx 20rpx;
  border-top: 2rpx solid #e9efed;
  background: #ffffff;
}

.difficulty-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 16rpx 4rpx;
  color: #8b9894;
  font-size: 18rpx;
}

.difficulty-dots {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: space-between;
  max-width: 240rpx;
}

.difficulty-dots view {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #57ad85;
}

.difficulty-dots view:nth-child(2) { background: #94ad59; }
.difficulty-dots view:nth-child(3) { background: #d2a543; }
.difficulty-dots view:nth-child(4) { background: #d77a43; }
.difficulty-dots view:nth-child(5) { background: #d45b61; }

.level-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.level-button {
  min-height: 100rpx;
  padding: 10rpx 3rpx;
  border: 2rpx solid #d7e5df;
  border-top-width: 5rpx;
  border-radius: 16rpx;
  background: #fbfdfc;
  line-height: 1.15;
}

.level-button.difficulty-1 { border-top-color: #57ad85; }
.level-button.difficulty-2 { border-top-color: #94ad59; }
.level-button.difficulty-3 { border-top-color: #d2a543; }
.level-button.difficulty-4 { border-top-color: #d77a43; }
.level-button.difficulty-5 { border-top-color: #d45b61; }

.level-button.locked {
  border-color: #e2e8e6;
  background: #f2f5f4;
  color: #a1aaa7;
}

.level-number,
.level-label,
.level-stars {
  display: block;
}

.level-number {
  color: #283d3a;
  font-size: 26rpx;
  font-weight: 820;
}

.level-label {
  margin-top: 3rpx;
  color: #788884;
  font-size: 17rpx;
}

.level-stars {
  margin-top: 5rpx;
  color: #d79a2c;
  font-size: 15rpx;
  letter-spacing: -1rpx;
}

.locked .level-number,
.locked .level-label,
.locked .level-stars {
  color: #a1aaa7;
}

/* Visual refresh */
.campaign-page .campaign-progress {
  margin-top: 28rpx;
  border: 3rpx solid var(--color-ink);
  border-radius: 24rpx;
  background: var(--color-primary);
  box-shadow: 8rpx 8rpx 0 var(--color-ink);
}

.campaign-page .progress-copy view,
.campaign-page .progress-copy > text {
  color: #ded9ff;
}

.campaign-page .progress-copy view text {
  color: var(--color-accent);
}

.campaign-page .progress-track {
  height: 14rpx;
  border: 2rpx solid var(--color-ink);
  background: rgba(255, 255, 255, 0.22);
}

.campaign-page .progress-fill {
  background: var(--color-accent);
}

.campaign-page .category-list {
  gap: 16rpx;
  margin-top: 26rpx;
}

.campaign-page .category {
  border: 3rpx solid var(--color-ink);
  border-radius: 22rpx;
  background: var(--color-surface);
  box-shadow: 5rpx 5rpx 0 rgba(41, 45, 58, 0.12);
}

.campaign-page .category-header.expanded {
  background: var(--color-primary-soft);
}

.campaign-page .category-emoji {
  border: 2rpx solid var(--color-ink);
  background: var(--color-accent);
}

.campaign-page .category-name {
  color: var(--color-text);
  font-weight: 820;
}

.campaign-page .category-description,
.campaign-page .difficulty-line {
  color: var(--color-muted);
}

.campaign-page .category-track {
  background: #ded8ce;
}

.campaign-page .category-track view {
  background: var(--color-primary);
}

.campaign-page .category-stars {
  color: var(--color-primary-dark);
}

.campaign-page .category-chevron {
  color: var(--color-primary-dark);
}

.campaign-page .level-area {
  border-top: 3rpx solid var(--color-ink);
  background: #fffdf8;
}

.campaign-page .level-button {
  border: 2rpx solid var(--color-ink);
  border-top-width: 7rpx;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 3rpx 3rpx 0 rgba(41, 45, 58, 0.12);
}

.campaign-page .level-button:active {
  box-shadow: 1rpx 1rpx 0 rgba(41, 45, 58, 0.12);
}

.campaign-page .level-button.locked {
  border-color: #aaa59c;
  background: #eae6de;
  box-shadow: none;
}

.campaign-page .level-number {
  color: var(--color-text);
}

.campaign-page .level-stars {
  color: #c78310;
}

/* Compact phone layout fixes from simulator review */
.campaign-page .category-header {
  display: flex;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  align-items: center;
  margin: 0;
}

.campaign-page .category-header.card-pressed {
  opacity: 0.88;
  transform: none;
}

.campaign-page .category-copy {
  overflow: hidden;
}

.campaign-page .category-description {
  width: 100%;
}

.campaign-page .level-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.campaign-page .level-button {
  display: flex;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 112rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 10rpx 6rpx;
  overflow: hidden;
  text-align: center;
}

.campaign-page .level-button.level-pressed {
  box-shadow: 1rpx 1rpx 0 rgba(41, 45, 58, 0.12);
}

.campaign-page .level-number,
.campaign-page .level-label,
.campaign-page .level-stars {
  width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campaign-page .level-number {
  font-size: 29rpx;
  line-height: 1.1;
}

.campaign-page .level-label {
  margin-top: 5rpx;
  font-size: 18rpx;
  line-height: 1.2;
}

.campaign-page .level-stars {
  margin-top: 7rpx;
  font-size: 17rpx;
  line-height: 1.2;
  letter-spacing: 0;
}

/* Unified campaign typography */
.campaign-page .progress-copy view text {
  font-size: 36rpx;
}

.campaign-page .progress-copy view,
.campaign-page .progress-copy > text {
  font-size: 22rpx;
}

.campaign-page .category-name {
  font-size: 28rpx;
}

.campaign-page .category-description {
  font-size: 22rpx;
}

.campaign-page .category-stars {
  font-size: 20rpx;
}

.campaign-page .difficulty-line {
  font-size: 20rpx;
}

.campaign-page .level-number {
  font-size: 28rpx;
}

.campaign-page .level-label {
  font-size: 20rpx;
}

.campaign-page .level-stars {
  font-size: 18rpx;
}
