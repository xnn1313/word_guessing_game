.campaign-page {
  padding-top: 22rpx;
}

.campaign-progress {
  position: relative;
  margin-top: 26rpx;
  padding: 24rpx 28rpx 24rpx 34rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: var(--color-night);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(22, 54, 58, 0.16);
}

.campaign-progress::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 7rpx;
  background: linear-gradient(180deg, var(--color-primary), var(--color-accent));
  content: "";
}

.progress-copy {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.progress-copy view,
.progress-copy > text {
  color: rgba(255, 255, 255, 0.62);
  font-size: var(--font-label);
}

.progress-copy view text {
  color: var(--color-accent);
  font-size: 36rpx;
  font-weight: 820;
  font-variant-numeric: tabular-nums;
}

.progress-track {
  height: 11rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
}

.progress-fill {
  min-width: 4rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--color-accent);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.category {
  overflow: hidden;
  border: 2rpx solid var(--color-border);
  border-radius: 22rpx;
  background: var(--color-surface);
  box-shadow: 0 7rpx 20rpx rgba(22, 54, 58, 0.06);
}

.category-header {
  display: flex;
  width: 100%;
  min-width: 0;
  min-height: 122rpx;
  align-items: center;
  padding: 18rpx 20rpx;
  text-align: left;
}

.category-header.expanded {
  background: #edf7f4;
}

.category-header.card-pressed {
  transform: none;
}

.category-emoji {
  display: grid;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 19rpx;
  background: #ffe3a0;
  font-size: 34rpx;
}

.category-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 18rpx;
  overflow: hidden;
}

.category-name {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 780;
}

.category-description {
  width: 100%;
  overflow: hidden;
  margin-top: 4rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-track {
  width: 160rpx;
  height: 7rpx;
  margin-top: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e2eae7;
}

.category-track view {
  min-width: 3rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--color-primary);
}

.category-right {
  display: flex;
  flex: 0 0 auto;
  align-items: flex-end;
  flex-direction: column;
  margin-left: 12rpx;
}

.category-stars {
  color: var(--color-primary-dark);
  font-size: var(--font-caption);
  font-weight: 740;
}

.category-chevron {
  margin-top: 4rpx;
  color: var(--color-primary-dark);
  font-size: 28rpx;
  transition: transform 200ms ease;
}

.category-chevron.open {
  transform: rotate(180deg);
}

.level-area {
  padding: 0 18rpx 20rpx;
  border-top: 2rpx solid var(--color-border);
  background: var(--color-surface-soft);
}

.difficulty-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 16rpx 4rpx;
  color: var(--color-muted);
  font-size: var(--font-caption);
}

.difficulty-dots {
  display: flex;
  max-width: 240rpx;
  flex: 1;
  align-items: center;
  justify-content: space-between;
}

.difficulty-dots view {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #57ad85;
}

.difficulty-dots view:nth-child(2) { background: #94ad59; }
.difficulty-dots view:nth-child(3) { background: #d2a543; }
.difficulty-dots view:nth-child(4) { background: #d77a43; }
.difficulty-dots view:nth-child(5) { background: #d45b61; }

.level-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.level-button {
  display: flex;
  width: 100%;
  min-width: 0;
  min-height: 112rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 10rpx 6rpx;
  overflow: hidden;
  border: 2rpx solid var(--color-border-strong);
  border-top-width: 6rpx;
  border-radius: 15rpx;
  background: var(--color-surface);
  line-height: 1.15;
  text-align: center;
}

.level-button.difficulty-1 { border-top-color: #57ad85; }
.level-button.difficulty-2 { border-top-color: #94ad59; }
.level-button.difficulty-3 { border-top-color: #d2a543; }
.level-button.difficulty-4 { border-top-color: #d77a43; }
.level-button.difficulty-5 { border-top-color: #d45b61; }

.level-button.locked {
  border-color: #d4dcd8;
  background: #e9eeeb;
  color: #96a19e;
}

.level-number,
.level-label,
.level-stars {
  display: block;
  width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level-number {
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.1;
}

.level-label {
  margin-top: 5rpx;
  color: var(--color-muted);
  font-size: 19rpx;
}

.level-stars {
  margin-top: 7rpx;
  color: #a66c12;
  font-size: 18rpx;
}

.locked .level-number,
.locked .level-label,
.locked .level-stars {
  color: #96a19e;
}
